# DisplayXR Browser build configuration — sourced by every script in this dir.
# The single source of truth for the pinned Chromium milestone. Bump this on each
# monthly rebase (see docs/rebase-runbook.md), regenerate patches/, re-verify.

# Pinned Chromium *stable* milestone tag (chromiumdash). The patch series in
# patches/ is generated against exactly this tag.
CHROMIUM_TAG="${CHROMIUM_TAG:-150.0.7871.129}"

# Local Chromium checkout (the src/ dir that holds .gn, chrome/, out/).
CHROMIUM_SRC="${CHROMIUM_SRC:-C:/src/chromium/src}"

# depot_tools install (autoninja/gn/gclient live here). Must be on PATH for a build.
DEPOT_TOOLS="${DEPOT_TOOLS:-C:/src/depot_tools}"

# Build output dir under $CHROMIUM_SRC/out. Official static distributable build.
OUT_DIR="${OUT_DIR:-Official}"

# No Google RBE and no Win toolchain download on a self-hosted box.
export DEPOT_TOOLS_WIN_TOOLCHAIN=0
