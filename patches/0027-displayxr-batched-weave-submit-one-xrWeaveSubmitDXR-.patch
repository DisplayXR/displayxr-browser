   WeaveInput& in = inputs_[target_id];
   const bool sync = SyncMode();
   if ((!sync && (in.in_flight || !weaver_.is_bound())) || window_rect.IsEmpty() ||
@@ -402,6 +419,265 @@ bool DisplayXRWeaveGpu::SubmitSync(WeaveInput& in,
