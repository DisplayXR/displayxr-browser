+bool DisplayXRWeaveGpu::SubmitBatchSync() {
+  if (!batch_open_) {
+    return false;
+  }
+  batch_open_ = false;
+  const bool had_copies = batch_mutex_held_ && !batch_entries_.empty();
+  if (batch_mutex_held_) {
+    // Hand the input to the service in the "caller done writing" state.
+    context_->Flush();
+    shared_input_.input_mutex->ReleaseSync(0);
+    batch_mutex_held_ = false;
+  }
+  if (!had_copies) {
+    return false;
+  }
+
+  // #625 phase-snap (CEF parity): once per batch frame, like the per-target
+  // path did once per submit.
+  DisplayXRWeaveClient::SnapWindowIfMoved();
+
+  std::vector<DisplayXRWeaveClient::WeaveRect> rects;
+  rects.reserve(batch_entries_.size());
+  for (const BatchEntry& e : batch_entries_) {
+    rects.push_back({e.rect.x(), e.rect.y(), e.rect.width(), e.rect.height()});
+  }
+
+  const base::TimeTicks t0 = base::TimeTicks::Now();
+  DisplayXRWeaveClient::WeaveSubmitResult sr = DisplayXRWeaveClient::SubmitBatch(
+      reinterpret_cast<uintptr_t>(shared_input_.input_handle), rects,
+      /*input_is_dxgi=*/true);
+  const base::TimeDelta dt = base::TimeTicks::Now() - t0;
+  if (!sr.ok) {
+    static int s_fail = 0;
+    if (s_fail < 3) {
+      ++s_fail;
+      LOG(ERROR) << "[DisplayXR] batch weave submit failed (n=" << rects.size()
+                 << ")";
+    }
+    return false;
+  }
+  // Throttled batch-cost telemetry: this ONE call replaced n serialized ~1 ms
+  // submits — the number that lifts the visible-element ceiling.
+  static base::TimeTicks s_last_log;
+  if (base::TimeTicks::Now() - s_last_log > base::Seconds(5)) {
+    s_last_log = base::TimeTicks::Now();
+    VLOG(1) << "[DisplayXR] batch weave: n=" << rects.size() << " in "
+            << dt.InMicroseconds() << "us (one submit) " << sr.width << "x"
+            << sr.height << " eyes_valid=" << sr.eyes_valid;
+  }
+
+  // Store one result per target, exactly as SubmitSync stores per submit, so
+  // Viz's Phase-B import/draw path is unchanged. The fresh woven/fence handles
+  // (first submit / resize) ride on the FIRST entry; every other entry carries
+  // handle 0 = reuse the imported shared texture — Phase B already imports the
+  // window-sized woven output once and draws each rect's region from it.
+  bool first = true;
+  for (const BatchEntry& e : batch_entries_) {
+    PendingResult& pending = results_[e.target_id];
+    Result r;
+    r.ok = true;
+    r.fence_value = sr.fence_value;
+    r.width = sr.width;
+    r.height = sr.height;
+    if (first) {
+      first = false;
+      if (sr.woven_handle) {
+        r.woven_handle = sr.woven_handle;
+      }
+      if (sr.fence_handle) {
+        r.fence_handle = sr.fence_handle;
+      }
+    }
+    // Carry a still-pending fresh handle forward (same texture) so Viz never
+    // misses an import — mirrors SubmitSync/OnWeaveReply.
+    if (!r.woven_handle && pending.have) {
+      r.woven_handle = pending.result.woven_handle;
+      pending.result.woven_handle = 0;
+    }
+    if (!r.fence_handle && pending.have) {
+      r.fence_handle = pending.result.fence_handle;
+      pending.result.fence_handle = 0;
+    }
+    if (pending.have) {
+      CloseResultHandles(pending.result);
+    }
+    pending.result = r;
+    pending.have = true;
+  }
+  batch_entries_.clear();
+  return true;
+}
