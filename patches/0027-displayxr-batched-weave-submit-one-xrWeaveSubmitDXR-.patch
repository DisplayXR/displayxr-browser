 }
 
+bool DisplayXRWeaveGpu::BatchMode() const {
+  // Spec v3 is required for the chained rect-array submit; a spec-v2 runtime
+  // keeps the per-target SubmitSync loop (still correct, just N submits).
+  return SyncMode() && DisplayXRWeaveClient::WeaveSpecVersion() >= 3;
+}
+
+void DisplayXRWeaveGpu::BeginBatchSync(const gfx::Size& window_size) {
+  // Defensive: a prior frame that never reached SubmitBatchSync must not leave
+  // the shared input's keyed mutex held.
+  if (batch_mutex_held_ && shared_input_.input_mutex) {
+    shared_input_.input_mutex->ReleaseSync(0);
+  }
+  batch_mutex_held_ = false;
+  batch_open_ = true;
+  batch_size_ = window_size;
+  batch_entries_.clear();
+}
+
+bool DisplayXRWeaveGpu::EnsureBatchInputAndAcquire(ID3D11Device* device,
+                                                   DXGI_FORMAT format) {
+  if (!batch_open_ || batch_size_.IsEmpty() || !device) {
+    return false;
+  }
+  // All of a frame's copies share ONE input; a mid-frame format mismatch would
+  // recreate it under the held mutex and lose the earlier copies. In practice
+  // every canvas copy comes from the same composited output format.
+  if (!batch_entries_.empty() && shared_input_.input_tex &&
+      shared_input_.input_format != format) {
+    static bool logged_fmt = false;
+    if (!logged_fmt) {
+      logged_fmt = true;
+      LOG(ERROR) << "[DisplayXR] batch weave: mixed input formats in one frame ("
+                 << shared_input_.input_format << " vs " << format
+                 << ") — skipping this target";
+    }
+    return false;
+  }
+  if (!EnsureInput(shared_input_, device,
+                   format, static_cast<uint32_t>(batch_size_.width()),
+                   static_cast<uint32_t>(batch_size_.height()))) {
+    return false;
+  }
+  if (!batch_mutex_held_) {
+    if (shared_input_.input_mutex->AcquireSync(0, 1000) != S_OK) {
+      LOG(ERROR) << "[DisplayXR] batch weave: AcquireSync(0) failed";
+      return false;
+    }
+    batch_mutex_held_ = true;
+  }
+  return true;
+}
+
+bool DisplayXRWeaveGpu::BatchCopyCanvas(ID3D11Device* device,
+                                        ID3D11Texture2D* canvas_tex,
+                                        UINT array_slice,
+                                        const gfx::Rect& src_rect,
+                                        const gfx::Rect& window_rect,
+                                        uint32_t target_id) {
+  if (window_rect.IsEmpty() || !device || !canvas_tex) {
+    return false;
+  }
+  D3D11_TEXTURE2D_DESC cd = {};
+  canvas_tex->GetDesc(&cd);
+  if (!EnsureBatchInputAndAcquire(device, cd.Format)) {
+    return false;
+  }
+
+  // Copy the canvas sub-rect into the shared window-sized input AT THE
+  // ELEMENT'S OWN WINDOW POSITION (the v3 batch layout: sample position ==
+  // weave position). Same clamping as the per-target path.
+  D3D11_BOX box = {};
+  box.left = static_cast<UINT>(src_rect.x());
+  box.top = static_cast<UINT>(src_rect.y());
+  box.front = 0;
+  box.right = static_cast<UINT>(src_rect.right());
+  box.bottom = static_cast<UINT>(src_rect.bottom());
+  box.back = 1;
+  if (box.right > cd.Width) {
+    box.right = cd.Width;
+  }
+  if (box.bottom > cd.Height) {
+    box.bottom = cd.Height;
+  }
+  // Keep the copy inside the shared input (window_rect is window-clipped by
+  // the caller; this guards a race with a same-frame window shrink).
+  const uint32_t dst_x = static_cast<uint32_t>(std::max(window_rect.x(), 0));
+  const uint32_t dst_y = static_cast<uint32_t>(std::max(window_rect.y(), 0));
+  if (dst_x >= shared_input_.input_w || dst_y >= shared_input_.input_h) {
+    return false;
+  }
+  const uint32_t max_w = shared_input_.input_w - dst_x;
+  const uint32_t max_h = shared_input_.input_h - dst_y;
+  if (box.right - box.left > max_w) {
+    box.right = box.left + max_w;
+  }
+  if (box.bottom - box.top > max_h) {
+    box.bottom = box.top + max_h;
+  }
+  if (box.right <= box.left || box.bottom <= box.top) {
+    return false;
+  }
+
+  context_->CopySubresourceRegion(shared_input_.input_tex.Get(),
+                                  /*DstSubresource=*/0, dst_x, dst_y,
+                                  /*DstZ=*/0, canvas_tex, array_slice, &box);
+  batch_entries_.push_back({target_id, window_rect});
+  return true;
+}
+
+bool DisplayXRWeaveGpu::BatchCopyPixels(ID3D11Device* device,
+                                        const uint8_t* bgra_pixels,
+                                        uint32_t stride,
+                                        const gfx::Rect& window_rect,
+                                        uint32_t target_id) {
+  if (window_rect.IsEmpty() || !device || !bgra_pixels) {
+    return false;
+  }
+  if (!EnsureBatchInputAndAcquire(device, DXGI_FORMAT_B8G8R8A8_UNORM)) {
+    return false;
+  }
+
+  // Reuse the per-target upload texture (CPU staging) from the inputs_ pool;
+  // in batch mode only the upload fields of that entry are used.
+  WeaveInput& in = inputs_[target_id];
+  const uint32_t w = static_cast<uint32_t>(window_rect.width());
+  const uint32_t h = static_cast<uint32_t>(window_rect.height());
+  if (!in.upload_tex || in.upload_w != w || in.upload_h != h) {
+    in.upload_tex.Reset();
+    D3D11_TEXTURE2D_DESC ud = {};
+    ud.Width = w;
+    ud.Height = h;
+    ud.MipLevels = 1;
+    ud.ArraySize = 1;
+    ud.Format = DXGI_FORMAT_B8G8R8A8_UNORM;
+    ud.SampleDesc.Count = 1;
+    ud.Usage = D3D11_USAGE_DEFAULT;
+    ud.BindFlags = D3D11_BIND_SHADER_RESOURCE;
+    if (FAILED(device_->CreateTexture2D(&ud, nullptr, &in.upload_tex))) {
+      LOG(ERROR) << "[DisplayXR] batch weave: CreateTexture2D(upload) failed";
+      in.upload_tex.Reset();
+      return false;
+    }
+    in.upload_w = w;
+    in.upload_h = h;
+  }
+  context_->UpdateSubresource(in.upload_tex.Get(), /*DstSubresource=*/0,
+                              /*pDstBox=*/nullptr, bgra_pixels, stride,
+                              /*SrcDepthPitch=*/0);
+  const uint32_t dst_x = static_cast<uint32_t>(std::max(window_rect.x(), 0));
+  const uint32_t dst_y = static_cast<uint32_t>(std::max(window_rect.y(), 0));
+  if (dst_x >= shared_input_.input_w || dst_y >= shared_input_.input_h) {
+    return false;
+  }
+  D3D11_BOX box = {};
+  box.right = std::min(w, shared_input_.input_w - dst_x);
+  box.bottom = std::min(h, shared_input_.input_h - dst_y);
+  box.back = 1;
+  if (box.right == 0 || box.bottom == 0) {
+    return false;
+  }
+  context_->CopySubresourceRegion(shared_input_.input_tex.Get(),
+                                  /*DstSubresource=*/0, dst_x, dst_y,
+                                  /*DstZ=*/0, in.upload_tex.Get(), 0, &box);
