+// Batched weave (spec v3, #625): ONE xrWeaveSubmitDXR carrying up to
+// XR_WEAVE_SUBMIT_MAX_RECTS_DXR rects via the chained XrWeaveSubmitRectsDXR.
+// The input is WINDOW-sized with each rect's SBS content at its own window
+// position (the v3 batch layout; base rect ignored). More rects than the cap
+// chunk into multiple batched calls — the runtime's weave fence is one
+// monotonic timeline, so waiting the LAST chunk's fence value covers all.
+DisplayXRWeaveClient::WeaveSubmitResult SubmitBatchWin(
+    uintptr_t input_handle,
+    const std::vector<DisplayXRWeaveClient::WeaveRect>& rects,
+    bool input_is_dxgi) {
+  const size_t rect_count = rects.size();
+  DisplayXRWeaveClient::WeaveSubmitResult result;
+  WeaveClientState& s = State();
+  if (s.session == XR_NULL_HANDLE || !s.submit || rect_count == 0) {
+    return result;  // ok=false: dormant / failed init / nothing to weave
+  }
+  if (s.weave_spec_version < 3) {
+    static bool logged_v2 = false;
+    if (!logged_v2) {
+      logged_v2 = true;
+      VLOG(1) << "[DisplayXR] SubmitBatch on a spec-v" << s.weave_spec_version
+              << " runtime — caller must use the per-element Submit loop";
+    }
+    return result;
+  }
+
+  static bool logged_chunk = false;
+  if (rect_count > XR_WEAVE_SUBMIT_MAX_RECTS_DXR && !logged_chunk) {
+    logged_chunk = true;
+    VLOG(1) << "[DisplayXR] SubmitBatch: " << rect_count
+            << " rects exceed the per-call cap " << XR_WEAVE_SUBMIT_MAX_RECTS_DXR
+            << " — chunking into multiple batched submits";
+  }
+
+  XrRect2Di xr_rects[XR_WEAVE_SUBMIT_MAX_RECTS_DXR];
+  size_t done = 0;
+  while (done < rect_count) {
+    const size_t n =
+        std::min<size_t>(rect_count - done, XR_WEAVE_SUBMIT_MAX_RECTS_DXR);
+    for (size_t i = 0; i < n; ++i) {
+      const DisplayXRWeaveClient::WeaveRect& r = rects[done + i];
+      XrRect2Di& xr = UNSAFE_TODO(xr_rects[i]);
+      xr.offset.x = r.x;
+      xr.offset.y = r.y;
+      xr.extent.width = r.w;
+      xr.extent.height = r.h;
+    }
+
+    XrWeaveSubmitRectsDXR batch = {XR_TYPE_WEAVE_SUBMIT_RECTS_DXR};
+    batch.rectCount = static_cast<uint32_t>(n);
+    batch.rects = xr_rects;
+
+    XrWeaveSubmitInfoDXR in = {XR_TYPE_WEAVE_SUBMIT_INFO_DXR};
+    in.next = &batch;
+    in.inputTexture = reinterpret_cast<void*>(input_handle);
+    in.inputIsDxgi = input_is_dxgi ? XR_TRUE : XR_FALSE;
+    // Base rect is ignored under the batch chain; keep it zero.
+
+    XrWeaveOutputDXR out = {XR_TYPE_WEAVE_OUTPUT_DXR};
+    const XrResult sr = s.submit(s.session, &in, &out);
+    if (XR_FAILED(sr)) {
+      static int s_fail = 0;
+      if (s_fail < 3) {
+        ++s_fail;
+        LOG(ERROR) << "[DisplayXR] xrWeaveSubmitDXR(batch n=" << n
+                   << ") failed: " << sr;
+      }
+      result.ok = false;
+      return result;
+    }
+
+    // Handles show up on the first submit / resize; keep whichever chunk
+    // returned them. Scalars (fence value, dims, eyes) track the LAST chunk.
+    result.ok = true;
+    if (out.weavedTexture) {
+      result.woven_handle = reinterpret_cast<uintptr_t>(out.weavedTexture);
+    }
+    if (out.fence) {
+      result.fence_handle = reinterpret_cast<uintptr_t>(out.fence);
+    }
+    result.fence_value = out.fenceValue;
+    result.width = out.width;
+    result.height = out.height;
+    result.eyes_valid = (out.eyesValid == XR_TRUE);
+    result.eyes.clear();
+    if (result.eyes_valid && out.eyeCount > 0) {
+      const uint32_t en = out.eyeCount > XR_WEAVE_MAX_EYES_DXR
+                              ? XR_WEAVE_MAX_EYES_DXR
+                              : out.eyeCount;
+      result.eyes.reserve(en * 3u);
+      for (uint32_t i = 0; i < en; ++i) {
+        const XrVector3f& eye = UNSAFE_TODO(out.eyes[i]);
+        result.eyes.push_back(eye.x);
+        result.eyes.push_back(eye.y);
+        result.eyes.push_back(eye.z);
+      }
+    }
+    done += n;
+  }
+
+  // B3d: cache eyes + the first rect (a representative element) for the
+  // DisplayXRService pull, mirroring the per-element Submit path.
+  s.latest_eyes = result.eyes;
+  s.latest_eyes_valid = result.eyes_valid;
+  const DisplayXRWeaveClient::WeaveRect& r0 = rects[0];
+  s.rect_x = r0.x;
+  s.rect_y = r0.y;
+  s.rect_w = r0.w > 0 ? static_cast<uint32_t>(r0.w) : 0u;
+  s.rect_h = r0.h > 0 ? static_cast<uint32_t>(r0.h) : 0u;
+  s.rect_valid = (r0.w > 0 && r0.h > 0);
+  return result;
+}
