+  // One window-relative device-pixel rect for SubmitBatch. Kept OpenXR- and
+  // gfx-free so this header stays includable from chromium_code TUs.
+  struct WeaveRect {
+    int32_t x = 0;
+    int32_t y = 0;
+    int32_t w = 0;
+    int32_t h = 0;
+  };
+
+  // Batched weave (XR_DXR_weave spec v3, #625): ONE xrWeaveSubmitDXR carrying
+  // |rects| via a chained XrWeaveSubmitRectsDXR. |input_handle| must be a
+  // WINDOW-sized keyed-mutex texture with each rect's SBS content at that
+  // rect's own window position (the v3 batch input-layout contract — NOT the
+  // per-element atlas Submit() takes). Chunks internally when |rects| exceeds
+  // the extension's per-call cap (each chunk gets its own fence value; the
+  // returned result carries the LAST chunk's fence value, which covers all
+  // earlier chunks on the runtime's single monotonic weave fence). Requires
+  // WeaveSpecVersion() >= 3; returns ok=false otherwise (callers fall back to
+  // per-element Submit() loops). Windows-only; a stub elsewhere.
+  static WeaveSubmitResult SubmitBatch(uintptr_t input_handle,
+                                       const std::vector<WeaveRect>& rects,
+                                       bool input_is_dxgi = false);
+
+  // The XR_DXR_weave spec version the RUNTIME reported at extension
+  // enumeration (0 until initialized / extension absent). >= 3 means the
+  // batched SubmitBatch path is available.
+  static uint32_t WeaveSpecVersion();
