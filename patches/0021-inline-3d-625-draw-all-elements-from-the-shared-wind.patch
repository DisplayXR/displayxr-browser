diff --git a/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.h b/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.h
index 098b78cf95b02..3efb289c0eba4 100644
--- a/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.h
+++ b/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.h
@@ -692,6 +692,17 @@ class SkiaOutputSurfaceImplOnGpu
   // most one target is submitted per frame; this rotates which one so all
   // targets refresh over successive frames (weave at reply cadence).
   size_t displayxr_next_submit_ = 0;
+
+  // The runtime weaves EVERY submitted sub-rect into ONE window-sized handback
+  // texture (process_atlas writes only the sub-rect, never clearing → the output
+  // accumulates all elements at their window positions). So the woven output is a
+  // single shared texture, not per-element: import it once (fresh handle arrives
+  // only on the first submit / a window-size change) and draw each inline-3d
+  // rect's region from it. |displayxr_shared_woven_fence_| is GPU-waited to the
+  // latest submit's fence value before sampling.
+  gpu::Mailbox displayxr_shared_woven_mailbox_;
+  scoped_refptr<gfx::D3DSharedFence> displayxr_shared_woven_fence_;
+  gfx::Size displayxr_shared_woven_size_;
 #endif
 
   THREAD_CHECKER(thread_checker_);
