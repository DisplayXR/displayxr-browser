From 38f88771248efb84c7af3ae4be052264cd2d2410 Mon Sep 17 00:00:00 2001
From: dfattal <dfattal@gmail.com>
Date: Tue, 14 Jul 2026 17:06:40 -0700
Subject: [PATCH 31/41] TEMP DIAG (#625): log the inline-3d gate + the
 GPU->browser eye feed

Throwaway instrumentation to find why the inline-3d 2-view path stays off
(viewCount==1, mono at origin) even with the eye forwarding in place:
  - renderer: which of eyes_valid / info / rect_valid / output dims fails
  - GPU: is ReportEyesToBrowser firing, is the remote bound
  - browser: did the eyes land in the cache
Drop this commit once the chain is understood.
---
 .../displayxr/browser/displayxr_weaver_impl.cc       |  7 +++++++
 components/displayxr/gpu/displayxr_weave_gpu.cc      |  7 +++++++
 third_party/blink/renderer/modules/xr/xr_session.cc  | 12 ++++++++++++
 3 files changed, 26 insertions(+)

diff --git a/components/displayxr/browser/displayxr_weaver_impl.cc b/components/displayxr/browser/displayxr_weaver_impl.cc
index 471d02908596b..16a8ae1ea7480 100644
--- a/components/displayxr/browser/displayxr_weaver_impl.cc
+++ b/components/displayxr/browser/displayxr_weaver_impl.cc
@@ -74,6 +74,13 @@ void DisplayXRWeaverImpl::WeaveSubmit(gfx::DXGIHandle texture,
 
 void DisplayXRWeaverImpl::ReportInline3DEyes(const std::vector<float>& eyes,
                                              bool eyes_valid) {
+  // TEMP DIAG (#625): did the eye feed reach the browser process?
+  static int s_eye_log = 0;
+  if (s_eye_log < 5) {
+    ++s_eye_log;
+    VLOG(1) << "[DisplayXR] browser cached GPU eyes: n=" << eyes.size()
+            << " valid=" << eyes_valid;
+  }
   // Sync mode: the GPU process performed the submit and got the eyes, so seed
   // the browser-side cache DisplayXRService serves to the renderer. Without
   // this the renderer never sees valid eyes and UpdateInline3DViews is skipped.
diff --git a/components/displayxr/gpu/displayxr_weave_gpu.cc b/components/displayxr/gpu/displayxr_weave_gpu.cc
index 86915f2cb3627..93145169df9b8 100644
--- a/components/displayxr/gpu/displayxr_weave_gpu.cc
+++ b/components/displayxr/gpu/displayxr_weave_gpu.cc
@@ -64,6 +64,13 @@ void DisplayXRWeaveGpu::ReportEyesToBrowser(const std::vector<float>& eyes,
   // inline-3d session silently serves a single mono view at the origin (no
   // cube, no look-around). Fire-and-forget: one frame of staleness is fine and
   // a reply would cost a round-trip on the present thread.
+  // TEMP DIAG (#625): is the GPU end of the eye feed actually firing?
+  static int s_eye_log = 0;
+  if (s_eye_log < 5) {
+    ++s_eye_log;
+    VLOG(1) << "[DisplayXR] GPU->browser eyes: bound=" << weaver_.is_bound()
+            << " n=" << eyes.size() << " valid=" << eyes_valid;
+  }
   if (!weaver_.is_bound()) {
     return;
   }
diff --git a/third_party/blink/renderer/modules/xr/xr_session.cc b/third_party/blink/renderer/modules/xr/xr_session.cc
index 1c0afb7437ae0..08eeaf98d6c0e 100644
--- a/third_party/blink/renderer/modules/xr/xr_session.cc
+++ b/third_party/blink/renderer/modules/xr/xr_session.cc
@@ -2496,6 +2496,18 @@ void XRSession::UpdateInlineView() {
   // negative control: no service -> stays mono, inert).
   if (is_inline_3d_) {
     RequestInline3DState();
+    // TEMP DIAG (#625): which gate keeps the 2-view inline-3d path off.
+    {
+      static int s_gate_log = 0;
+      if (s_gate_log < 20) {
+        ++s_gate_log;
+        VLOG(1) << "[DisplayXR] inline3d gate: eyes_valid=" << inline_3d_eyes_valid_
+                << " info=" << (inline_3d_info_ ? 1 : 0) << " rect_valid="
+                << (inline_3d_info_ ? (inline_3d_info_->rect_valid ? 1 : 0) : -1)
+                << " out=" << output_width_ << "x" << output_height_
+                << " scene_layer=" << (inline_3d_scene_layer_ ? 1 : 0);
+      }
+    }
     if (inline_3d_eyes_valid_ && inline_3d_info_ &&
         inline_3d_info_->rect_valid && output_width_ > 0 &&
         output_height_ > 0) {
-- 
