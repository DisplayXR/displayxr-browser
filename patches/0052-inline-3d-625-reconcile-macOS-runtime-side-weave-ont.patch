+  // Record the release accounting for the presented scratch so mac's
+  // DidReceiveReleasedOverlays finds it. The scratch's lifetime is owned by
+  // |inline_3d_scratch_|, so a bare-mailbox lock (which keeps nothing alive) is
+  // all that's needed.
+  if (lock_index == std::numeric_limits<size_t>::max()) {
+    // Direct-scanout source: had no lock; the original canvas backing lives in
+    // |render_pass_backings_| (stays alive for this frame's GPU weave), so just
+    // ADD a bare-mailbox lock for the scratch.
+    locks->emplace_back(slot);
+  } else {
+    // PrepareRenderPassOverlay source: hold the original render_pass_lock one
+    // frame (keeps the backing in-flight for the GPU weave, and off the
+    // awaiting-release path since the original is no longer presented), and
+    // REPLACE its lock with a bare-mailbox lock on the presented scratch.
+    inline_3d_held_source_locks_.push_back(std::move((*locks)[lock_index]));
