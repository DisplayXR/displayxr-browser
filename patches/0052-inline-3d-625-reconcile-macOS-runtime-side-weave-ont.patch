+bool SkiaOutputSurfaceImplOnGpu::EnsureScratchClearedMac(
+    const gpu::Mailbox& scratch_mailbox) {
+  if (scratch_mailbox.IsZero()) {
+    return false;
+  }
+  if (displayxr_cleared_scratch_mac_.count(scratch_mailbox)) {
+    return true;
+  }
+  // A fresh SharedImage is UNCLEARED; Skia-write it once (marks cleared) so the
+  // overlay present path's BeginScopedReadAccess accepts it. The woven pixels
+  // are Metal-blitted into its IOSurface each frame (incl. this one), so the
+  // clear colour is immediately overwritten.
+  auto rep = shared_image_representation_factory_->ProduceSkia(
+      scratch_mailbox, context_state_.get());
+  if (!rep) {
+    return false;
+  }
+  std::vector<GrBackendSemaphore> sbegin, send;
+  SkSurfaceProps props;
+  auto write = rep->BeginScopedWriteAccess(
+      /*final_msaa_count=*/0, props, &sbegin, &send,
+      gpu::SharedImageRepresentation::AllowUnclearedAccess::kYes);
+  if (!write || !write->surface()) {
+    return false;
+  }
+  SkSurface* surface = write->surface();
+  if (!sbegin.empty()) {
+    surface->wait(sbegin.size(), sbegin.data(),
+                  /*deleteSemaphoresAfterWait=*/false);
+  }
+  surface->getCanvas()->clear(SkColors::kBlack);
+  FlushSurface(surface, send, write.get());
+  if (gr_context()) {
+    gr_context()->submit();
+  }
+  if (graphite_shared_context()) {
+    graphite_shared_context()->submit();
+  }
+  displayxr_cleared_scratch_mac_.insert(scratch_mailbox);
+  return true;
+}
