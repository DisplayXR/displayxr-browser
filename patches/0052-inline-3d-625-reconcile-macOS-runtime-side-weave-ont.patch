+  int input_w = 0;  // packed total width (sum of element widths)
+  int input_h = 0;  // max element height
+  for (size_t i = 0; i < overlays_.size(); ++i) {
+    const auto& o = overlays_[i];
+    if (o.displayxr_weave_source.IsZero() || o.mailbox.IsZero()) {
+      continue;
+    }
+    auto rep = shared_image_representation_factory_->ProduceOverlayForWeave(
+        o.displayxr_weave_source);
+    auto acc = rep ? rep->BeginScopedReadAccess() : nullptr;
+    gfx::ScopedIOSurface ios =
+        acc ? acc->GetIOSurface() : gfx::ScopedIOSurface();
+    if (!ios) {
+      continue;
+    }
+    const int iw = static_cast<int>(IOSurfaceGetWidth(ios.get()));
+    const int ih = static_cast<int>(IOSurfaceGetHeight(ios.get()));
+    weaves.push_back({i, o.displayxr_weave_target, ios, iw, ih, input_w});
+    input_w += iw;  // next element packs to the right
+    input_h = std::max(input_h, ih);
+  }
+  if (weaves.empty()) {
+    return;
+  }
+
+  // Phase A: weave every canvas at full backing resolution (correct 2x1
+  // un-squeeze), one batched synchronous submit.
+  provider->BeginBatchSync(gfx::Size(input_w, input_h));
+  for (const Weave& w : weaves) {
+    provider->WeaveCanvasMac(w.source_ios.get(), gfx::Rect(0, 0, w.iw, w.ih),
+                             gfx::Rect(w.px, 0, w.iw, w.ih), w.target);
+  }
+  const bool submit_ok = provider->SubmitBatchSync();
+  if (!submit_ok) {
+    return;
+  }
+
+  // Phase B: create/size each target's scratch (SkiaRenderer minted the mailbox
+  // but couldn't size it — the source's real size only lives in its IOSurface,
+  // which we read above), then blit the woven output into the scratch IOSurface.
+  for (const Weave& w : weaves) {
+    const gpu::Mailbox scratch = overlays_[w.idx].mailbox;
+    if (scratch.IsZero()) {
+      continue;
+    }
+    const gfx::Size want(w.iw, w.ih);
+    auto it = displayxr_scratch_sizes_mac_.find(scratch);
+    if (it == displayxr_scratch_sizes_mac_.end() || it->second != want) {
+      if (it != displayxr_scratch_sizes_mac_.end()) {
+        shared_image_factory_->DestroySharedImage(scratch);
+        displayxr_cleared_scratch_mac_.erase(scratch);
+        displayxr_scratch_sizes_mac_.erase(it);
+      }
+      // SCANOUT routes the scratch to IOSurfaceImageBacking (BGRA8) — both
+      // Skia-writable (the one-time clear below) and Overlay-readable
+      // (ProduceOverlayForWeave -> GetIOSurface, blitted into and presented).
+      gpu::SharedImageInfo si_info(
+          SinglePlaneFormat::kBGRA_8888, want, gfx::ColorSpace::CreateSRGB(),
+          kTopLeft_GrSurfaceOrigin, kPremul_SkAlphaType,
+          gpu::SHARED_IMAGE_USAGE_SCANOUT | gpu::SHARED_IMAGE_USAGE_DISPLAY_READ |
+              gpu::SHARED_IMAGE_USAGE_DISPLAY_WRITE,
+          "DisplayXRInline3DWovenScratch");
+      if (!shared_image_factory_->CreateSharedImage(scratch, si_info,
+                                                    gpu::kNullSurfaceHandle)) {
+        continue;
+      }
+      displayxr_scratch_sizes_mac_[scratch] = want;
+    }
+    const bool cleared = EnsureScratchClearedMac(scratch);
+    if (!cleared) {
+      continue;
+    }
+    auto rep =
+        shared_image_representation_factory_->ProduceOverlayForWeave(scratch);
+    auto acc = rep ? rep->BeginScopedReadAccess() : nullptr;
+    gfx::ScopedIOSurface dst =
+        acc ? acc->GetIOSurface() : gfx::ScopedIOSurface();
+    if (!dst) {
+      continue;
+    }
+    provider->BlitWovenToMac(dst.get(), gfx::Rect(w.px, 0, w.iw, w.ih));
+  }
+}
