@@ -0,0 +1,104 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef COMPONENTS_DISPLAYXR_GPU_DISPLAYXR_WEAVE_GPU_MAC_H_
+#define COMPONENTS_DISPLAYXR_GPU_DISPLAYXR_WEAVE_GPU_MAC_H_
+
+#include "build/build_config.h"
+
+#if BUILDFLAG(IS_APPLE)
+
+#include <IOSurface/IOSurfaceRef.h>
+
+#include <cstdint>
+#include <vector>
+
+#include "base/apple/scoped_cftyperef.h"
+#include "base/memory/raw_ptr_exclusion.h"
+#include "base/containers/flat_map.h"
+#include "components/viz/service/display_embedder/displayxr_weave_provider.h"
+#include "ui/gfx/geometry/rect.h"
+#include "ui/gfx/geometry/size.h"
+
+namespace displayxr {
+
+// macOS GPU-process implementation of viz::DisplayXRWeaveProvider (#625 PR3).
+//
+// Much simpler than the Windows DisplayXRWeaveGpu: the macOS runtime weave
+// service (#760) is SYNCHRONOUS (it waits on GPU completion before returning),
+// so there is no keyed mutex, no mojo bridge, and no async in-flight tracking.
+// Per frame the batch bracket copies each visible element's SBS sub-rect into
+// ONE shared window-sized input IOSurface (MTLBlit) at its window position, then
+// SubmitBatchSync fires ONE xrWeaveSubmitDXR and stores the woven output
+// IOSurface for Viz to composite (PR4). The GPU-process weave session is brought
+// up in the constructor via InitializeCoreMac().
+//
+// Created + called on the GPU main thread.
+class DisplayXRWeaveGpuMac : public viz::DisplayXRWeaveProvider {
+ public:
+  DisplayXRWeaveGpuMac();
+  DisplayXRWeaveGpuMac(const DisplayXRWeaveGpuMac&) = delete;
+  DisplayXRWeaveGpuMac& operator=(const DisplayXRWeaveGpuMac&) = delete;
+  ~DisplayXRWeaveGpuMac() override;
+
+  // viz::DisplayXRWeaveProvider:
+  bool SubmitInFlight(uint32_t target_id) const override;
+  bool WeaveCanvasMac(IOSurfaceRef canvas_iosurface,
+                      const gfx::Rect& src_rect,
+                      const gfx::Rect& window_rect,
+                      uint32_t target_id) override;
+  bool WeavePixelsMac(const uint8_t* bgra_pixels,
+                      uint32_t stride,
+                      const gfx::Rect& window_rect,
+                      uint32_t target_id) override;
+  bool BlitWovenToMac(IOSurfaceRef dst, const gfx::Rect& src_rect) override;
+  bool TryTakeWovenResult(uint32_t target_id, Result* out) override;
+  void PruneTargets(size_t count) override;
+  bool BatchMode() const override;
+  void BeginBatchSync(const gfx::Size& window_size) override;
+  bool SubmitBatchSync() override;
+
+ private:
+  // Lazily (re)create the shared window-sized input IOSurface (BGRA8, global so
+  // the runtime service can IOSurfaceLookup it by ID). Returns false on failure.
+  bool EnsureSharedInput(const gfx::Size& size);
+
+  // Metal objects, held as void* so this header stays ObjC-free for the C++ TUs
+  // that include it (the embedder ContentGpuClient). Retained/released via
+  // __bridge casts in the .mm.
+  RAW_PTR_EXCLUSION void* device_ = nullptr;  // id<MTLDevice>
+  RAW_PTR_EXCLUSION void* queue_ = nullptr;   // id<MTLCommandQueue>
+
+  base::apple::ScopedCFTypeRef<IOSurfaceRef> input_iosurface_;
+  gfx::Size input_size_;
+
+  // The runtime hands back the woven output IOSurfaceRef on the FIRST submit only
+  // (out.weavedTexture; NULL thereafter — it re-weaves into the same surface).
+  // Cache it so every frame's result carries the live woven surface.
+  base::apple::ScopedCFTypeRef<IOSurfaceRef> cached_woven_;
+
+  bool batch_open_ = false;
+  gfx::Size batch_size_;
+  struct BatchEntry {
+    uint32_t target_id = 0;
+    gfx::Rect rect;  // window-relative device px
+  };
+  std::vector<BatchEntry> batch_entries_;
+
+  // Latest woven result per target id. |woven| keeps the woven IOSurface alive
+  // (our ref) until the target is re-woven or pruned; |result.woven_handle| is
+  // its IOSurfaceID for Viz to look up.
+  struct Pending {
+    bool have = false;
+    Result result;
+    base::apple::ScopedCFTypeRef<IOSurfaceRef> woven;
+  };
+  base::flat_map<uint32_t, Pending> results_;
+};
+
+}  // namespace displayxr
+
+#endif  // BUILDFLAG(IS_APPLE)
+
+#endif  // COMPONENTS_DISPLAYXR_GPU_DISPLAYXR_WEAVE_GPU_MAC_H_
diff --git a/components/displayxr/gpu/displayxr_weave_gpu_mac.mm b/components/displayxr/gpu/displayxr_weave_gpu_mac.mm
new file mode 100644
index 0000000000000..59fc5bd3d2440
--- /dev/null
+++ b/components/displayxr/gpu/displayxr_weave_gpu_mac.mm
@@ -0,0 +1,300 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifdef UNSAFE_BUFFERS_BUILD
+// TODO(crbug.com/351564777): Remove and convert to safer constructs.
+#pragma allow_unsafe_buffers
+#endif
+
+#include "components/displayxr/gpu/displayxr_weave_gpu_mac.h"
+
+#if BUILDFLAG(IS_APPLE)
+
+#import <Metal/Metal.h>
+
+
+#include "base/logging.h"
+#include "components/displayxr/browser/displayxr_weave_client.h"
+#include "components/displayxr/browser/displayxr_weave_client_mac.h"
+
+namespace displayxr {
+
+namespace {
+
+// Wrap an IOSurface as a BGRA8 MTLTexture for the blit copy (no data copy).
+id<MTLTexture> WrapIOSurface(id<MTLDevice> device, IOSurfaceRef surface) {
+  if (!device || !surface) {
+    return nil;
+  }
+  const NSUInteger w = IOSurfaceGetWidth(surface);
+  const NSUInteger h = IOSurfaceGetHeight(surface);
+  MTLTextureDescriptor* desc = [MTLTextureDescriptor
+      texture2DDescriptorWithPixelFormat:MTLPixelFormatBGRA8Unorm
+                                   width:w
+                                  height:h
+                               mipmapped:NO];
+  desc.usage = MTLTextureUsageShaderRead | MTLTextureUsageShaderWrite;
+  desc.storageMode = MTLStorageModeShared;
+  return [device newTextureWithDescriptor:desc iosurface:surface plane:0];
+}
+
+}  // namespace
+
+DisplayXRWeaveGpuMac::DisplayXRWeaveGpuMac() {
+  // Bring up the GPU-process weave session (idempotent; dormant if the runtime
+  // + loaders aren't installed). The session lives in THIS process so the sync
+  // xrWeaveSubmitDXR runs in-process with zero hops.
+  InitializeCoreMac();
+  id<MTLDevice> device = MTLCreateSystemDefaultDevice();
+  if (device) {
+    id<MTLCommandQueue> queue = [device newCommandQueue];
+    device_ = (__bridge_retained void*)device;
+    queue_ = (__bridge_retained void*)queue;
+  } else {
+    LOG(ERROR) << "[DisplayXR] mac weave: no Metal device — weave disabled";
+  }
+}
+
+DisplayXRWeaveGpuMac::~DisplayXRWeaveGpuMac() {
+  if (queue_) {
+    id<MTLCommandQueue> q = (__bridge_transfer id<MTLCommandQueue>)queue_;
+    (void)q;
+    queue_ = nullptr;
+  }
+  if (device_) {
+    id<MTLDevice> d = (__bridge_transfer id<MTLDevice>)device_;
+    (void)d;
+    device_ = nullptr;
+  }
+}
+
+bool DisplayXRWeaveGpuMac::BatchMode() const {
+  // Sync GPU-process weave requires the session live + a spec-v3 runtime for the
+  // chained rect-array submit.
+  return DisplayXRWeaveClient::IsSupported() &&
+         DisplayXRWeaveClient::WeaveSpecVersion() >= 3;
+}
+
+bool DisplayXRWeaveGpuMac::SubmitInFlight(uint32_t /*target_id*/) const {
+  // Synchronous: nothing is ever outstanding across frames.
+  return false;
+}
+
+bool DisplayXRWeaveGpuMac::EnsureSharedInput(const gfx::Size& size) {
+  if (size.IsEmpty()) {
+    return false;
+  }
+  if (input_iosurface_ && input_size_ == size) {
+    return true;
+  }
+  // BGRA8, global so the runtime service can IOSurfaceLookup it by ID (#760).
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wdeprecated-declarations"
+  NSDictionary* props = @{
+    (id)kIOSurfaceWidth : @(size.width()),
+    (id)kIOSurfaceHeight : @(size.height()),
+    (id)kIOSurfaceBytesPerElement : @4,
+    (id)kIOSurfacePixelFormat : @((unsigned)'BGRA'),
+    (id)kIOSurfaceIsGlobal : @YES,
+  };
+#pragma clang diagnostic pop
+  IOSurfaceRef surf = IOSurfaceCreate((__bridge CFDictionaryRef)props);
+  if (!surf) {
+    LOG(ERROR) << "[DisplayXR] mac weave: IOSurfaceCreate failed "
+               << size.width() << "x" << size.height();
+    return false;
+  }
+  input_iosurface_.reset(surf);  // adopts the +1 ref from Create
+  input_size_ = size;
+  return true;
+}
+
+void DisplayXRWeaveGpuMac::BeginBatchSync(const gfx::Size& window_size) {
+  batch_open_ = true;
+  batch_size_ = window_size;
+  batch_entries_.clear();
+  EnsureSharedInput(window_size);
+}
+
+bool DisplayXRWeaveGpuMac::WeaveCanvasMac(IOSurfaceRef canvas_iosurface,
+                                          const gfx::Rect& src_rect,
+                                          const gfx::Rect& window_rect,
+                                          uint32_t target_id) {
+  if (!batch_open_ || !canvas_iosurface || !device_ || !queue_ ||
+      !input_iosurface_) {
+    return false;
+  }
+  id<MTLDevice> device = (__bridge id<MTLDevice>)device_;
+  id<MTLCommandQueue> queue = (__bridge id<MTLCommandQueue>)queue_;
+  id<MTLTexture> src = WrapIOSurface(device, canvas_iosurface);
+  id<MTLTexture> dst = WrapIOSurface(device, input_iosurface_.get());
+  if (!src || !dst) {
+    return false;
+  }
+  id<MTLCommandBuffer> cb = [queue commandBuffer];
+  id<MTLBlitCommandEncoder> blit = [cb blitCommandEncoder];
+  [blit copyFromTexture:src
+            sourceSlice:0
+            sourceLevel:0
+           sourceOrigin:MTLOriginMake(src_rect.x(), src_rect.y(), 0)
+             sourceSize:MTLSizeMake(src_rect.width(), src_rect.height(), 1)
+              toTexture:dst
+       destinationSlice:0
+       destinationLevel:0
+      destinationOrigin:MTLOriginMake(window_rect.x(), window_rect.y(), 0)];
+  [blit endEncoding];
+  [cb commit];
+  [cb waitUntilCompleted];
+  batch_entries_.push_back({target_id, window_rect});
+  return true;
+}
+
+bool DisplayXRWeaveGpuMac::BlitWovenToMac(IOSurfaceRef dst,
+                                          const gfx::Rect& src_rect) {
+  if (!dst || !cached_woven_ || !device_ || !queue_) {
+    return false;
+  }
+  id<MTLDevice> device = (__bridge id<MTLDevice>)device_;
+  id<MTLCommandQueue> queue = (__bridge id<MTLCommandQueue>)queue_;
+  id<MTLTexture> src = WrapIOSurface(device, cached_woven_.get());
+  id<MTLTexture> d = WrapIOSurface(device, dst);
+  if (!src || !d) {
+    return false;
+  }
+  id<MTLCommandBuffer> cb = [queue commandBuffer];
+  id<MTLBlitCommandEncoder> blit = [cb blitCommandEncoder];
+  [blit copyFromTexture:src
+            sourceSlice:0
+            sourceLevel:0
+           sourceOrigin:MTLOriginMake(src_rect.x(), src_rect.y(), 0)
+             sourceSize:MTLSizeMake(src_rect.width(), src_rect.height(), 1)
+              toTexture:d
+       destinationSlice:0
+       destinationLevel:0
+      destinationOrigin:MTLOriginMake(0, 0, 0)];
+  [blit endEncoding];
+  [cb commit];
+  [cb waitUntilCompleted];
+  return true;
+}
+
+bool DisplayXRWeaveGpuMac::WeavePixelsMac(const uint8_t* bgra_pixels,
+                                          uint32_t stride,
+                                          const gfx::Rect& window_rect,
+                                          uint32_t target_id) {
+  if (!batch_open_ || !bgra_pixels || !input_iosurface_) {
+    return false;
+  }
+  IOSurfaceRef surf = input_iosurface_.get();
+  IOSurfaceLock(surf, 0, nullptr);
+  uint8_t* base = static_cast<uint8_t*>(IOSurfaceGetBaseAddress(surf));
+  const size_t dst_stride = IOSurfaceGetBytesPerRow(surf);
+  const int rows = window_rect.height();
+  const size_t row_bytes = static_cast<size_t>(window_rect.width()) * 4u;
+  for (int r = 0; r < rows; ++r) {
+    uint8_t* dst = base + (window_rect.y() + r) * dst_stride +
+                   static_cast<size_t>(window_rect.x()) * 4u;
+    const uint8_t* srcp = bgra_pixels + static_cast<size_t>(r) * stride;
+    memcpy(dst, srcp, row_bytes);
+  }
+  IOSurfaceUnlock(surf, 0, nullptr);
+  batch_entries_.push_back({target_id, window_rect});
+  return true;
+}
+
+bool DisplayXRWeaveGpuMac::SubmitBatchSync() {
+  if (!batch_open_) {
+    return false;
+  }
+  batch_open_ = false;
+  if (batch_entries_.empty() || !input_iosurface_) {
+    return false;
+  }
+  DisplayXRWeaveClient::SnapWindowIfMoved();  // parity; identity on mac
+
+  std::vector<DisplayXRWeaveClient::WeaveRect> rects;
+  rects.reserve(batch_entries_.size());
+  for (const BatchEntry& e : batch_entries_) {
+    rects.push_back({e.rect.x(), e.rect.y(), e.rect.width(), e.rect.height()});
+  }
+
+  // The runtime IPC (ipc_metal_handle_to_iosurface_id) expects the input handle
+  // to be an IOSurface*REF* pointer and derives the global IOSurfaceID itself via
+  // IOSurfaceGetID(). Passing the raw IOSurfaceID makes the runtime deref a small
+  // integer -> EXC_BAD_ACCESS. Pass the ref pointer (matches the probe's
+  // submit.inputTexture = (void*)input contract).
+  DisplayXRWeaveClient::WeaveSubmitResult sr = DisplayXRWeaveClient::SubmitBatch(
+      reinterpret_cast<uintptr_t>(input_iosurface_.get()), rects,
+      /*input_is_dxgi=*/false);
+  if (!sr.ok) {
+    static int s_fail = 0;
+    if (s_fail < 3) {
+      ++s_fail;
+      LOG(ERROR) << "[DisplayXR] mac batch weave submit failed (n="
+                 << rects.size() << ")";
+    }
+    batch_entries_.clear();
+    return false;
+  }
+
+  // The woven output is one window-sized IOSurface (returned as an IOSurfaceID).
+  // Look it up (our own ref) and store per target — the first entry owns the
+  // ref; every entry carries the same woven_handle so Viz imports once and draws
+  // each rect's region (mirrors the Windows batch path).
+  // sr.woven_handle is `out.weavedTexture` — an IOSurface*REF* pointer, retained
+  // and handed back on the FIRST submit only (0 afterwards; the runtime re-weaves
+  // into the same surface). NOT an IOSurfaceID — do NOT IOSurfaceLookup it. Adopt
+  // the first handback into cached_woven_ and reuse it every frame.
+  if (sr.woven_handle) {
+    cached_woven_.reset(reinterpret_cast<IOSurfaceRef>(sr.woven_handle));
+  }
+  base::apple::ScopedCFTypeRef<IOSurfaceRef> woven = cached_woven_;
+
+  bool first = true;
+  for (const BatchEntry& e : batch_entries_) {
+    Pending& p = results_[e.target_id];
+    p.have = true;
+    p.result = Result{};
+    p.result.ok = true;
+    // Always hand viz the LIVE woven IOSurfaceRef (cached), not sr.woven_handle
+    // (non-zero on the first submit only). Viz imports it into a SharedImage and
+    // substitutes it into the overlay for on-screen compositing.
+    p.result.woven_handle =
+        reinterpret_cast<uintptr_t>(cached_woven_.get());
+    p.result.fence_value = sr.fence_value;
+    p.result.width = sr.width;
+    p.result.height = sr.height;
+    if (first) {
+      first = false;
+      p.woven = woven;  // hold the ref on the representative entry
+    } else {
+      p.woven.reset();
+    }
+  }
+  batch_entries_.clear();
+  return true;
+}
+
+bool DisplayXRWeaveGpuMac::TryTakeWovenResult(uint32_t target_id, Result* out) {
+  auto it = results_.find(target_id);
+  if (it == results_.end() || !it->second.have) {
+    return false;
+  }
+  *out = it->second.result;
+  return true;
+}
+
+void DisplayXRWeaveGpuMac::PruneTargets(size_t count) {
+  for (auto it = results_.begin(); it != results_.end();) {
+    if (it->first >= count) {
+      it = results_.erase(it);
+    } else {
+      ++it;
+    }
+  }
+}
+
+}  // namespace displayxr
+
+#endif  // BUILDFLAG(IS_APPLE)
