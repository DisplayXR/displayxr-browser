diff --git a/components/displayxr/browser/displayxr_weave_client_mac.mm b/components/displayxr/browser/displayxr_weave_client_mac.mm
new file mode 100644
index 0000000000000..d881d78881426
--- /dev/null
+++ b/components/displayxr/browser/displayxr_weave_client_mac.mm
@@ -0,0 +1,706 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// macOS inline-3D weave client (#625, Step B — macOS port PR1).
+//
+// The macOS sibling of the Windows body in displayxr_weave_client.cc. Same
+// contract (DisplayXRWeaveClient statics), different platform substrate:
+//
+//   * The weave session binds with MoltenVK (XrGraphicsBindingVulkanKHR), NOT
+//     Metal/D3D11. On the macOS IPC/service path both the metal_native and
+//     vk_native native compositors are disabled (oxr_session_gfx_*_native.c,
+//     is_service_mode), and a headless session can't weave (oxr_weave.c
+//     session_is_ipc requires xcn != NULL). The MoltenVK-bound IPC session is
+//     the only one the runtime's XR_DXR_weave accepts on macOS — verified by
+//     test_apps/probes/weave_probe_vk_macos, whose bring-up this mirrors.
+//   * The OpenXR loader AND MoltenVK are dlopen'd (not linked): inline-3D stays
+//     dormant (IsSupported()==false) when the DisplayXR runtime isn't installed,
+//     the macOS analogue of the Windows delay-load of openxr_loader.dll.
+//
+// PR1 scope (Seam-C de-risk): dlopen the loaders, create a forced-IPC instance,
+// a MoltenVK device, the present-owner weave session, xrWeaveBindWindowDXR, and
+// resolve the weave PFNs — proving the linkage/process path on macOS. The
+// per-frame weave (IOSurface submit) + the GPU-process provider land in PR3.
+
+#ifdef UNSAFE_BUFFERS_BUILD
+// Bring-up code over the vendored OpenXR / Vulkan C APIs (fixed-size name
+// buffers, extension-string arrays). TODO(#625): harden alongside the Windows
+// client. Matches the source_set's no_chromium_code relaxation.
+#pragma allow_unsafe_buffers
+#endif
+
+#include "components/displayxr/browser/displayxr_weave_client_mac.h"
+
+#include <dlfcn.h>
+#include <time.h>
+
+#include <cstring>
+#include <string>
+#include <string_view>
+#include <vector>
+
+#include "base/logging.h"
+
+// vulkan.h MUST precede openxr_platform.h: under XR_USE_GRAPHICS_API_VULKAN the
+// platform header references VkDevice/VkInstance/VkResult and expects them
+// already declared.
+#include <vulkan/vulkan.h>
+
+// XR_USE_TIMESPEC exposes xrConvertTimespecTimeToTimeKHR (the macOS analogue of
+// the Windows QPC->XrTime conversion the rig locate needs).
+#define XR_USE_GRAPHICS_API_VULKAN
+#define XR_USE_TIMESPEC
+#include <openxr/openxr.h>
+#include <openxr/openxr_platform.h>
+
+#include <openxr/XR_DXR_display_info.h>
+#include <openxr/XR_DXR_display_zones.h>
+#include <openxr/XR_DXR_local_3d_zone.h>
+#include <openxr/XR_DXR_view_rig.h>
+#include <openxr/XR_DXR_weave.h>
+
+namespace displayxr {
+namespace {
+
+// ---- Dynamically loaded entry points (dormant-when-absent) -----------------
+// We dlopen the two loaders and bootstrap everything else through their
+// proc-address getters, so a machine without the DisplayXR runtime simply
+// leaves these null and inline-3D reports unsupported.
+PFN_xrGetInstanceProcAddr g_xrGetInstanceProcAddr = nullptr;
+PFN_vkGetInstanceProcAddr g_vkGetInstanceProcAddr = nullptr;
+
+// Candidate paths for the runtime-shipped loaders. The runtime .pkg installs
+// them under /usr/local/lib (Homebrew-style) or alongside the active-runtime
+// JSON; also honor DYLD search + an explicit override for dev builds.
+void* DlopenFirst(const char* const* names, size_t n) {
+  for (size_t i = 0; i < n; ++i) {
+    if (void* h = dlopen(names[i], RTLD_NOW | RTLD_LOCAL)) {
+      return h;
+    }
+  }
+  return nullptr;
+}
+
+bool LoadLoaders() {
+  static bool tried = false;
+  static bool ok = false;
+  if (tried) {
+    return ok;
+  }
+  tried = true;
+
+  const char* xr_names[] = {
+      "libopenxr_loader.dylib",
+      "/usr/local/lib/libopenxr_loader.dylib",
+      "/opt/homebrew/lib/libopenxr_loader.dylib",
+  };
+  const char* vk_names[] = {
+      "libvulkan.dylib",
+      "libMoltenVK.dylib",
+      "/usr/local/lib/libvulkan.dylib",
+      "/usr/local/lib/libMoltenVK.dylib",
+  };
+  void* xr_lib = DlopenFirst(xr_names, std::size(xr_names));
+  void* vk_lib = DlopenFirst(vk_names, std::size(vk_names));
+  if (!xr_lib || !vk_lib) {
+    VLOG(1) << "[DisplayXR] loaders absent (xr=" << (void*)xr_lib
+            << " vk=" << (void*)vk_lib << ") — inline-3D dormant";
+    return false;
+  }
+  g_xrGetInstanceProcAddr = reinterpret_cast<PFN_xrGetInstanceProcAddr>(
+      dlsym(xr_lib, "xrGetInstanceProcAddr"));
+  g_vkGetInstanceProcAddr = reinterpret_cast<PFN_vkGetInstanceProcAddr>(
+      dlsym(vk_lib, "vkGetInstanceProcAddr"));
+  ok = g_xrGetInstanceProcAddr && g_vkGetInstanceProcAddr;
+  return ok;
+}
+
+// Resolve an XR PFN through the bootstrapped getter. |instance| may be NULL for
+// the pre-instance calls (xrCreateInstance, xrEnumerateInstanceExtensionProperties).
+template <typename Fn>
+Fn GetXr(XrInstance instance, const char* name) {
+  PFN_xrVoidFunction p = nullptr;
+  if (g_xrGetInstanceProcAddr) {
+    g_xrGetInstanceProcAddr(instance, name, &p);
+  }
+  return reinterpret_cast<Fn>(p);
+}
+
+template <typename Fn>
+Fn GetVk(VkInstance instance, const char* name) {
+  return reinterpret_cast<Fn>(
+      g_vkGetInstanceProcAddr ? g_vkGetInstanceProcAddr(instance, name)
+                              : nullptr);
+}
+
+// ---- Process-global weave state (mac) --------------------------------------
+struct MacWeaveState {
+  XrInstance instance = XR_NULL_HANDLE;
+  XrSystemId system_id = XR_NULL_SYSTEM_ID;
+  XrSession session = XR_NULL_HANDLE;
+  VkInstance vk_instance = VK_NULL_HANDLE;
+  VkDevice vk_device = VK_NULL_HANDLE;
+  VkPhysicalDevice vk_phys = VK_NULL_HANDLE;
+  uint32_t vk_queue_family = 0;
+
+  bool has_weave = false;
+  uint32_t weave_spec_version = 0;
+
+  // Weave PFNs (resolved once the instance is up).
+  PFN_xrWeaveBindWindowDXR bind_window = nullptr;
+  PFN_xrWeaveSubmitDXR submit = nullptr;
+  PFN_xrWeaveSnapWindowRectDXR snap = nullptr;
+
+  // PR2 rig locate (XR_DXR_view_rig + XR_DXR_display_zones + timespec time):
+  // the runtime computes the off-axis views for each element. has_rig_views is
+  // true only when all three are live + the LOCAL space and PFN came up.
+  bool has_view_rig = false;
+  bool has_display_zones = false;
+  bool has_rig_views = false;
+  PFN_xrConvertTimespecTimeToTimeKHR convert_time = nullptr;
+  XrSpace ref_space = XR_NULL_HANDLE;
+
+  bool initialized = false;
+};
+
+MacWeaveState& State() {
+  static MacWeaveState* s = new MacWeaveState();
+  return *s;
+}
+
+void SplitExts(const std::string& s,
+               std::vector<std::string>& storage,
+               std::vector<const char*>& ptrs) {
+  size_t start = 0;
+  for (size_t i = 0; i <= s.size(); ++i) {
+    if (i == s.size() || s[i] == ' ' || s[i] == '\0') {
+      if (i > start) {
+        storage.push_back(s.substr(start, i - start));
+      }
+      start = i + 1;
+    }
+  }
+  for (const auto& e : storage) {
+    ptrs.push_back(e.c_str());
+  }
+}
+
+// Create the MoltenVK VkInstance/VkDevice the XR session binds to, per
+// XR_KHR_vulkan_enable. Mirrors weave_probe_vk_macos exactly.
+bool CreateMoltenVkDevice(MacWeaveState& s) {
+  auto xrGetVkReq = GetXr<PFN_xrGetVulkanGraphicsRequirementsKHR>(
+      s.instance, "xrGetVulkanGraphicsRequirementsKHR");
+  auto xrGetVkIExt = GetXr<PFN_xrGetVulkanInstanceExtensionsKHR>(
+      s.instance, "xrGetVulkanInstanceExtensionsKHR");
+  auto xrGetVkDExt = GetXr<PFN_xrGetVulkanDeviceExtensionsKHR>(
+      s.instance, "xrGetVulkanDeviceExtensionsKHR");
+  auto xrGetVkDev = GetXr<PFN_xrGetVulkanGraphicsDeviceKHR>(
+      s.instance, "xrGetVulkanGraphicsDeviceKHR");
+  if (!xrGetVkReq || !xrGetVkIExt || !xrGetVkDExt || !xrGetVkDev) {
+    LOG(ERROR) << "[DisplayXR] XR_KHR_vulkan_enable PFNs missing";
+    return false;
+  }
+  XrGraphicsRequirementsVulkanKHR vk_req = {
+      XR_TYPE_GRAPHICS_REQUIREMENTS_VULKAN_KHR};
+  if (XR_FAILED(xrGetVkReq(s.instance, s.system_id, &vk_req))) {
+    return false;
+  }
+
+  auto vkCreateInstance =
+      GetVk<PFN_vkCreateInstance>(VK_NULL_HANDLE, "vkCreateInstance");
+  auto vkEnumInstExt = GetVk<PFN_vkEnumerateInstanceExtensionProperties>(
+      VK_NULL_HANDLE, "vkEnumerateInstanceExtensionProperties");
+  if (!vkCreateInstance || !vkEnumInstExt) {
+    return false;
+  }
+
+  uint32_t len = 0;
+  xrGetVkIExt(s.instance, s.system_id, 0, &len, nullptr);
+  std::string iext_str(len, '\0');
+  xrGetVkIExt(s.instance, s.system_id, len, &len, iext_str.data());
+  std::vector<std::string> iext_storage;
+  std::vector<const char*> iexts;
+  SplitExts(iext_str, iext_storage, iexts);
+
+  uint32_t avail = 0;
+  vkEnumInstExt(nullptr, &avail, nullptr);
+  std::vector<VkExtensionProperties> avail_exts(avail);
+  vkEnumInstExt(nullptr, &avail, avail_exts.data());
+  bool has_portability = false;
+  for (const auto& e : avail_exts) {
+    if (std::string_view(e.extensionName) == "VK_KHR_portability_enumeration") {
+      has_portability = true;
+      iexts.push_back("VK_KHR_portability_enumeration");
+      break;
+    }
+  }
+
+  VkApplicationInfo app_info = {VK_STRUCTURE_TYPE_APPLICATION_INFO};
+  app_info.pApplicationName = "DisplayXRBrowser";
+  app_info.apiVersion = VK_API_VERSION_1_1;
+  VkInstanceCreateInfo vici = {VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO};
+  vici.pApplicationInfo = &app_info;
+  vici.enabledExtensionCount = static_cast<uint32_t>(iexts.size());
+  vici.ppEnabledExtensionNames = iexts.data();
+  if (has_portability) {
+    vici.flags |= VK_INSTANCE_CREATE_ENUMERATE_PORTABILITY_BIT_KHR;
+  }
+  if (vkCreateInstance(&vici, nullptr, &s.vk_instance) != VK_SUCCESS) {
+    LOG(ERROR) << "[DisplayXR] vkCreateInstance (MoltenVK) failed";
+    return false;
+  }
+
+  if (XR_FAILED(xrGetVkDev(s.instance, s.system_id, s.vk_instance,
+                           &s.vk_phys))) {
+    return false;
+  }
+
+  auto vkGetQF = GetVk<PFN_vkGetPhysicalDeviceQueueFamilyProperties>(
+      s.vk_instance, "vkGetPhysicalDeviceQueueFamilyProperties");
+  auto vkEnumDevExt = GetVk<PFN_vkEnumerateDeviceExtensionProperties>(
+      s.vk_instance, "vkEnumerateDeviceExtensionProperties");
+  auto vkCreateDevice =
+      GetVk<PFN_vkCreateDevice>(s.vk_instance, "vkCreateDevice");
+  if (!vkGetQF || !vkEnumDevExt || !vkCreateDevice) {
+    return false;
+  }
+
+  uint32_t qf_count = 0;
+  vkGetQF(s.vk_phys, &qf_count, nullptr);
+  std::vector<VkQueueFamilyProperties> qfs(qf_count);
+  vkGetQF(s.vk_phys, &qf_count, qfs.data());
+  s.vk_queue_family = UINT32_MAX;
+  for (uint32_t i = 0; i < qf_count; ++i) {
+    if (qfs[i].queueFlags & VK_QUEUE_GRAPHICS_BIT) {
+      s.vk_queue_family = i;
+      break;
+    }
+  }
+  if (s.vk_queue_family == UINT32_MAX) {
+    return false;
+  }
+
+  len = 0;
+  xrGetVkDExt(s.instance, s.system_id, 0, &len, nullptr);
+  std::string dext_str(len, '\0');
+  xrGetVkDExt(s.instance, s.system_id, len, &len, dext_str.data());
+  std::vector<std::string> dext_storage;
+  std::vector<const char*> dexts;
+  SplitExts(dext_str, dext_storage, dexts);
+
+  uint32_t dav = 0;
+  vkEnumDevExt(s.vk_phys, nullptr, &dav, nullptr);
+  std::vector<VkExtensionProperties> dav_exts(dav);
+  vkEnumDevExt(s.vk_phys, nullptr, &dav, dav_exts.data());
+  for (const auto& e : dav_exts) {
+    if (std::string_view(e.extensionName) == "VK_KHR_portability_subset") {
+      bool already = false;
+      for (const char* d : dexts) {
+        if (std::string_view(d) == "VK_KHR_portability_subset") {
+          already = true;
+        }
+      }
+      if (!already) {
+        dexts.push_back("VK_KHR_portability_subset");
+      }
+      break;
+    }
+  }
+
+  float prio = 1.0f;
+  VkDeviceQueueCreateInfo qci = {VK_STRUCTURE_TYPE_DEVICE_QUEUE_CREATE_INFO};
+  qci.queueFamilyIndex = s.vk_queue_family;
+  qci.queueCount = 1;
+  qci.pQueuePriorities = &prio;
+  VkDeviceCreateInfo dci = {VK_STRUCTURE_TYPE_DEVICE_CREATE_INFO};
+  dci.queueCreateInfoCount = 1;
+  dci.pQueueCreateInfos = &qci;
+  dci.enabledExtensionCount = static_cast<uint32_t>(dexts.size());
+  dci.ppEnabledExtensionNames = dexts.data();
+  if (vkCreateDevice(s.vk_phys, &dci, nullptr, &s.vk_device) != VK_SUCCESS) {
+    LOG(ERROR) << "[DisplayXR] vkCreateDevice (MoltenVK) failed";
+    return false;
+  }
+  return true;
+}
+
+}  // namespace
+
+// ---- Public mac entry points (called from the client.cc dispatchers) -------
+
+void InitializeCoreMac() {
+  MacWeaveState& s = State();
+  if (s.initialized) {
+    return;
+  }
+  s.initialized = true;
+
+  if (!LoadLoaders()) {
+    return;  // runtime absent — stay dormant
+  }
+
+  // Force the runtime onto the IPC path (the weave service is IPC-only). The
+  // runtime dylib reads its own getenv, so setenv on the process is sufficient.
+  setenv("XRT_FORCE_MODE", "ipc", /*overwrite=*/0);
+
+  auto xrEnumExt = GetXr<PFN_xrEnumerateInstanceExtensionProperties>(
+      XR_NULL_HANDLE, "xrEnumerateInstanceExtensionProperties");
+  auto xrCreateInstance =
+      GetXr<PFN_xrCreateInstance>(XR_NULL_HANDLE, "xrCreateInstance");
+  if (!xrEnumExt || !xrCreateInstance) {
+    LOG(ERROR) << "[DisplayXR] loader present but core PFNs missing";
+    return;
+  }
+
+  uint32_t ext_count = 0;
+  if (XR_FAILED(xrEnumExt(nullptr, 0, &ext_count, nullptr))) {
+    LOG(ERROR) << "[DisplayXR] xrEnumerateInstanceExtensionProperties failed";
+    return;
+  }
+  std::vector<XrExtensionProperties> exts(ext_count,
+                                          {XR_TYPE_EXTENSION_PROPERTIES});
+  if (XR_FAILED(xrEnumExt(nullptr, ext_count, &ext_count, exts.data()))) {
+    return;
+  }
+  bool has_vk = false, has_display_info = false, has_convert_time = false,
+       has_local3d = false;
+  for (const auto& e : exts) {
+    std::string_view n(e.extensionName);
+    if (n == XR_DXR_WEAVE_EXTENSION_NAME) {
+      s.has_weave = true;
+      s.weave_spec_version = e.extensionVersion;
+    } else if (n == XR_KHR_VULKAN_ENABLE_EXTENSION_NAME) {
+      has_vk = true;
+    } else if (n == XR_DXR_DISPLAY_INFO_EXTENSION_NAME) {
+      has_display_info = true;
+    } else if (n == XR_DXR_VIEW_RIG_EXTENSION_NAME) {
+      s.has_view_rig = true;
+    } else if (n == XR_DXR_DISPLAY_ZONES_EXTENSION_NAME) {
+      s.has_display_zones = true;
+    } else if (n == XR_DXR_LOCAL_3D_ZONE_EXTENSION_NAME) {
+      has_local3d = true;
+    } else if (n == XR_KHR_CONVERT_TIMESPEC_TIME_EXTENSION_NAME) {
+      has_convert_time = true;
+    }
+  }
+  if (!s.has_weave || !has_vk) {
+    LOG(WARNING) << "[DisplayXR] runtime lacks weave/vulkan_enable — inline-3D "
+                    "unsupported (weave="
+                 << s.has_weave << " vk=" << has_vk << ")";
+    return;
+  }
+  // display_zones requires local_3d_zone (enforced at xrCreateInstance).
+  s.has_rig_views = s.has_view_rig && s.has_display_zones && has_local3d &&
+                    has_convert_time;
+
+  std::vector<const char*> enabled = {XR_KHR_VULKAN_ENABLE_EXTENSION_NAME,
+                                      XR_DXR_WEAVE_EXTENSION_NAME};
+  if (has_display_info) {
+    enabled.push_back(XR_DXR_DISPLAY_INFO_EXTENSION_NAME);
+  }
+  // The weave is core; the rig only improves scene geometry. Track the boundary
+  // so a rig-side rejection retries weave-only rather than killing inline-3D.
+  const size_t weave_ext_count = enabled.size();
+  if (s.has_rig_views) {
+    enabled.push_back(XR_DXR_VIEW_RIG_EXTENSION_NAME);
+    enabled.push_back(XR_DXR_DISPLAY_ZONES_EXTENSION_NAME);
+    enabled.push_back(XR_DXR_LOCAL_3D_ZONE_EXTENSION_NAME);
+    enabled.push_back(XR_KHR_CONVERT_TIMESPEC_TIME_EXTENSION_NAME);
+  }
+
+  XrInstanceCreateInfo ici = {XR_TYPE_INSTANCE_CREATE_INFO};
+  std::snprintf(ici.applicationInfo.applicationName,
+                sizeof(ici.applicationInfo.applicationName), "%s",
+                "DisplayXRBrowser");
+  ici.applicationInfo.applicationVersion = 1;
+  std::snprintf(ici.applicationInfo.engineName,
+                sizeof(ici.applicationInfo.engineName), "%s", "Chromium");
+  ici.applicationInfo.apiVersion = XR_CURRENT_API_VERSION;
+  ici.enabledExtensionCount = static_cast<uint32_t>(enabled.size());
+  ici.enabledExtensionNames = enabled.data();
+  XrResult ir = xrCreateInstance(&ici, &s.instance);
+  if (XR_FAILED(ir) && s.has_rig_views) {
+    LOG(ERROR) << "[DisplayXR] xrCreateInstance with rig exts failed (" << ir
+               << ") — retrying weave-only (scenes stay mono)";
+    s.has_rig_views = false;
+    enabled.resize(weave_ext_count);
+    ici.enabledExtensionCount = static_cast<uint32_t>(enabled.size());
+    ici.enabledExtensionNames = enabled.data();
+    ir = xrCreateInstance(&ici, &s.instance);
+  }
+  if (XR_FAILED(ir)) {
+    LOG(ERROR) << "[DisplayXR] xrCreateInstance failed: " << ir;
+    return;
+  }
+
+  auto xrGetSystem = GetXr<PFN_xrGetSystem>(s.instance, "xrGetSystem");
+  XrSystemGetInfo sgi = {XR_TYPE_SYSTEM_GET_INFO};
+  sgi.formFactor = XR_FORM_FACTOR_HEAD_MOUNTED_DISPLAY;
+  if (!xrGetSystem ||
+      XR_FAILED(xrGetSystem(s.instance, &sgi, &s.system_id))) {
+    LOG(ERROR) << "[DisplayXR] xrGetSystem failed";
+    return;
+  }
+
+  if (!CreateMoltenVkDevice(s)) {
+    return;
+  }
+
+  // Present-owner weave session bound to the MoltenVK device.
+  auto xrCreateSession =
+      GetXr<PFN_xrCreateSession>(s.instance, "xrCreateSession");
+  XrGraphicsBindingVulkanKHR vk_binding = {
+      XR_TYPE_GRAPHICS_BINDING_VULKAN_KHR};
+  vk_binding.instance = s.vk_instance;
+  vk_binding.physicalDevice = s.vk_phys;
+  vk_binding.device = s.vk_device;
+  vk_binding.queueFamilyIndex = s.vk_queue_family;
+  vk_binding.queueIndex = 0;
+  XrSessionCreateInfo sci = {XR_TYPE_SESSION_CREATE_INFO};
+  sci.next = &vk_binding;
+  sci.systemId = s.system_id;
+  if (!xrCreateSession ||
+      XR_FAILED(xrCreateSession(s.instance, &sci, &s.session))) {
+    LOG(ERROR) << "[DisplayXR] xrCreateSession (weave present-owner) failed";
+    return;
+  }
+
+  // Resolve weave PFNs + bind the window (id 0: the runtime stores it and the
+  // macOS snap is identity — no NSWindow plumbing needed for the weave itself).
+  s.bind_window =
+      GetXr<PFN_xrWeaveBindWindowDXR>(s.instance, "xrWeaveBindWindowDXR");
+  s.submit = GetXr<PFN_xrWeaveSubmitDXR>(s.instance, "xrWeaveSubmitDXR");
+  s.snap = GetXr<PFN_xrWeaveSnapWindowRectDXR>(s.instance,
+                                               "xrWeaveSnapWindowRectDXR");
+  if (!s.bind_window || !s.submit) {
+    LOG(ERROR) << "[DisplayXR] weave PFNs unresolved";
+    return;
+  }
+  s.bind_window(s.session, /*windowHandle=*/nullptr);
+
+  // PR2 rig locate: a LOCAL reference space + the timespec time-conversion PFN.
+  // Neither needs a RUNNING session (xrLocateViews validates only the space,
+  // view-config type, and displayTime > 0), so this stays submit-only.
+  if (s.has_rig_views) {
+    s.convert_time = GetXr<PFN_xrConvertTimespecTimeToTimeKHR>(
+        s.instance, "xrConvertTimespecTimeToTimeKHR");
+    auto xrCreateReferenceSpace = GetXr<PFN_xrCreateReferenceSpace>(
+        s.instance, "xrCreateReferenceSpace");
+    XrReferenceSpaceCreateInfo rsci = {XR_TYPE_REFERENCE_SPACE_CREATE_INFO};
+    rsci.referenceSpaceType = XR_REFERENCE_SPACE_TYPE_LOCAL;
+    rsci.poseInReferenceSpace.orientation = {0.f, 0.f, 0.f, 1.f};
+    rsci.poseInReferenceSpace.position = {0.f, 0.f, 0.f};
+    XrResult rr = xrCreateReferenceSpace
+                      ? xrCreateReferenceSpace(s.session, &rsci, &s.ref_space)
+                      : XR_ERROR_FUNCTION_UNSUPPORTED;
+    if (XR_FAILED(rr) || !s.convert_time) {
+      LOG(ERROR) << "[DisplayXR] rig locate setup failed (space=" << rr
+                 << " convert_time=" << (s.convert_time ? "ok" : "NULL")
+                 << ") — scenes stay mono";
+      s.has_rig_views = false;
+    }
+  }
+
+  LOG(WARNING) << "[DisplayXR] inline-3D weave client ready on macOS "
+                  "(MoltenVK IPC session, weave_spec="
+               << s.weave_spec_version
+               << " rig_views=" << s.has_rig_views << ")";
+}
+
+bool IsSupportedMac() {
+  MacWeaveState& s = State();
+  return s.session != XR_NULL_HANDLE && s.has_weave && s.submit != nullptr;
+}
+
+uint32_t WeaveSpecVersionMac() {
+  return State().weave_spec_version;
+}
+
+std::vector<DisplayXRWeaveClient::RigView> LocateViewsForRectMac(
+    const DisplayXRWeaveClient::WeaveRect& rect,
+    float virtual_display_height) {
+  MacWeaveState& s = State();
+  std::vector<DisplayXRWeaveClient::RigView> out;
+  if (!s.has_rig_views || s.session == XR_NULL_HANDLE ||
+      s.ref_space == XR_NULL_HANDLE || !s.convert_time || rect.w <= 0 ||
+      rect.h <= 0) {
+    return out;
+  }
+
+  // xrLocateViews rejects displayTime <= 0. CLOCK_MONOTONIC -> XrTime via the
+  // timespec conversion (the macOS analogue of the Windows QPC path). The time
+  // only drives head/display-plane prediction (the eyes come from the DP's
+  // latest sample), so "now" is right.
+  struct timespec ts = {};
+  if (clock_gettime(CLOCK_MONOTONIC, &ts) != 0) {
+    return out;
+  }
+  XrTime now = 0;
+  if (XR_FAILED(s.convert_time(s.instance, &ts, &now)) || now <= 0) {
+    return out;
+  }
+
+  XrDisplayRigDXR rig = {XR_TYPE_DISPLAY_RIG_DXR};
+  rig.pose.orientation = {0.f, 0.f, 0.f, 1.f};
+  rig.pose.position = {0.f, 0.f, 0.f};
+  rig.virtualDisplayHeight =
+      virtual_display_height > 0.f ? virtual_display_height : 0.f;
+  rig.ipdFactor = 1.f;
+  rig.parallaxFactor = 1.f;
+  rig.perspectiveFactor = 1.f;
+
+  // The element's rect IS the canvas (window-client-relative device px — the
+  // same rect the weave submits).
+  XrDisplayZoneDXR zone = {XR_TYPE_DISPLAY_ZONE_DXR};
+  zone.next = &rig;
+  zone.zoneId = 0;
+  zone.rect.offset = {rect.x, rect.y};
+  zone.rect.extent = {rect.w, rect.h};
+
+  XrViewLocateInfo li = {XR_TYPE_VIEW_LOCATE_INFO};
+  li.next = &zone;
+  li.viewConfigurationType = XR_VIEW_CONFIGURATION_TYPE_PRIMARY_STEREO;
+  li.displayTime = now;
+  li.space = s.ref_space;
+
+  auto xrLocateViews =
+      GetXr<PFN_xrLocateViews>(s.instance, "xrLocateViews");
+  if (!xrLocateViews) {
+    return out;
+  }
+  XrViewState vs = {XR_TYPE_VIEW_STATE};
+  // The display's rendering mode may expose N views (sim_display's 2x2 Quad
+  // reports 4); inline-3D consumes the PRIMARY STEREO PAIR (views 0-1, the
+  // runtime's standard stereo layout). Size the buffer for up to 8 tiles so a
+  // >2-view mode doesn't trip XR_ERROR_SIZE_INSUFFICIENT (-11).
+  XrView views[8];
+  for (XrView& vv : views) vv = XrView{XR_TYPE_VIEW};
+  uint32_t view_count = 0;
+  XrResult lv_rc = xrLocateViews(s.session, &li, &vs, 8, &view_count, views);
+  if (XR_FAILED(lv_rc) || view_count == 0) {
+    static bool warned = false;
+    if (!warned) {
+      warned = true;
+      LOG(ERROR) << "[DisplayXR] xrLocateViews (rig) failed on macOS";
+    }
+    return out;
+  }
+  if (!(vs.viewStateFlags & XR_VIEW_STATE_POSITION_VALID_BIT) ||
+      !(vs.viewStateFlags & XR_VIEW_STATE_ORIENTATION_VALID_BIT)) {
+    return out;
+  }
+
+  const uint32_t take = view_count < 2u ? view_count : 2u;  // inline-3D stereo pair
+  for (uint32_t i = 0; i < take; ++i) {
+    const XrView& xv = views[i];
+    DisplayXRWeaveClient::RigView v;
+    v.pos_x = xv.pose.position.x;
+    v.pos_y = xv.pose.position.y;
+    v.pos_z = xv.pose.position.z;
+    v.orient_x = xv.pose.orientation.x;
+    v.orient_y = xv.pose.orientation.y;
+    v.orient_z = xv.pose.orientation.z;
+    v.orient_w = xv.pose.orientation.w;
+    v.fov_left = xv.fov.angleLeft;
+    v.fov_right = xv.fov.angleRight;
+    v.fov_up = xv.fov.angleUp;
+    v.fov_down = xv.fov.angleDown;
+    out.push_back(v);
+  }
+  return out;
+}
+
+
+// PR3: batched synchronous weave (XR_DXR_weave spec v3). macOS port of
+// SubmitBatchWin — same chained XrWeaveSubmitRectsDXR flow, but the input/output
+// weave handles are bare IOSurfaceIDs (the runtime IOSurfaceLookup's them; the
+// surfaces must be kIOSurfaceIsGlobal). No DXGI on macOS. Synchronous per the
+// #760 contract: the runtime waits on GPU completion before returning, so the
+// woven IOSurface is ready when this returns.
+DisplayXRWeaveClient::WeaveSubmitResult SubmitBatchMac(
+    uintptr_t input_handle,
+    const std::vector<DisplayXRWeaveClient::WeaveRect>& rects,
+    bool /*input_is_dxgi*/) {
+  const size_t rect_count = rects.size();
+  DisplayXRWeaveClient::WeaveSubmitResult result;
+  MacWeaveState& s = State();
+  if (s.session == XR_NULL_HANDLE || !s.submit || rect_count == 0) {
+    return result;  // dormant / failed init / nothing to weave
+  }
+  if (s.weave_spec_version < 3) {
+    static bool logged_v2 = false;
+    if (!logged_v2) {
+      logged_v2 = true;
+      VLOG(1) << "[DisplayXR] SubmitBatch(mac) on spec-v" << s.weave_spec_version
+              << " runtime — needs v3 batch";
+    }
+    return result;
+  }
+
+  XrRect2Di xr_rects[XR_WEAVE_SUBMIT_MAX_RECTS_DXR];
+  size_t done = 0;
+  while (done < rect_count) {
+    const size_t n =
+        std::min<size_t>(rect_count - done, XR_WEAVE_SUBMIT_MAX_RECTS_DXR);
+    for (size_t i = 0; i < n; ++i) {
+      const DisplayXRWeaveClient::WeaveRect& r = rects[done + i];
+      XrRect2Di& xr = xr_rects[i];
+      xr.offset.x = r.x;
+      xr.offset.y = r.y;
+      xr.extent.width = r.w;
+      xr.extent.height = r.h;
+    }
+
+    XrWeaveSubmitRectsDXR batch = {XR_TYPE_WEAVE_SUBMIT_RECTS_DXR};
+    batch.rectCount = static_cast<uint32_t>(n);
+    batch.rects = xr_rects;
+
+    XrWeaveSubmitInfoDXR in = {XR_TYPE_WEAVE_SUBMIT_INFO_DXR};
+    in.next = &batch;
+    in.inputTexture = reinterpret_cast<void*>(input_handle);  // IOSurfaceRef ptr
+    in.inputIsDxgi = XR_FALSE;
+
+    XrWeaveOutputDXR out = {XR_TYPE_WEAVE_OUTPUT_DXR};
+    const XrResult sr = s.submit(s.session, &in, &out);
+    if (XR_FAILED(sr)) {
+      static int s_fail = 0;
+      if (s_fail < 3) {
+        ++s_fail;
+        LOG(ERROR) << "[DisplayXR] xrWeaveSubmitDXR(mac batch n=" << n
+                   << ") failed: " << sr;
+      }
+      result.ok = false;
+      return result;
+    }
+
+    result.ok = true;
+    if (out.weavedTexture) {
+      result.woven_handle = reinterpret_cast<uintptr_t>(out.weavedTexture);
+    }
+    if (out.fence) {
+      result.fence_handle = reinterpret_cast<uintptr_t>(out.fence);
+    }
+    result.fence_value = out.fenceValue;
+    result.width = out.width;
+    result.height = out.height;
+    result.eyes_valid = (out.eyesValid == XR_TRUE);
+    result.eyes.clear();
+    if (result.eyes_valid && out.eyeCount > 0) {
+      const uint32_t en = out.eyeCount > XR_WEAVE_MAX_EYES_DXR
+                              ? XR_WEAVE_MAX_EYES_DXR
+                              : out.eyeCount;
+      result.eyes.reserve(en * 3u);
+      for (uint32_t i = 0; i < en; ++i) {
+        const XrVector3f& eye = out.eyes[i];
+        result.eyes.push_back(eye.x);
+        result.eyes.push_back(eye.y);
+        result.eyes.push_back(eye.z);
+      }
+    }
+    done += n;
+  }
+  return result;
+}
+
+}  // namespace displayxr
