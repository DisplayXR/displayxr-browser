+void SkiaRenderer::SubstituteInline3DOverlayMac(
+    OverlayCandidate* overlay,
+    std::vector<OverlayLock>* locks,
+    size_t lock_index,
+    uint32_t target) {
+  // The scratch must match the canvas backing (the full-resolution flat SBS),
+  // but the matched overlay is often a texture overlay whose
+  // |resource_size_in_pixels| is 0x0 — the true size only lives in the backing
+  // IOSurface, which viz can't read. So viz only mints a STABLE mailbox name per
+  // target here; the GPU thread (which reads the source IOSurface size) creates
+  // the actual SCANOUT BGRA8 SharedImage under this name at the right size.
+  if (inline_3d_scratch_.size() <= target) {
+    inline_3d_scratch_.resize(target + 1);
+  }
+  Inline3DScratch& sc = inline_3d_scratch_[target];
+  // Present a different ring slot each frame so CoreAnimation sees a new
+  // io_surface bound to the CALayer and re-composites the fresh woven pixels
+  // (a single stable scratch is cached by CA and only advances on interaction).
+  gpu::Mailbox& slot = sc.mailbox[sc.next];
+  if (slot.IsZero()) {
+    slot = gpu::Mailbox::Generate();
+  }
+  sc.next = (sc.next + 1) % Inline3DScratch::kRingSize;
+
+  // Carry the original canvas backing to the GPU thread (it weaves it), then
+  // present the woven scratch instead so every present path samples the woven
+  // surface — never the raw SBS canvas (fixes trackpad-scroll SBS flicker).
+  overlay->displayxr_weave_source = overlay->mailbox;
+  overlay->displayxr_weave_target = target;
+  overlay->mailbox = slot;
