+void XRSession::ReportInline3DRects() {
+  // Collect each registered inline-3d canvas's window-relative device-px rect
+  // (getBoundingClientRect x device-scale-factor) and hand it to the compositor.
+  // The rects ride to Viz on CompositorFrameMetadata::inline_3d_rects, arriving
+  // atomically with the frame whose pixels they describe (design §13.3) — so the
+  // woven output sub-rect always matches the composited page. Even when
+  // display_layers_ is empty we push an empty list to clear a prior frame's rects.
+  LocalDOMWindow* window = DynamicTo<LocalDOMWindow>(GetExecutionContext());
+  if (!window) {
+    return;
+  }
+  LocalFrame* frame = window->GetFrame();
+  if (!frame) {
+    return;
+  }
+  FrameWidget* widget = frame->GetWidgetForLocalRoot();
+  if (!widget) {
+    return;
+  }
+  const double dsf = frame->DevicePixelRatio();
+  std::vector<gfx::Rect> rects;
+  rects.reserve(display_layers_.size());
+  for (const auto& layer : display_layers_) {
+    Element* target = layer->target();
+    if (!target) {
+      continue;
+    }
+    // getBoundingClientRect() is viewport-relative CSS px; the composited output
+    // is window-relative device px. For the main frame the visual-viewport origin
+    // maps to the widget origin, so device px = CSS px x DSF (pinch-zoom /
+    // multi-monitor origin refinements are deferred).
+    DOMRect* r = target->GetBoundingClientRect();
+    if (!r) {
+      continue;
+    }
+    gfx::RectF css_rect(static_cast<float>(r->x()), static_cast<float>(r->y()),
+                        static_cast<float>(r->width()),
+                        static_cast<float>(r->height()));
+    css_rect.Scale(static_cast<float>(dsf));
+    gfx::Rect device_rect = gfx::ToRoundedRect(css_rect);
+    if (!device_rect.IsEmpty()) {
+      rects.push_back(device_rect);
+    }
+  }
+  widget->SetInline3DRects(rects);
+  {
+    static int g_rir = 0;
+    if (++g_rir % 60 == 1) {
+      LOG(ERROR) << "[DisplayXR] ReportInline3DRects layers="
+                 << display_layers_.size() << " rects=" << rects.size()
+                 << " dsf=" << dsf
+                 << (rects.empty() ? "" : " r0=" + rects[0].ToString());
+    }
+  }
+}
