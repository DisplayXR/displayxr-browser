diff --git a/components/displayxr/gpu/displayxr_weave_gpu.cc b/components/displayxr/gpu/displayxr_weave_gpu.cc
index 38787273cf8fd..ba6dc285e1ed6 100644
--- a/components/displayxr/gpu/displayxr_weave_gpu.cc
+++ b/components/displayxr/gpu/displayxr_weave_gpu.cc
@@ -200,6 +200,92 @@ viz::DisplayXRWeaveProvider::Result DisplayXRWeaveGpu::WeaveCanvas(
   return out;
 }
 
+viz::DisplayXRWeaveProvider::Result DisplayXRWeaveGpu::WeavePixels(
+    ID3D11Device* device,
+    const uint8_t* bgra_pixels,
+    uint32_t stride,
+    const gfx::Rect& window_rect) {
+  Result out;
+  if (!weaver_.is_bound() || window_rect.IsEmpty() || !device || !bgra_pixels) {
+    return out;
+  }
+
+  const uint32_t w = static_cast<uint32_t>(window_rect.width());
+  const uint32_t h = static_cast<uint32_t>(window_rect.height());
+  if (!EnsureInput(device, DXGI_FORMAT_B8G8R8A8_UNORM, w, h)) {
+    return out;
+  }
+
+  // (Re)create the non-shared DEFAULT upload texture on device X. We UpdateSub-
+  // resource the CPU pixels here, then CopyResource into the shared input — CPU
+  // upload directly into a keyed-mutex/NT-shared texture invalidates its handle
+  // (service OpenSharedResource -> E_INVALIDARG).
+  if (!upload_tex_ || upload_w_ != w || upload_h_ != h) {
+    upload_tex_.Reset();
+    D3D11_TEXTURE2D_DESC ud = {};
+    ud.Width = w;
+    ud.Height = h;
+    ud.MipLevels = 1;
+    ud.ArraySize = 1;
+    ud.Format = DXGI_FORMAT_B8G8R8A8_UNORM;
+    ud.SampleDesc.Count = 1;
+    ud.Usage = D3D11_USAGE_DEFAULT;
+    ud.BindFlags = D3D11_BIND_SHADER_RESOURCE;
+    if (FAILED(device_->CreateTexture2D(&ud, nullptr, &upload_tex_))) {
+      LOG(ERROR) << "[DisplayXR] B4b WeavePixels: CreateTexture2D(upload) failed";
+      upload_tex_.Reset();
+      return out;
+    }
+    upload_w_ = w;
+    upload_h_ = h;
+  }
+
+  // CPU pixels -> upload texture -> (keyed-mutex) shared input via GPU copy.
+  context_->UpdateSubresource(upload_tex_.Get(), /*DstSubresource=*/0,
+                              /*pDstBox=*/nullptr, bgra_pixels, stride,
+                              /*SrcDepthPitch=*/0);
+  if (input_mutex_->AcquireSync(0, 1000) != S_OK) {
+    LOG(ERROR) << "[DisplayXR] B4b WeavePixels: AcquireSync(0) failed";
+    return out;
+  }
+  context_->CopyResource(input_tex_.Get(), upload_tex_.Get());
+  context_->Flush();
+  input_mutex_->ReleaseSync(0);
+
+  HANDLE dup = nullptr;
+  if (!::DuplicateHandle(::GetCurrentProcess(), input_handle_,
+                         ::GetCurrentProcess(), &dup, 0, FALSE,
+                         DUPLICATE_SAME_ACCESS) ||
+      !dup) {
+    LOG(ERROR) << "[DisplayXR] B4b WeavePixels: DuplicateHandle(input) failed";
+    return out;
+  }
+  gfx::DXGIHandle input{base::win::ScopedHandle(dup)};
+
+  mojom::DisplayXRWeaveResultPtr result;
+  if (!weaver_->WeaveSubmit(std::move(input), window_rect, &result)) {
+    LOG(ERROR) << "[DisplayXR] B4b WeavePixels: Sync WeaveSubmit call failed";
+    return out;
+  }
+  if (!result) {
+    return out;
+  }
+
+  out.ok = true;
+  out.fence_value = result->fence_value;
+  out.width = result->width;
+  out.height = result->height;
+  if (result->woven) {
+    out.woven_handle = reinterpret_cast<uintptr_t>(
+        result->woven->TakeBufferHandle().release());
+  }
+  if (result->fence) {
+    out.fence_handle = reinterpret_cast<uintptr_t>(
+        result->fence->TakeBufferHandle().release());
+  }
+  return out;
+}
