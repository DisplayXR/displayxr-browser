diff --git a/cc/trees/layer_tree_host_impl.cc b/cc/trees/layer_tree_host_impl.cc
index 7f28122e1fc1a..80d8cc6dcd2bc 100644
--- a/cc/trees/layer_tree_host_impl.cc
+++ b/cc/trees/layer_tree_host_impl.cc
@@ -2457,6 +2457,49 @@ viz::CompositorFrameMetadata LayerTreeHostImpl::MakeCompositorFrameMetadata() {
         /*is_for_compositor_frame_metadata=*/true);
     metadata.inline_3d_rects = active_tree()->inline_3d_rects();
   }
+  // DisplayXR inline-3D (#625, Step B / Phase 2 — scroll-sync): the rects above
+  // are getBoundingClientRect measured on the Blink main thread at the COMMITTED
+  // scroll offset. This (Viz-process) host_impl may have impl-scrolled the page
+  // further before drawing, so the composited pixels sit ahead of the reported
+  // rects → the woven sub-rects trail (raw SBS peeks) during a fling. Shift each
+  // rect back by the viewport's impl-accumulated scroll delta (current active
+  // offset − committed base) so the weave rect tracks the pixels presented THIS
+  // frame. Handles the dominant case (content scrolling with the root viewport);
+  // nested-scroller content is a follow-up.
+  if (!metadata.inline_3d_rects.empty()) {
+    const ScrollNode* viewport_scroll = OuterViewportScrollNode();
+    if (!viewport_scroll) {
+      viewport_scroll = InnerViewportScrollNode();
+    }
+    if (viewport_scroll && viewport_scroll->element_id) {
+      const ScrollTree& scroll_tree =
+          active_tree_->property_trees()->scroll_tree();
+      if (const SyncedScrollOffset* synced =
+              scroll_tree.GetSyncedScrollOffset(viewport_scroll->element_id)) {
+        // Delta() == active offset − active base == impl scroll accumulated since
+        // the commit that supplied these rects (DIP; matches getBoundingClientRect
+        // units before the device-scale multiply Blink applied).
+        const gfx::Vector2dF delta = synced->Delta();
+        const float dsf = active_tree_->device_scale_factor();
+        const int dx = base::ClampRound(delta.x() * dsf);
+        const int dy = base::ClampRound(delta.y() * dsf);
+        if (dx != 0 || dy != 0) {
+          // Growing scroll offset moves content up/left → element window origin
+          // decreases by the same device-px amount.
+          for (gfx::Rect& r : metadata.inline_3d_rects) {
+            r.Offset(-dx, -dy);
+          }
+          static int log_throttle = 0;
+          if ((log_throttle++ % 30) == 0) {
+            VLOG(1) << "[DisplayXR] Phase2 scroll-sync: viewport impl delta dip="
+                    << delta.ToString() << " -> shift device px=(" << -dx << ","
+                    << -dy << ") dsf=" << dsf << " n="
+                    << metadata.inline_3d_rects.size();
+          }
+        }
+      }
+    }
+  }
 
   if (!screenshot_destination_.is_empty()) {
     metadata.screenshot_destination =
