   bool SubmitBatchSync() override;
+  bool SetBatchOverlayMac(IOSurfaceRef atlas) override;
 
  private:
   // Lazily (re)create the shared window-sized input IOSurface (BGRA8, global so
@@ -80,6 +88,16 @@ class DisplayXRWeaveGpuMac : public viz::DisplayXRWeaveProvider {
 
   bool batch_open_ = false;
   gfx::Size batch_size_;
+
+  // v4/v5 (browser#18/#22): the window-sized premul-BGRA 2D overlay atlas staged
+  // by SetBatchOverlayMac between BeginBatchSync and SubmitBatchSync, submitted
+  // alongside input_iosurface_ (chained XrWeaveSubmitOverlaysDXR) so the DP
+  // composites 2D OVER the woven output. Retained (CFRetain via RETAIN policy)
+  // until the next batch overwrites it. |overlay_set_this_batch_| is cleared in
+  // BeginBatchSync and set by SetBatchOverlayMac; a frame that never stages an
+  // overlay weaves with none.
+  base::apple::ScopedCFTypeRef<IOSurfaceRef> overlay_atlas_;
+  bool overlay_set_this_batch_ = false;
   struct BatchEntry {
     uint32_t target_id = 0;
     gfx::Rect rect;  // window-relative device px
diff --git a/components/displayxr/gpu/displayxr_weave_gpu_mac.mm b/components/displayxr/gpu/displayxr_weave_gpu_mac.mm
index 59fc5bd3d2440..3bec0ae8eab1c 100644
--- a/components/displayxr/gpu/displayxr_weave_gpu_mac.mm
+++ b/components/displayxr/gpu/displayxr_weave_gpu_mac.mm
@@ -15,6 +15,7 @@
 
 
 #include "base/logging.h"
+#include "base/memory/scoped_policy.h"
 #include "components/displayxr/browser/displayxr_weave_client.h"
 #include "components/displayxr/browser/displayxr_weave_client_mac.h"
 
@@ -114,9 +115,72 @@
   batch_open_ = true;
   batch_size_ = window_size;
   batch_entries_.clear();
+  overlay_set_this_batch_ = false;
   EnsureSharedInput(window_size);
 }
 
+// v4/v5 (browser#18/#22): stage the window-sized premul-BGRA 2D overlay atlas for
+// THIS batch. Called (at most once) between BeginBatchSync and SubmitBatchSync.
+//
+// The caller's |atlas| is a Chromium shared-image IOSurface — it is NOT global,
+// so the runtime service (a SEPARATE process) cannot IOSurfaceLookup it by ID and
+// the whole submit fails ("weave failed xrt_result=-1" + broken pipe → white
+// tiles; #0053). Like the weave INPUT (EnsureSharedInput), the overlay MUST be a
+// kIOSurfaceIsGlobal surface. So MTL-blit the caller's atlas into a gpu_mac-owned
+// GLOBAL overlay IOSurface and submit THAT — the runtime derives its global ID.
+bool DisplayXRWeaveGpuMac::SetBatchOverlayMac(IOSurfaceRef atlas) {
+  if (!batch_open_ || !atlas || !device_ || !queue_) {
+    return false;
+  }
+  const size_t w = IOSurfaceGetWidth(atlas);
+  const size_t h = IOSurfaceGetHeight(atlas);
+  if (w == 0 || h == 0) {
+    return false;
+  }
+  // Reuse a gpu_mac-owned GLOBAL BGRA8 overlay IOSurface; recreate on size change.
+  if (!overlay_atlas_ || IOSurfaceGetWidth(overlay_atlas_.get()) != w ||
+      IOSurfaceGetHeight(overlay_atlas_.get()) != h) {
+#pragma clang diagnostic push
+#pragma clang diagnostic ignored "-Wdeprecated-declarations"
+    NSDictionary* props = @{
+      (id)kIOSurfaceWidth : @((unsigned)w),
+      (id)kIOSurfaceHeight : @((unsigned)h),
+      (id)kIOSurfaceBytesPerElement : @4,
+      (id)kIOSurfacePixelFormat : @((unsigned)'BGRA'),
+      (id)kIOSurfaceIsGlobal : @YES,
+    };
+#pragma clang diagnostic pop
+    IOSurfaceRef surf = IOSurfaceCreate((__bridge CFDictionaryRef)props);
+    if (!surf) {
+      return false;
+    }
+    overlay_atlas_.reset(surf);  // adopts the +1 ref from Create
+  }
+  id<MTLDevice> device = (__bridge id<MTLDevice>)device_;
+  id<MTLCommandQueue> queue = (__bridge id<MTLCommandQueue>)queue_;
+  id<MTLTexture> src = WrapIOSurface(device, atlas);
+  id<MTLTexture> dst = WrapIOSurface(device, overlay_atlas_.get());
+  if (!src || !dst) {
+    return false;
+  }
+  id<MTLCommandBuffer> cb = [queue commandBuffer];
+  id<MTLBlitCommandEncoder> blit = [cb blitCommandEncoder];
+  [blit copyFromTexture:src
+            sourceSlice:0
+            sourceLevel:0
+           sourceOrigin:MTLOriginMake(0, 0, 0)
+             sourceSize:MTLSizeMake(w, h, 1)
+              toTexture:dst
+       destinationSlice:0
+       destinationLevel:0
+      destinationOrigin:MTLOriginMake(0, 0, 0)];
+  [blit endEncoding];
+  [cb commit];
+  [cb waitUntilCompleted];
+  overlay_set_this_batch_ = true;
+  return true;
+}
