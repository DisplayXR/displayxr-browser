   // IOSurfaceGetID(). Passing the raw IOSurfaceID makes the runtime deref a small
   // integer -> EXC_BAD_ACCESS. Pass the ref pointer (matches the probe's
   // submit.inputTexture = (void*)input contract).
+  // v4: hand the overlay atlas alongside the content input when one was staged
+  // this frame; 0 otherwise (runtime omits the overlay chain). Like the input,
+  // the wire handle is the IOSurface*REF* pointer (the runtime derives the global
+  // IOSurfaceID itself). No DXGI on mac.
+  const uintptr_t overlay_handle =
+      (overlay_set_this_batch_ && overlay_atlas_)
+          ? reinterpret_cast<uintptr_t>(overlay_atlas_.get())
+          : 0;
   DisplayXRWeaveClient::WeaveSubmitResult sr = DisplayXRWeaveClient::SubmitBatch(
       reinterpret_cast<uintptr_t>(input_iosurface_.get()), rects,
-      /*input_is_dxgi=*/false);
+      /*input_is_dxgi=*/false, overlay_handle, /*overlay_is_dxgi=*/false);
   if (!sr.ok) {
     static int s_fail = 0;
     if (s_fail < 3) {
@@ -276,6 +348,75 @@
   return true;
 }
 
+bool DisplayXRWeaveGpuMac::SubmitAtlasV6Mac(
+    IOSurfaceRef atlas,
+    uint32_t view_count,
+    uint32_t tile_columns,
+    uint32_t tile_rows,
+    uint32_t content_view_width,
+    uint32_t content_view_height,
+    const std::vector<gfx::Rect>& rects) {
+  // v6 (#774): the caller (SkiaOutputSurfaceImplOnGpu::MaybeWeaveOverlaysMac) has
+  // already Skia-assembled the packed N-view atlas into |atlas|, so we skip the
+  // BeginBatchSync/WeaveCanvasMac MTLBlit packing entirely — just submit |atlas|
+  // with the layout chained. |rects| are the element window rects (scope hint).
+  batch_open_ = false;  // close the batch the caller opened (no WeaveCanvasMac)
+  batch_entries_.clear();
+  if (!atlas) {
+    return false;
+  }
+  DisplayXRWeaveClient::SnapWindowIfMoved();  // parity; identity on mac
+
+  std::vector<DisplayXRWeaveClient::WeaveRect> wrects;
+  wrects.reserve(rects.size());
+  for (const gfx::Rect& r : rects) {
+    wrects.push_back({r.x(), r.y(), r.width(), r.height()});
+  }
+
+  // v4/v5 overlay atlas (staged via SetBatchOverlayMac between BeginBatchSync and
+  // here) rides the same submit; 0 if none this frame. IOSurface*REF* pointer.
+  const uintptr_t overlay_handle =
+      (overlay_set_this_batch_ && overlay_atlas_)
+          ? reinterpret_cast<uintptr_t>(overlay_atlas_.get())
+          : 0;
+
+  // Pass the atlas as an IOSurface*REF* pointer (the runtime derives the global
+  // IOSurfaceID itself — see SubmitBatchSync's note). view_count > 0 chains the
+  // XrWeaveSubmitLayoutDXR inside SubmitBatchMac.
+  DisplayXRWeaveClient::WeaveSubmitResult sr = displayxr::SubmitBatchMac(
+      reinterpret_cast<uintptr_t>(atlas), wrects, /*input_is_dxgi=*/false,
+      overlay_handle, view_count, tile_columns, tile_rows, content_view_width,
+      content_view_height);
+  if (!sr.ok) {
+    static int s_fail = 0;
+    if (s_fail < 3) {
+      ++s_fail;
+      LOG(ERROR) << "[DisplayXR] mac v6 atlas weave submit failed (views="
+                 << view_count << " grid=" << tile_columns << "x" << tile_rows
+                 << " content=" << content_view_width << "x"
+                 << content_view_height << ")";
+    }
+    return false;
+  }
+
+  // The woven output (one content view) is handed back as an IOSurface*REF* on
+  // the FIRST submit only (0 afterwards; the runtime re-weaves into the same
+  // surface). Adopt it into cached_woven_ and reuse it every frame — Phase B's
+  // BlitWovenToMac reads cached_woven_.
+  if (sr.woven_handle) {
+    cached_woven_.reset(reinterpret_cast<IOSurfaceRef>(sr.woven_handle));
+  }
+  static int s_ok_throttle = 0;
+  if ((s_ok_throttle++ % 120) == 0) {
+    VLOG(1) << "[DisplayXR] mac v6 atlas weave ok: views=" << view_count
+            << " grid=" << tile_columns << "x" << tile_rows
+            << " content=" << content_view_width << "x" << content_view_height
+            << " out=" << sr.width << "x" << sr.height
+            << " overlay=" << (overlay_handle ? "yes" : "no");
+  }
+  return cached_woven_.get() != nullptr;
+}
