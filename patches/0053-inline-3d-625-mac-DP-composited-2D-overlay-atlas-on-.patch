@@ -36,10 +36,27 @@ std::vector<DisplayXRWeaveClient::RigView> LocateViewsForRectMac(
 
 // PR3: batched synchronous weave (spec v3). Returns the woven IOSurface (as an
 // IOSurfaceID in woven_handle) + eyes. input_handle is the input IOSurfaceID.
+// |overlay_handle| (XR_DXR_weave spec v4/v5, browser#18/#22) is an optional
+// window-sized premul-BGRA 2D overlay atlas IOSurface*REF* pointer (0 = none) the
+// DP composites OVER the woven output; chained as XrWeaveSubmitOverlaysDXR on the
+// last chunk. There is no DXGI on mac, so no overlay_is_dxgi.
+//
+// v6 (#774): when |view_count| > 0 the |input_handle| is a WORST-CASE N-view
+// atlas (tiles packed contiguously from the top-left at
+// |content_view_width|x|content_view_height|, grid |tile_columns|x|tile_rows|)
+// rather than the per-rect squeezed SBS of v3/v4/v5. An XrWeaveSubmitLayoutDXR is
+// then chained; |rects| degrade to a scope hint. |view_count| == 0 keeps the
+// v3/v4/v5 layout byte-for-byte (the default). N>2 is blocked on #776.
 DisplayXRWeaveClient::WeaveSubmitResult SubmitBatchMac(
     uintptr_t input_handle,
     const std::vector<DisplayXRWeaveClient::WeaveRect>& rects,
-    bool input_is_dxgi);
+    bool input_is_dxgi,
+    uintptr_t overlay_handle,
+    uint32_t view_count = 0,
+    uint32_t tile_columns = 0,
+    uint32_t tile_rows = 0,
+    uint32_t content_view_width = 0,
+    uint32_t content_view_height = 0);
 
 }  // namespace displayxr
 
diff --git a/components/displayxr/browser/displayxr_weave_client_mac.mm b/components/displayxr/browser/displayxr_weave_client_mac.mm
index d881d78881426..8c663d43ba649 100644
--- a/components/displayxr/browser/displayxr_weave_client_mac.mm
+++ b/components/displayxr/browser/displayxr_weave_client_mac.mm
@@ -621,13 +621,48 @@ uint32_t WeaveSpecVersionMac() {
 DisplayXRWeaveClient::WeaveSubmitResult SubmitBatchMac(
     uintptr_t input_handle,
     const std::vector<DisplayXRWeaveClient::WeaveRect>& rects,
-    bool /*input_is_dxgi*/) {
+    bool /*input_is_dxgi*/,
+    uintptr_t overlay_handle,
+    uint32_t view_count,
+    uint32_t tile_columns,
+    uint32_t tile_rows,
+    uint32_t content_view_width,
+    uint32_t content_view_height) {
   const size_t rect_count = rects.size();
   DisplayXRWeaveClient::WeaveSubmitResult result;
   MacWeaveState& s = State();
   if (s.session == XR_NULL_HANDLE || !s.submit || rect_count == 0) {
     return result;  // dormant / failed init / nothing to weave
   }
+
+  // v6 (#774): chain XrWeaveSubmitLayoutDXR when the caller assembled an N-view
+  // worst-case atlas (view_count > 0). The runtime parses the struct by TYPE
+  // PRESENCE (OXR_GET_INPUT_FROM_CHAIN), NOT by advertised version, so a v6-
+  // capable runtime consumes it regardless of the spec number it reports.
+  //
+  // NOTE(v6 gate — read before "fixing" to >= 6): the shipping v6 runtime
+  // (feat/macos-weave-v6-nview, #774) still advertises XR_DXR_weave
+  // SPEC_VERSION 5 — it did NOT bump the version macro even though it added the
+  // layout struct. Gating on >= 6 would therefore NEVER fire against the very
+  // runtime this path targets, leaving the mac gallery broken. We gate on >= 5
+  // (the minimum a v6-capable runtime reports) and log once. A genuine v5-only
+  // runtime that predates #774 would misread the content-sized atlas as
+  // window-sized SBS, but the browser's mac assembly is now v6-only, so there is
+  // no v5 layout to fall back to anyway.
+  // TODO(v6): once the runtime bumps XR_DXR_weave_SPEC_VERSION to 6, tighten
+  // this to >= 6 and drop the note. N>2 is blocked on #776 (mode negotiation).
+  const bool want_v6 = view_count > 0;
+  const bool v6 = want_v6 && s.weave_spec_version >= 5;
+  if (want_v6 && !v6) {
+    static bool logged_v6 = false;
+    if (!logged_v6) {
+      logged_v6 = true;
+      VLOG(1) << "[DisplayXR] SubmitBatch(mac) v6 N-view atlas requested but "
+                 "runtime weave spec="
+              << s.weave_spec_version << " (<5) — cannot chain layout";
+    }
+  }
+
   if (s.weave_spec_version < 3) {
     static bool logged_v2 = false;
     if (!logged_v2) {
@@ -656,10 +691,48 @@ uint32_t WeaveSpecVersionMac() {
     batch.rectCount = static_cast<uint32_t>(n);
     batch.rects = xr_rects;
 
+    // v6 (#774): the N-view worst-case atlas layout. Chained onto in.next
+    // AFTER the rects (chain order: in -> [overlays] -> rects -> layout; the
+    // runtime walks by type so order is not load-bearing, but this mirrors the
+    // runtime probe). With this present, |input_handle| is the packed N-view
+    // atlas and |rects| are a scope hint. Only chained once the whole frame is
+    // in this single chunk (rect_count <= MAX); a split frame would need the
+    // layout on every chunk, which the browser never hits at N=2 anaglyph.
+    XrWeaveSubmitLayoutDXR layout = {XR_TYPE_WEAVE_SUBMIT_LAYOUT_DXR};
+    if (v6) {
+      layout.viewCount = view_count;
+      layout.tileColumns = tile_columns;
+      layout.tileRows = tile_rows;
+      layout.contentViewWidth = content_view_width;
+      layout.contentViewHeight = content_view_height;
+      batch.next = &layout;
+    }
+
     XrWeaveSubmitInfoDXR in = {XR_TYPE_WEAVE_SUBMIT_INFO_DXR};
     in.next = &batch;
     in.inputTexture = reinterpret_cast<void*>(input_handle);  // IOSurfaceRef ptr
     in.inputIsDxgi = XR_FALSE;
+    // v5 (browser#22): mark the FIRST chunk of the frame so the runtime clears its
+    // window-sized woven output to premultiplied transparent before weaving — gaps
+    // between tiles come out transparent (not stale), letting the caller present
+    // the woven output whole-window. Later chunks (done > 0) accumulate into the
+    // same output. No-op on a spec<5 runtime (field past its struct; ignored).
+    in.firstChunk = (done == 0) ? XR_TRUE : XR_FALSE;
+
+    // v4 (browser#18/#22): the DP-composited 2D overlay atlas composites OVER the
+    // whole woven output, so chain it on the LAST chunk only — once, on top, after
+    // every rect has woven. Splice ahead of the rects struct (next-chains are
+    // unordered) so the batch layout is preserved. The atlas is an IOSurface*REF*
+    // pointer like the input; no DXGI on mac.
+    XrWeaveSubmitOverlaysDXR overlays = {XR_TYPE_WEAVE_SUBMIT_OVERLAYS_DXR};
+    const bool last_chunk = (done + n) >= rect_count;
+    if (overlay_handle != 0 && last_chunk && s.weave_spec_version >= 4) {
+      overlays.overlayTexture = reinterpret_cast<void*>(overlay_handle);
+      overlays.overlayIsDxgi = XR_FALSE;
+      overlays.rectCount = 0;  // whole-atlas composite (premul alpha authoritative)
+      overlays.next = &batch;
+      in.next = &overlays;
+    }
 
     XrWeaveOutputDXR out = {XR_TYPE_WEAVE_OUTPUT_DXR};
     const XrResult sr = s.submit(s.session, &in, &out);
