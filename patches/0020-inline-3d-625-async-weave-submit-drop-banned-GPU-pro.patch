+
+bool DisplayXRWeaveGpu::SubmitInput(const gfx::Rect& window_rect,
+                                    uint32_t target_id) {
+  // Duplicate the input handle for the Mojo message (it consumes/duplicates the
+  // handle into the browser process); keep our own for reuse. The single-in-
+  // flight guard keeps the input stable until the reply, so the browser reads
+  // the pixels we just wrote even though the call no longer blocks.
   HANDLE dup = nullptr;
   if (!::DuplicateHandle(::GetCurrentProcess(), input_handle_,
                          ::GetCurrentProcess(), &dup, 0, FALSE,
                          DUPLICATE_SAME_ACCESS) ||
       !dup) {
-    LOG(ERROR) << "[DisplayXR] B4b WeavePixels: DuplicateHandle(input) failed";
-    return out;
+    LOG(ERROR) << "[DisplayXR] weave: DuplicateHandle(input) failed";
+    return false;
   }
   gfx::DXGIHandle input{base::win::ScopedHandle(dup)};
 
-  mojom::DisplayXRWeaveResultPtr result;
-  if (!weaver_->WeaveSubmit(std::move(input), window_rect, &result)) {
-    LOG(ERROR) << "[DisplayXR] B4b WeavePixels: Sync WeaveSubmit call failed";
-    return out;
-  }
+  submit_in_flight_ = true;
+  // ASYNC: fire WeaveSubmit without blocking (a [Sync] call from the GPU process
+  // is banned). The reply lands back on this GPU-main sequence (the Remote lives
+  // here); OnWeaveReply stores the woven handles for |target_id|.
+  weaver_->WeaveSubmit(std::move(input), window_rect,
+                       base::BindOnce(&DisplayXRWeaveGpu::OnWeaveReply,
+                                      weak_factory_.GetWeakPtr(), target_id));
+  return true;
+}
+
+void DisplayXRWeaveGpu::OnWeaveReply(uint32_t target_id,
+                                     mojom::DisplayXRWeaveResultPtr result) {
+  submit_in_flight_ = false;
   if (!result) {
-    return out;
+    // Browser-side weave failed / session not live; keep the target's last good
+    // woven result so it stops updating rather than flickering to raw.
+    return;
   }
 
-  out.ok = true;
-  out.fence_value = result->fence_value;
-  out.width = result->width;
-  out.height = result->height;
+  PendingResult& pending = results_[target_id];
+  Result r;
+  r.ok = true;
+  r.fence_value = result->fence_value;
+  r.width = result->width;
+  r.height = result->height;
+  // The woven/fence handles are fresh only on (re)allocation; a steady-state
+  // reply reuses the same texture. If a fresh handle from a prior un-taken reply
+  // is still pending, carry it forward (same underlying texture) so Viz doesn't
+  // miss the import.
   if (result->woven) {
-    out.woven_handle = reinterpret_cast<uintptr_t>(
+    r.woven_handle = reinterpret_cast<uintptr_t>(
         result->woven->TakeBufferHandle().release());
+  } else if (pending.have) {
+    r.woven_handle = pending.result.woven_handle;
+    pending.result.woven_handle = 0;
   }
   if (result->fence) {
-    out.fence_handle = reinterpret_cast<uintptr_t>(
+    r.fence_handle = reinterpret_cast<uintptr_t>(
         result->fence->TakeBufferHandle().release());
+  } else if (pending.have) {
+    r.fence_handle = pending.result.fence_handle;
+    pending.result.fence_handle = 0;
+  }
+  // Close whatever the prior un-taken result still owns (not carried forward).
+  if (pending.have) {
+    CloseResultHandles(pending.result);
+  }
+  pending.result = r;
+  pending.have = true;
+}
+
+bool DisplayXRWeaveGpu::TryTakeWovenResult(uint32_t target_id, Result* out) {
+  auto it = results_.find(target_id);
+  if (it == results_.end() || !it->second.have) {
+    return false;
+  }
+  *out = it->second.result;
+  // Ownership of the handles transfers to the caller; drop our copy so the
+  // dtor / a later reply does not double-close them.
+  it->second.result = Result();
+  it->second.have = false;
+  return true;
+}
+
+void DisplayXRWeaveGpu::PruneTargets(size_t count) {
+  for (auto it = results_.begin(); it != results_.end();) {
+    if (it->first >= count) {
+      if (it->second.have) {
+        CloseResultHandles(it->second.result);
+      }
+      it = results_.erase(it);
+    } else {
+      ++it;
+    }
+  }
+}
+
+// static
+void DisplayXRWeaveGpu::CloseResultHandles(Result& r) {
+  if (r.woven_handle) {
+    ::CloseHandle(reinterpret_cast<HANDLE>(r.woven_handle));
+    r.woven_handle = 0;
+  }
+  if (r.fence_handle) {
+    ::CloseHandle(reinterpret_cast<HANDLE>(r.fence_handle));
+    r.fence_handle = 0;
   }
-  return out;
 }
 
 }  // namespace displayxr
