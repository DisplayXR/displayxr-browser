@@ -42,11 +42,16 @@ struct DisplayXRWeaveResult {
 
 interface DisplayXRWeaver {
   // Weave one window sub-rect. |texture| is the pre-weave SBS keyed-mutex shared
-  // texture; |rect| is its window-relative device-pixel placement. Returns the
-  // woven output, or null if the weave failed / the session isn't live.
-  // Synchronous: the GPU thread blocks on the per-frame weave (the CEF-host
