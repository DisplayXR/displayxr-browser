 }
 
+void DisplayXRServiceImpl::GetLatestViews(const gfx::Rect& element_window_rect,
+                                          float virtual_display_height,
+                                          GetLatestViewsCallback callback) {
+  // Straight pass-through: the rect the renderer sends is already the
+  // window-client device-px rect the runtime's zone canvas is defined in, so
+  // there is nothing to rebase here. (Contrast GetLatestEyes above, which has
+  // to convert to display-relative for the renderer's own projection math.)
+  DisplayXRWeaveClient::WeaveRect rect;
+  rect.x = element_window_rect.x();
+  rect.y = element_window_rect.y();
+  rect.w = element_window_rect.width();
+  rect.h = element_window_rect.height();
+
+  std::vector<blink::mojom::DisplayXRViewPtr> out;
+  for (const DisplayXRWeaveClient::RigView& v :
+       DisplayXRWeaveClient::LocateViewsForRect(rect,
+                                                virtual_display_height)) {
+    auto mv = blink::mojom::DisplayXRView::New();
+    mv->pos_x = v.pos_x;
+    mv->pos_y = v.pos_y;
+    mv->pos_z = v.pos_z;
+    mv->orient_x = v.orient_x;
+    mv->orient_y = v.orient_y;
+    mv->orient_z = v.orient_z;
+    mv->orient_w = v.orient_w;
+    mv->fov_left = v.fov_left;
+    mv->fov_right = v.fov_right;
+    mv->fov_up = v.fov_up;
+    mv->fov_down = v.fov_down;
+    out.push_back(std::move(mv));
+  }
+  std::move(callback).Run(std::move(out));
+}
+
 }  // namespace displayxr
