+// XR_DXR_view_rig + XR_DXR_display_zones: let the RUNTIME build the off-axis
+// views for one element. See the header for why this replaces the renderer-side
+// Kooima entirely.
+std::vector<DisplayXRWeaveClient::RigView> LocateViewsForRectWin(
+    const DisplayXRWeaveClient::WeaveRect& rect,
+    float virtual_display_height) {
+  WeaveClientState& s = State();
+  std::vector<DisplayXRWeaveClient::RigView> out;
+  if (!s.has_rig_views || s.session == XR_NULL_HANDLE ||
+      s.ref_space == XR_NULL_HANDLE || !s.convert_time || rect.w <= 0 ||
+      rect.h <= 0) {
+    return out;
+  }
+
+  // xrLocateViews rejects displayTime <= 0. QPC -> XrTime is the canonical
+  // conversion; the time only drives the head/display-plane pose prediction
+  // (the eyes come from the DP's latest sample), so "now" is right here.
+  LARGE_INTEGER qpc = {};
+  if (!::QueryPerformanceCounter(&qpc)) {
+    return out;
+  }
+  XrTime now = 0;
+  if (XR_FAILED(s.convert_time(s.instance, &qpc, &now)) || now <= 0) {
+    return out;
+  }
+
+  // The rig: virtualDisplayHeight sets the scene scale (m2v = it / the
+  // element's physical height, computed runtime-side from the zone rect).
+  // Factors at 1.0 = no comfort attenuation, physical perspective.
+  XrDisplayRigDXR rig = {XR_TYPE_DISPLAY_RIG_DXR};
+  rig.pose.orientation = {0.f, 0.f, 0.f, 1.f};
+  rig.pose.position = {0.f, 0.f, 0.f};
+  rig.virtualDisplayHeight =
+      virtual_display_height > 0.f ? virtual_display_height : 0.f;
+  rig.ipdFactor = 1.f;
+  rig.parallaxFactor = 1.f;
+  rig.perspectiveFactor = 1.f;
+
+  // The zone: the element's rect IS the canvas. |rect| is window-client-relative
+  // device px — exactly what u_canvas_rect wants and exactly what the weave
+  // already submits, so there is no second coordinate derivation to get wrong.
+  XrDisplayZoneDXR zone = {XR_TYPE_DISPLAY_ZONE_DXR};
+  zone.next = &rig;
+  zone.zoneId = 0;
+  zone.rect.offset = {rect.x, rect.y};
+  zone.rect.extent = {rect.w, rect.h};
+
+  XrViewLocateInfo li = {XR_TYPE_VIEW_LOCATE_INFO};
+  li.next = &zone;
+  li.viewConfigurationType = XR_VIEW_CONFIGURATION_TYPE_PRIMARY_STEREO;
+  li.displayTime = now;
+  li.space = s.ref_space;
+
+  XrViewState vs = {XR_TYPE_VIEW_STATE};
+  XrView views[2] = {{XR_TYPE_VIEW}, {XR_TYPE_VIEW}};
+  uint32_t view_count = 0;
+  const XrResult lr =
+      xrLocateViews(s.session, &li, &vs, 2, &view_count, views);
+  if (XR_FAILED(lr) || view_count == 0) {
+    static bool warned = false;
+    if (!warned) {
+      warned = true;
+      LOG(ERROR) << "[DisplayXR] xrLocateViews (rig) failed -> " << lr;
+    }
+    return out;
+  }
+  // Both flags must be set: without POSITION_VALID the poses are meaningless
+  // and we would silently render a mono-ish scene at the origin.
+  if (!(vs.viewStateFlags & XR_VIEW_STATE_POSITION_VALID_BIT) ||
+      !(vs.viewStateFlags & XR_VIEW_STATE_ORIENTATION_VALID_BIT)) {
+    return out;
+  }
+
+  // Range-for, not views[i]: indexing a fixed-size array by variable trips
