diff --git a/gpu/command_buffer/service/shared_image/shared_image_manager.cc b/gpu/command_buffer/service/shared_image/shared_image_manager.cc
index efa9b5af0509b..4422c45111df0 100644
--- a/gpu/command_buffer/service/shared_image/shared_image_manager.cc
+++ b/gpu/command_buffer/service/shared_image/shared_image_manager.cc
@@ -384,6 +384,36 @@ std::unique_ptr<OverlayImageRepresentation> SharedImageManager::ProduceOverlay(
   return representation;
 }
 
+#if BUILDFLAG(IS_WIN)
+std::unique_ptr<OverlayImageRepresentation>
+SharedImageManager::ProduceOverlayForWeave(const gpu::Mailbox& mailbox,
+                                           gpu::MemoryTypeTracker* tracker) {
+  CALLED_ON_VALID_THREAD();
+
+  AutoLock autolock(this);
+  auto* backing = GetBacking(mailbox);
+  if (!backing) {
+    LOG(ERROR) << "SharedImageManager::ProduceOverlayForWeave: non-existent "
+                  "mailbox.";
+    return nullptr;
+  }
+
+  // No SCANOUT enforcement here (see header): the weave source SI is
+  // DISPLAY_READ/WRITE-only (no SCANOUT, so it stays a plain D3DImageBacking
+  // rather than a DComp visual), yet the D3D overlay representation still
+  // exposes its ID3D11Texture2D, which is all the weave copy needs.
+  auto representation = backing->ProduceOverlay(this, tracker);
+  if (!representation) {
+    LOG(ERROR) << "SharedImageManager::ProduceOverlayForWeave: incompatible "
