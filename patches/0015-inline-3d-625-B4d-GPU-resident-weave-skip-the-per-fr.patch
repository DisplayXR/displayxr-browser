+        skia_representations_.erase(displayxr_scratch_state_[i].mailbox);
+      }
+    }
+  }
+  displayxr_scratch_state_.resize(inline_3d_rects_.size());
+
   // (D) Per rect: weave the composited sub-rect and draw the woven result back
   // over the output. Serialized (the provider reuses one keyed-mutex input +
   // one woven output), mirroring the CEF host's per-element loop.
@@ -2808,52 +2830,209 @@ void SkiaOutputSurfaceImplOnGpu::WeaveCompositedSurface(SkSurface* output,
       continue;
     }
 
-    // Read the composited sub-rect back to CPU (BGRA8), then upload it into the
-    // weave input. Ganesh has a synchronous SkSurface::readPixels; Graphite has
-    // no sync readback, so it uses the blocking-async path. Read from the output
-    // SkSurface (it knows its own recording context and flushes as needed). We
-    // read before drawing the woven back, so there is no read/write hazard.
     const int rw = rect.width();
     const int rh = rect.height();
-    const SkImageInfo info = SkImageInfo::Make(
-        rw, rh, kBGRA_8888_SkColorType, kPremul_SkAlphaType,
-        SkColorSpace::MakeSRGB());
-
-    const uint8_t* src_pixels = nullptr;
-    size_t src_stride = 0;
-    std::vector<uint8_t> ganesh_pixels;    // owns the Ganesh sync-read pixels
-    WeaveReadPixelsContext read_ctx;       // owns the Graphite async-read result
-    if (auto* graphite = context_state_->graphite_shared_context()) {
-      // Graphite: blocking-async rescale+read of the sub-rect (identity scale —
-      // dst dims == src rect dims), submitting + waiting so the pixels are ready
-      // synchronously. FlushGraphiteRecorder() first so the just-drawn output is
-      // committed before the read.
-      context_state_->FlushGraphiteRecorder();
-      graphite->asyncRescaleAndReadPixelsAndSubmit(
-          output, info, SkIRect::MakeXYWH(rect.x(), rect.y(), rw, rh),
-          SkImage::RescaleGamma::kSrc, SkImage::RescaleMode::kRepeatedLinear,
-          base::BindOnce(&WeaveReadPixelsContext::OnReadPixelsDone), &read_ctx);
-      if (!read_ctx.finished || !read_ctx.async_result ||
-          read_ctx.async_result->count() != 1) {
-        continue;
-      }
-      src_pixels =
-          reinterpret_cast<const uint8_t*>(read_ctx.async_result->data(0));
-      src_stride = read_ctx.async_result->rowBytes(0);
-    } else {
-      // Ganesh: synchronous readback into a local buffer.
-      const size_t stride = static_cast<size_t>(rw) * 4;
-      ganesh_pixels.resize(stride * rh);
-      if (!output->readPixels(info, ganesh_pixels.data(), stride, rect.x(),
-                              rect.y())) {
-        continue;
+
+    DisplayXRWeaveProvider::Result r;
+    bool wove = false;
+
+    // B4d GPU-resident weave (DComp path, prefer_zero_copy). Keep the composited
+    // sub-rect on the GPU instead of the readPixels roundtrip: Skia-copy it into
+    // an owned SCANOUT scratch D3DImageBacking, ProduceOverlay its raw
+    // ID3D11Texture2D, and WeaveCanvas it straight into the keyed-mutex weave
+    // input. No hazard with the root backing's open write access — we snapshot
+    // |output| (as readPixels already does) and only ProduceOverlay a *separate*
+    // scratch mailbox. Any step failing falls through to the CPU readback below.
+    if (prefer_zero_copy) {
+      wove = [&]() -> bool {
+        // If any step fails we fall back to the WeavePixels CPU readback (still
+        // correct), logging the first reason once at VLOG(1) so a future
+        // regression is diagnosable without spamming default chrome.
+        static bool logged_fail = false;
+        auto fail = [&](const char* why) -> bool {
+          if (!logged_fail) {
+            logged_fail = true;
+            VLOG(1) << "[DisplayXR] B4d zero-copy fell back to WeavePixels: "
+                    << why;
+          }
+          return false;
+        };
+        DisplayXRScratchState& sc = displayxr_scratch_state_[i];
+        // (1) Ensure an owned DISPLAY_READ/WRITE (NON-SCANOUT) D3DImageBacking
+        // scratch sized to |rect|. Non-scanout is deliberate: a SCANOUT backing
+        // on Windows becomes a DComp visual (want_dcomp_texture in
+        // d3d_image_backing_factory.cc) whose overlay image is NOT a raw texture
+        // (kDCompVisualContent); a plain DISPLAY backing keeps a sampleable
+        // ID3D11Texture2D, read below via the SCANOUT-gate-free
+        // ProduceOverlayForWeave. BGRA8 matches |output|.
+        if (sc.mailbox.IsZero() || sc.size != rect.size()) {
+          if (!sc.mailbox.IsZero()) {
+            shared_image_factory_->DestroySharedImage(sc.mailbox);
+            skia_representations_.erase(sc.mailbox);
+            sc.mailbox = gpu::Mailbox();
+          }
+          gpu::Mailbox mailbox = gpu::Mailbox::Generate();
+          gpu::SharedImageInfo si_info(
+              SinglePlaneFormat::kBGRA_8888, rect.size(),
+              gfx::ColorSpace::CreateSRGB(), kTopLeft_GrSurfaceOrigin,
+              kPremul_SkAlphaType,
+              gpu::SHARED_IMAGE_USAGE_DISPLAY_READ |
+                  gpu::SHARED_IMAGE_USAGE_DISPLAY_WRITE |
+                  // CPU_READ forces D3DImageBackingFactory: under Graphite-Dawn a
+                  // plain DISPLAY-only image is claimed by WrappedSkImageBacking
+                  // (no overlay). CPU_READ is in D3D's supported set but not
+                  // WrappedSkImage's / DComp's, and (unlike SCANOUT) does NOT set
+                  // want_dcomp_texture, so the backing stays a plain, overlay-
+                  // exposable ID3D11Texture2D (kD3D11Texture).
+                  gpu::SHARED_IMAGE_USAGE_CPU_READ,
+              "DisplayXRScratch");
+          if (!shared_image_factory_->CreateSharedImage(
+                  mailbox, si_info, gpu::kNullSurfaceHandle)) {
+            return fail("CreateSharedImage(scratch)");
+          }
+          sc.mailbox = mailbox;
+          sc.size = rect.size();
+        }
+
+        // (2) GPU Skia-copy the composited sub-rect into the scratch surface.
+        {
+          auto scratch_rep = shared_image_representation_factory_->ProduceSkia(
+              sc.mailbox, context_state_.get());
+          if (!scratch_rep) {
+            return fail("ProduceSkia(scratch)");
+          }
+          std::vector<GrBackendSemaphore> sbegin, send;
+          SkSurfaceProps props;
+          auto scratch_write = scratch_rep->BeginScopedWriteAccess(
+              /*final_msaa_count=*/0, props, &sbegin, &send,
+              gpu::SharedImageRepresentation::AllowUnclearedAccess::kYes);
+          if (!scratch_write || !scratch_write->surface()) {
+            return fail("BeginScopedWriteAccess(scratch)");
+          }
+          SkSurface* scratch_surface = scratch_write->surface();
+          if (!sbegin.empty()) {
+            scratch_surface->wait(sbegin.size(), sbegin.data(),
+                                  /*deleteSemaphoresAfterWait=*/false);
+          }
+          // Commit the just-drawn output before snapshotting it (Graphite is
+          // deferred; Ganesh handles this in makeImageSnapshot).
+          if (context_state_->graphite_shared_context()) {
+            context_state_->FlushGraphiteRecorder();
+          }
+          sk_sp<SkImage> src_img = output->makeImageSnapshot(
+              SkIRect::MakeXYWH(rect.x(), rect.y(), rw, rh));
+          if (!src_img) {
+            return fail("makeImageSnapshot");
+          }
+          SkPaint paint;
+          paint.setBlendMode(SkBlendMode::kSrc);
+          scratch_surface->getCanvas()->drawImageRect(
+              src_img.get(), SkRect::MakeWH(rw, rh), SkRect::MakeWH(rw, rh),
+              SkSamplingOptions(SkFilterMode::kNearest), &paint,
+              SkCanvas::kStrict_SrcRectConstraint);
+          FlushSurface(scratch_surface, send, scratch_write.get());
+          if (gr_context()) {
+            gr_context()->submit();
+          }
+          if (graphite_shared_context()) {
+            graphite_shared_context()->submit();
+          }
+          // scratch_write / scratch_rep release here; content is submitted.
+        }
+
+        // (3) ProduceOverlayForWeave the scratch (SCANOUT-gate-free) to get its
+        // raw ID3D11Texture2D.
+        auto overlay_rep =
+            shared_image_representation_factory_->ProduceOverlayForWeave(
+                sc.mailbox);
+        if (!overlay_rep) {
+          return fail("ProduceOverlayForWeave(scratch)");
+        }
+        auto overlay_read = overlay_rep->BeginScopedReadAccess();
+        if (!overlay_read) {
+          return fail("overlay BeginScopedReadAccess");
+        }
+        std::optional<gl::DCLayerOverlayImage> ov =
+            overlay_read->GetDCLayerOverlayImage();
+        if (!ov || ov->type() != gl::DCLayerOverlayType::kD3D11Texture ||
+            !ov->d3d11_video_texture()) {
+          if (!logged_fail) {
+            logged_fail = true;
+            VLOG(1) << "[DisplayXR] B4d zero-copy fell back to WeavePixels: "
+                       "overlay not kD3D11Texture (has_value="
+                    << ov.has_value() << " type="
+                    << (ov ? static_cast<int>(ov->type()) : -1) << ")";
+          }
+          return false;  // not a raw texture -> caller falls back to readback
+        }
+
+        // (4) GPU-resident weave: CopySubresourceRegion scratch -> keyed-mutex
+        // input, then submit to the service. WeaveCanvas is synchronous, so the
+        // overlay read access stays valid across it.
+        r = provider->WeaveCanvas(
+            device_x.Get(), ov->d3d11_video_texture(),
+            static_cast<UINT>(ov->texture_array_slice()),
+            gfx::Rect(0, 0, rw, rh), rect);
+        static bool logged_zc = false;
+        if (r.ok && !logged_zc) {
+          logged_zc = true;
+          VLOG(1) << "[DisplayXR] weave: GPU-resident scratch path (no CPU "
+                     "readback) "
+                  << rw << "x" << rh;
+        }
+        return r.ok;
+      }();
+    }
+
+    if (!wove) {
+      // CPU-readback fallback (GL output device, or a failed zero-copy step):
+      // read the composited sub-rect back to CPU (BGRA8) and upload it into the
+      // weave input. Ganesh has a synchronous SkSurface::readPixels; Graphite
+      // has no sync readback, so it uses the blocking-async path. Read from the
+      // output SkSurface (it knows its own recording context and flushes as
+      // needed) before drawing the woven back, so there is no read/write hazard.
+      const SkImageInfo info = SkImageInfo::Make(
+          rw, rh, kBGRA_8888_SkColorType, kPremul_SkAlphaType,
+          SkColorSpace::MakeSRGB());
+
+      const uint8_t* src_pixels = nullptr;
+      size_t src_stride = 0;
+      std::vector<uint8_t> ganesh_pixels;  // owns the Ganesh sync-read pixels
+      WeaveReadPixelsContext read_ctx;     // owns the Graphite async-read result
+      if (auto* graphite = context_state_->graphite_shared_context()) {
+        // Graphite: blocking-async rescale+read of the sub-rect (identity scale
+        // — dst dims == src rect dims), submitting + waiting so the pixels are
+        // ready synchronously. FlushGraphiteRecorder() first so the just-drawn
+        // output is committed before the read.
+        context_state_->FlushGraphiteRecorder();
+        graphite->asyncRescaleAndReadPixelsAndSubmit(
+            output, info, SkIRect::MakeXYWH(rect.x(), rect.y(), rw, rh),
+            SkImage::RescaleGamma::kSrc, SkImage::RescaleMode::kRepeatedLinear,
+            base::BindOnce(&WeaveReadPixelsContext::OnReadPixelsDone),
+            &read_ctx);
+        if (!read_ctx.finished || !read_ctx.async_result ||
+            read_ctx.async_result->count() != 1) {
+          continue;
+        }
+        src_pixels =
+            reinterpret_cast<const uint8_t*>(read_ctx.async_result->data(0));
+        src_stride = read_ctx.async_result->rowBytes(0);
+      } else {
+        // Ganesh: synchronous readback into a local buffer.
+        const size_t stride = static_cast<size_t>(rw) * 4;
+        ganesh_pixels.resize(stride * rh);
+        if (!output->readPixels(info, ganesh_pixels.data(), stride, rect.x(),
+                                rect.y())) {
+          continue;
+        }
+        src_pixels = ganesh_pixels.data();
+        src_stride = stride;
       }
-      src_pixels = ganesh_pixels.data();
-      src_stride = stride;
+
+      r = provider->WeavePixels(device_x.Get(), src_pixels,
+                                static_cast<uint32_t>(src_stride), rect);
     }
 
-    const DisplayXRWeaveProvider::Result r = provider->WeavePixels(
-        device_x.Get(), src_pixels, static_cast<uint32_t>(src_stride), rect);
     if (!r.ok) {
       continue;
     }
