   displayxr_woven_state_.resize(inline_3d_rects_.size());
 
+  // Same prune for the B4d GPU-resident weave scratch SharedImages.
+  if (displayxr_scratch_state_.size() > inline_3d_rects_.size()) {
+    for (size_t i = inline_3d_rects_.size();
