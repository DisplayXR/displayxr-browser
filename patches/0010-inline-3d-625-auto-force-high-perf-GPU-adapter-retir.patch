 .../browser/shell_content_browser_client.cc   | 26 ++++++++++++++++---
 3 files changed, 50 insertions(+), 6 deletions(-)

diff --git a/chrome/browser/chrome_content_browser_client.cc b/chrome/browser/chrome_content_browser_client.cc
index d791d1896ac5b..59563cbd9dcdd 100644
--- a/chrome/browser/chrome_content_browser_client.cc
+++ b/chrome/browser/chrome_content_browser_client.cc
@@ -382,6 +382,7 @@
 #include "extensions/common/switches.h"
 #include "google_apis/gaia/gaia_urls.h"
 #include "google_apis/google_api_keys.h"
+#include "gpu/config/gpu_driver_bug_workaround_type.h"
 #include "gpu/config/gpu_switches.h"
 #include "ipc/ipc_channel_proxy.h"
 #include "media/base/media_switches.h"
@@ -2835,9 +2836,28 @@ void ChromeContentBrowserClient::AppendExtraCommandLineSwitches(
   // DisplayXR inline-3D (#625, Step B / B4): forward the opt-in to child
   // processes so the GPU/Viz process registers the weave provider + tags the
   // canvas quad. Dormant unless requested.
-  if (base::CommandLine::ForCurrentProcess()->HasSwitch("enable-inline-3d") &&
-      !command_line->HasSwitch("enable-inline-3d")) {
-    command_line->AppendSwitch("enable-inline-3d");
+  if (base::CommandLine::ForCurrentProcess()->HasSwitch("enable-inline-3d")) {
+    if (!command_line->HasSwitch("enable-inline-3d")) {
+      command_line->AppendSwitch("enable-inline-3d");
+    }
+#if BUILDFLAG(IS_WIN)
+    // The weave input is an NT-shared keyed-mutex D3D11 texture the DisplayXR
+    // service creates on the runtime's adapter — the high-performance discrete
+    // GPU, selected by xrGetD3D11GraphicsRequirementsKHR. On a dual-GPU laptop
+    // chrome's GPU process defaults to the integrated GPU, so the service's
+    // OpenSharedResource(NT) on that handle fails cross-adapter (E_INVALIDARG).
+    // Force the GPU process onto the high-performance adapter so its device
+    // (context_state_->GetD3D11Device(), used for the weave input) shares the
+    // runtime's adapter. This is the automatic equivalent of the manual
+    // --force_high_performance_gpu launch flag (#625 blocker #5).
+    const std::string force_hp_gpu = gpu::GpuDriverBugWorkaroundTypeToString(
+        gpu::FORCE_HIGH_PERFORMANCE_GPU);
+    if (command_line->GetSwitchValueASCII(switches::kProcessType) ==
+            switches::kGpuProcess &&
+        !command_line->HasSwitch(force_hp_gpu)) {
+      command_line->AppendSwitch(force_hp_gpu);
+    }
+#endif  // BUILDFLAG(IS_WIN)
   }
 
 #if BUILDFLAG(IS_MAC)
