 }
 
+#if BUILDFLAG(IS_WIN)
+void ShellContentGpuClient::PostCompositorThreadCreated(
+    base::SingleThreadTaskRunner* task_runner) {
+  // #625 Step B (B2b): one-shot probe proving the GPU->browser weave bridge.
+  // Runs on the GPU main thread (where ChildThread lives). The browser only
+  // binds the receiver when --enable-inline-3d is set, so this is dormant
+  // otherwise (the reply never arrives). B2c replaces this with the per-frame
+  // weave driven from Viz.
+  ChildThread::Get()->BindHostReceiver(weaver_.BindNewPipeAndPassReceiver());
+  weaver_->WeaveSubmit(
+      gfx::Rect(0, 0, 1, 1), base::BindOnce([](bool ok) {
+        LOG(ERROR) << "[DisplayXR] B2b GPU->browser WeaveSubmit reply ok=" << ok
+                   << " — GPU<->browser bridge PASSED";
+      }));
+}
+#endif
+
 }  // namespace content
