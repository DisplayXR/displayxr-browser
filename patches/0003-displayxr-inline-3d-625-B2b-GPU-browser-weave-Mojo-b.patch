new file mode 100644
index 0000000000000..9e44edb40d9f7
--- /dev/null
+++ b/content/shell/common/displayxr_weave.mojom
@@ -0,0 +1,20 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+module content.shell.mojom;
+
+import "ui/gfx/geometry/mojom/geometry.mojom";
+
+// DisplayXR inline-3D weave bridge (#625, Step B). The GPU/Viz process (where the
+// canvas SharedImage + present live) calls this per frame; the BROWSER process
+// hosts it (it owns the unsandboxed OpenXR weave session — the GPU sandbox blocks
+// the per-frame RPC to displayxr-service; see docs/roadmap/webxr-step-b-design.md).
+//
+// B2b proves the channel with just the window-relative rect. B2c extends
+// WeaveSubmit to carry the pre-weave gfx.mojom.DXGIHandle in, and return the
+// woven DXGIHandle + fence + tracked eyes.
+interface DisplayXRWeaver {
+  // Returns true once the browser-side weave client has handled the submission.
+  WeaveSubmit(gfx.mojom.Rect rect) => (bool ok);
+};
