diff --git a/content/shell/browser/displayxr_weaver_impl.cc b/content/shell/browser/displayxr_weaver_impl.cc
new file mode 100644
index 0000000000000..b81f71ce3147a
--- /dev/null
+++ b/content/shell/browser/displayxr_weaver_impl.cc
@@ -0,0 +1,34 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/shell/browser/displayxr_weaver_impl.h"
+
+#include <memory>
+#include <utility>
+
+#include "base/logging.h"
+#include "mojo/public/cpp/bindings/self_owned_receiver.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace content {
+
+// static
+void DisplayXRWeaverImpl::Bind(
+    mojo::PendingReceiver<shell::mojom::DisplayXRWeaver> receiver) {
+  mojo::MakeSelfOwnedReceiver(std::make_unique<DisplayXRWeaverImpl>(),
+                              std::move(receiver));
+}
+
+DisplayXRWeaverImpl::DisplayXRWeaverImpl() = default;
+DisplayXRWeaverImpl::~DisplayXRWeaverImpl() = default;
+
+void DisplayXRWeaverImpl::WeaveSubmit(const gfx::Rect& rect,
+                                      WeaveSubmitCallback callback) {
+  // B2b: prove the GPU->browser bridge. B2c forwards to xrWeaveSubmitEXT.
+  LOG(ERROR) << "[DisplayXR] B2b WeaveSubmit received in BROWSER from GPU: rect="
+             << rect.ToString() << " — GPU<->browser bridge OK";
+  std::move(callback).Run(/*ok=*/true);
+}
+
+}  // namespace content
diff --git a/content/shell/browser/displayxr_weaver_impl.h b/content/shell/browser/displayxr_weaver_impl.h
new file mode 100644
index 0000000000000..00099b5fcb557
--- /dev/null
+++ b/content/shell/browser/displayxr_weaver_impl.h
@@ -0,0 +1,34 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_SHELL_BROWSER_DISPLAYXR_WEAVER_IMPL_H_
+#define CONTENT_SHELL_BROWSER_DISPLAYXR_WEAVER_IMPL_H_
+
+#include "content/shell/common/displayxr_weave.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+namespace content {
+
+// Browser-process implementation of the GPU->browser weave bridge (#625, Step B).
+// B2b: logs the cross-process call + returns ok, proving the channel. B2c will
+// forward WeaveSubmit to the OpenXR weave session (DisplayXRWeaveClient).
+class DisplayXRWeaverImpl : public shell::mojom::DisplayXRWeaver {
+ public:
+  // Bind a receiver to a fresh self-owned impl. Call on the UI thread
+  // (ShellContentBrowserClient::BindGpuHostReceiver hops here from the IO thread).
+  static void Bind(
+      mojo::PendingReceiver<shell::mojom::DisplayXRWeaver> receiver);
+
+  DisplayXRWeaverImpl();
+  DisplayXRWeaverImpl(const DisplayXRWeaverImpl&) = delete;
+  DisplayXRWeaverImpl& operator=(const DisplayXRWeaverImpl&) = delete;
+  ~DisplayXRWeaverImpl() override;
+
+  // shell::mojom::DisplayXRWeaver:
+  void WeaveSubmit(const gfx::Rect& rect, WeaveSubmitCallback callback) override;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_SHELL_BROWSER_DISPLAYXR_WEAVER_IMPL_H_
