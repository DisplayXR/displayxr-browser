@@ -341,6 +345,19 @@ ShellContentBrowserClient::~ShellContentBrowserClient() {
   std::erase(GetShellContentBrowserClientInstancesImpl(), this);
 }
 
+void ShellContentBrowserClient::BindGpuHostReceiver(
+    mojo::GenericPendingReceiver receiver) {
+  // DisplayXR inline-3D (#625, Step B / B2b): GPU process -> browser weave
+  // bridge. Dormant unless opted in. Called on the IO thread.
+  if (!base::CommandLine::ForCurrentProcess()->HasSwitch("enable-inline-3d")) {
+    return;
+  }
+  if (auto r = receiver.As<shell::mojom::DisplayXRWeaver>()) {
+    GetUIThreadTaskRunner({})->PostTask(
+        FROM_HERE, base::BindOnce(&DisplayXRWeaverImpl::Bind, std::move(r)));
+  }
+}
+
 std::unique_ptr<BrowserMainParts>
 ShellContentBrowserClient::CreateBrowserMainParts(
     bool /* is_integration_test */) {
