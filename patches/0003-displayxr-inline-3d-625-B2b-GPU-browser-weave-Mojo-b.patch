+  // weave bridge once the compositor thread exists (B2b channel proof).
+  void PostCompositorThreadCreated(
+      base::SingleThreadTaskRunner* task_runner) override;
+
+ private:
+  mojo::Remote<shell::mojom::DisplayXRWeaver> weaver_;
+#endif
