+  DisplayXRWeaveClient::MaybeInitializeFromCommandLine();
   return 0;
 }
 
diff --git a/third_party/displayxr/BUILD.gn b/third_party/displayxr/BUILD.gn
new file mode 100644
index 0000000000000..d85ac7389b8e1
--- /dev/null
+++ b/third_party/displayxr/BUILD.gn
@@ -0,0 +1,37 @@
+# Copyright 2026 The Chromium Authors / DisplayXR
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+#
+# DisplayXR inline-3D (#625, Step B): the OpenXR loader + DisplayXR extension
+# headers the inline-3D weave client links against. Vendored binaries — see
+# README.displayxr for provenance. This target carries ZERO vendor/weave code;
+# it is only the loader import lib + the public extension headers.
+
+import("//build/config/win/visual_studio_version.gni")
+
+# Public headers: #include <openxr/openxr.h>, <openxr/XR_EXT_weave.h>, ...
+config("openxr_headers") {
+  include_dirs = [ "include" ]
+}
+
+# Link the prebuilt OpenXR loader import lib (CRT-neutral). lib_dirs is resolved
+# relative to this BUILD.gn directory.
+config("openxr_loader_link") {
+  libs = [ "openxr_loader.lib" ]
+  lib_dirs = [ "lib" ]
+}
+
+# Depend on this to compile against + link the OpenXR loader.
+group("openxr_loader") {
+  public_configs = [
+    ":openxr_headers",
+    ":openxr_loader_link",
+  ]
+  public_deps = [ ":openxr_loader_dll" ]
+}
+
+# Stage openxr_loader.dll next to the final executable (content_shell.exe).
+copy("openxr_loader_dll") {
+  sources = [ "bin/openxr_loader.dll" ]
+  outputs = [ "$root_out_dir/openxr_loader.dll" ]
+}
diff --git a/third_party/displayxr/README.displayxr b/third_party/displayxr/README.displayxr
new file mode 100644
index 0000000000000..7c47c73f3aafd
--- /dev/null
+++ b/third_party/displayxr/README.displayxr
@@ -0,0 +1,22 @@
+Name: DisplayXR OpenXR loader + extension headers (inline-3D / XR_EXT_weave)
+Short Name: displayxr
+URL: https://github.com/DisplayXR
+Version: openxr_loader 1.1.43; DisplayXR runtime v1.24.0 headers
+License: Apache-2.0 (OpenXR loader), BSL-1.0 (DisplayXR extension headers)
+Security Critical: no (dev/reference patch, flag-gated, not shipped by default)
+
+Description:
+  Vendored dependencies for the DisplayXR inline-3D weave client (issue #625,
+  Step B). Lets a flag-gated Chromium build hand a canvas's pre-weave stereo
+  texture to the DisplayXR OS runtime over the shipped XR_EXT_weave RPC and
+  composite the woven result. The browser contains NO weave shader and NO vendor
+  code (ADR-007 / ADR-019) — only the OpenXR loader + the public extension
+  headers + the RPC call.
+
+Contents:
+  include/openxr/      OpenXR core + DisplayXR extension headers, synced from the
+                       runtime repo src/external/openxr_includes/openxr.
+  lib/openxr_loader.lib  Khronos OpenXR loader import lib (release-1.1.43, x64).
+  bin/openxr_loader.dll  Khronos OpenXR loader runtime (release-1.1.43, x64).
+
+Local modifications: none.
