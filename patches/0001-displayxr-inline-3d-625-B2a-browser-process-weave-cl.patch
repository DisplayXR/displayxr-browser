@@ -0,0 +1,29 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CONTENT_SHELL_BROWSER_DISPLAYXR_WEAVE_CLIENT_H_
+#define CONTENT_SHELL_BROWSER_DISPLAYXR_WEAVE_CLIENT_H_
+
+// DisplayXR inline-3D weave client (#625, Step B). Lives in the browser process
+// (unsandboxed) because the per-frame weave RPC to displayxr-service is IPC the
+// GPU sandbox blocks (see docs/roadmap/webxr-step-b-design.md). B2a scope: link
+// the OpenXR loader into content_shell, create a forced-IPC instance, and
+// confirm XR_EXT_weave is available — the Seam-C linking/process de-risk. The
+// per-frame weave + Mojo bridge to the GPU process land in B2b/B2c.
+//
+// This header is intentionally OpenXR-free so it can be included from ordinary
+// (chromium_code) translation units; all OpenXR types stay in the .cc.
+
+namespace content {
+
+class DisplayXRWeaveClient {
+ public:
+  // If --enable-inline-3d is on the command line, initialize the weave client
+  // (idempotent, browser process only). Safe no-op otherwise or on non-Windows.
+  static void MaybeInitializeFromCommandLine();
+};
+
+}  // namespace content
+
+#endif  // CONTENT_SHELL_BROWSER_DISPLAYXR_WEAVE_CLIENT_H_
