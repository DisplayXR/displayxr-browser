diff --git a/content/shell/browser/displayxr_weave_client.cc b/content/shell/browser/displayxr_weave_client.cc
new file mode 100644
index 0000000000000..428a15a6d561f
--- /dev/null
+++ b/content/shell/browser/displayxr_weave_client.cc
@@ -0,0 +1,181 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/shell/browser/displayxr_weave_client.h"
+
+#include "base/command_line.h"
+#include "base/compiler_specific.h"
+#include "base/logging.h"
+#include "build/build_config.h"
+
+#if BUILDFLAG(IS_WIN)
+#include <windows.h>
+
+#include <d3d11.h>
+
+#include <cstring>
+#include <string_view>
+#include <vector>
+
+#define XR_USE_GRAPHICS_API_D3D11
+#define XR_USE_PLATFORM_WIN32
+#include <openxr/openxr.h>
+#include <openxr/openxr_platform.h>
+
+#include <openxr/XR_EXT_display_info.h>
+#include <openxr/XR_EXT_weave.h>
+#include <openxr/XR_EXT_win32_window_binding.h>
+#endif  // BUILDFLAG(IS_WIN)
+
+namespace content {
+
+namespace {
+
+// The opt-in switch. Off by default — the patch is dormant unless requested.
+constexpr char kEnableInline3DSwitch[] = "enable-inline-3d";
+
+#if BUILDFLAG(IS_WIN)
+
+// File-static client state. B2a only proves instance + extension availability;
+// B2b/B2c add the session, the bound HWND, and the per-frame weave bridge.
+struct WeaveClientState {
+  XrInstance instance = XR_NULL_HANDLE;
+  XrSystemId system_id = XR_NULL_SYSTEM_ID;
+  bool has_weave = false;
+  PFN_xrWeaveBindWindowEXT bind_window = nullptr;
+  PFN_xrWeaveSubmitEXT submit = nullptr;
+  PFN_xrWeaveSnapWindowRectEXT snap = nullptr;
+  bool initialized = false;
+};
+
+WeaveClientState& State() {
+  static WeaveClientState* s = new WeaveClientState();
+  return *s;
+}
+
+bool HasExtension(const std::vector<XrExtensionProperties>& exts,
+                  const char* name) {
+  for (const auto& e : exts) {
+    if (std::string_view(e.extensionName) == name) {
+      return true;
+    }
+  }
+  return false;
+}
+
+void InitializeWin() {
+  WeaveClientState& s = State();
+  if (s.initialized) {
+    return;
+  }
+  s.initialized = true;
+
+  // The weave service is IPC-only; force the runtime onto the out-of-process
+  // path. Set it on the PROCESS environment block (not the CRT env) so the
+  // runtime DLL's own GetEnvironmentVariable sees it (the DLL has its own
+  // static CRT). Don't clobber an explicit override.
+  char existing[32] = {0};
+  if (::GetEnvironmentVariableA("XRT_FORCE_MODE", existing, sizeof(existing)) ==
+      0) {
+    ::SetEnvironmentVariableA("XRT_FORCE_MODE", "ipc");
+  }
+
+  uint32_t ext_count = 0;
+  if (XR_FAILED(xrEnumerateInstanceExtensionProperties(nullptr, 0, &ext_count,
+                                                       nullptr))) {
+    LOG(ERROR) << "[DisplayXR] xrEnumerateInstanceExtensionProperties failed "
+                  "(is the OpenXR loader / DisplayXR runtime installed?)";
+    return;
+  }
+  std::vector<XrExtensionProperties> exts(ext_count,
+                                          {XR_TYPE_EXTENSION_PROPERTIES});
+  if (XR_FAILED(xrEnumerateInstanceExtensionProperties(
+          nullptr, ext_count, &ext_count, exts.data()))) {
+    LOG(ERROR) << "[DisplayXR] failed to enumerate instance extensions";
+    return;
+  }
+
+  const bool has_d3d11 = HasExtension(exts, XR_KHR_D3D11_ENABLE_EXTENSION_NAME);
+  const bool has_window =
+      HasExtension(exts, XR_EXT_WIN32_WINDOW_BINDING_EXTENSION_NAME);
+  const bool has_display_info =
+      HasExtension(exts, XR_EXT_DISPLAY_INFO_EXTENSION_NAME);
+  s.has_weave = HasExtension(exts, XR_EXT_WEAVE_EXTENSION_NAME);
+
+  LOG(ERROR) << "[DisplayXR] inline-3D weave client (B2a): "
+             << "D3D11=" << has_d3d11 << " win32_window_binding=" << has_window
+             << " display_info=" << has_display_info
+             << " weave=" << s.has_weave;
+
+  if (!has_d3d11 || !has_window || !s.has_weave) {
+    LOG(ERROR) << "[DisplayXR] required extensions missing — weave unavailable "
+                  "on this runtime; inline-3D disabled";
+    return;
+  }
+
+  std::vector<const char*> enabled = {
+      XR_KHR_D3D11_ENABLE_EXTENSION_NAME,
+      XR_EXT_WIN32_WINDOW_BINDING_EXTENSION_NAME,
+      XR_EXT_WEAVE_EXTENSION_NAME,
+  };
+  if (has_display_info) {
+    enabled.push_back(XR_EXT_DISPLAY_INFO_EXTENSION_NAME);
+  }
+
+  XrInstanceCreateInfo ci = {XR_TYPE_INSTANCE_CREATE_INFO};
+  UNSAFE_TODO(std::strcpy(ci.applicationInfo.applicationName,
+                          "ChromiumInline3D"));
+  ci.applicationInfo.applicationVersion = 1;
+  UNSAFE_TODO(std::strcpy(ci.applicationInfo.engineName, "Chromium"));
+  ci.applicationInfo.apiVersion = XR_CURRENT_API_VERSION;
+  ci.enabledExtensionCount = static_cast<uint32_t>(enabled.size());
+  ci.enabledExtensionNames = enabled.data();
+
+  XrResult r = xrCreateInstance(&ci, &s.instance);
+  if (XR_FAILED(r)) {
+    LOG(ERROR) << "[DisplayXR] xrCreateInstance failed: " << r
+               << " (is displayxr-service running?)";
+    return;
+  }
+
+  XrSystemGetInfo sgi = {XR_TYPE_SYSTEM_GET_INFO};
+  sgi.formFactor = XR_FORM_FACTOR_HEAD_MOUNTED_DISPLAY;
+  r = xrGetSystem(s.instance, &sgi, &s.system_id);
+  if (XR_FAILED(r)) {
+    LOG(ERROR) << "[DisplayXR] xrGetSystem failed: " << r;
+    return;
+  }
+
+  xrGetInstanceProcAddr(s.instance, "xrWeaveBindWindowEXT",
+                        reinterpret_cast<PFN_xrVoidFunction*>(&s.bind_window));
+  xrGetInstanceProcAddr(s.instance, "xrWeaveSubmitEXT",
+                        reinterpret_cast<PFN_xrVoidFunction*>(&s.submit));
+  xrGetInstanceProcAddr(s.instance, "xrWeaveSnapWindowRectEXT",
+                        reinterpret_cast<PFN_xrVoidFunction*>(&s.snap));
+
+  LOG(ERROR) << "[DisplayXR] instance + system OK; weave PFNs: bindWindow="
+             << (s.bind_window ? "ok" : "NULL")
+             << " submit=" << (s.submit ? "ok" : "NULL")
+             << " snap=" << (s.snap ? "ok" : "NULL")
+             << " — B2a linking/process de-risk PASSED";
+}
+
+#endif  // BUILDFLAG(IS_WIN)
+
+}  // namespace
+
+// static
+void DisplayXRWeaveClient::MaybeInitializeFromCommandLine() {
+  if (!base::CommandLine::ForCurrentProcess()->HasSwitch(
+          kEnableInline3DSwitch)) {
+    return;
+  }
+#if BUILDFLAG(IS_WIN)
+  InitializeWin();
+#else
+  LOG(ERROR) << "[DisplayXR] inline-3D is Windows-only in Step B";
+#endif
+}
+
+}  // namespace content
