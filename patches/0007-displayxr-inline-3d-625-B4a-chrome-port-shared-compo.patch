   // task posted via PostAfterStartupTask until its complete.
   AfterStartupTaskUtils::StartMonitoringStartup();
+
+#if BUILDFLAG(IS_WIN)
+  // DisplayXR inline-3D (#625, Step B / B4): initialize the browser-process weave
+  // client after the first browser window is up. Deferred to a delayed UI-thread
+  // task because at PostBrowserStart the initial window's HWND exists but is not
+  // yet shown (the message loop hasn't pumped its ShowWindow), and the client's
+  // one-shot bindWindow needs a visible top-level window. Dormant unless
+  // --enable-inline-3d. (content_shell can call this synchronously because it
+  // shows its window synchronously in PreMainMessageLoopRun; chrome does not.)
