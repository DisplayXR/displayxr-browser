+++ b/components/displayxr/browser/BUILD.gn
@@ -0,0 +1,51 @@
+# Copyright 2026 The Chromium Authors / DisplayXR
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+# The OpenXR weave client (browser process, #625 Step B). Isolated source_set so
+# the vendored OpenXR headers compile with relaxed (non-chromium) warnings; the
+# header it exposes is OpenXR-free so consumers stay chromium_code. Lives in the
+# unsandboxed browser process because the per-frame weave RPC to displayxr-service
+# is IPC the GPU sandbox blocks.
+source_set("weave_client") {
+  sources = [
+    "displayxr_weave_client.cc",
+    "displayxr_weave_client.h",
+  ]
+  configs -= [ "//build/config/compiler:chromium_code" ]
+  configs += [ "//build/config/compiler:no_chromium_code" ]
+  deps = [ "//base" ]
+  if (is_win) {
+    deps += [ "//third_party/displayxr:openxr_loader" ]
+    libs = [
+      "d3d11.lib",
+      "dxgi.lib",
+    ]
+  }
+}
+
+# Browser-process Mojo impls: the GPU->browser weave bridge (DisplayXRWeaver) and
+# the frame-scoped renderer->browser inline-3d service (blink DisplayXRService).
+# Embedders (content_shell, chrome) wire these into their ContentBrowserClient
+# (BindGpuHostReceiver + the per-frame BrowserInterfaceBroker), gated
+# --enable-inline-3d.
+source_set("browser") {
+  sources = [
+    "displayxr_service_impl.cc",
+    "displayxr_service_impl.h",
+    "displayxr_weaver_impl.cc",
+    "displayxr_weaver_impl.h",
+  ]
+
+  # public_dep: the embedder's browser-main hook includes displayxr_weave_client.h
+  # directly (to initialize the client), so consumers of :browser must see it.
+  public_deps = [ ":weave_client" ]
+  deps = [
+    "//base",
+    "//components/displayxr/common:displayxr_weave_mojom",
+    "//mojo/public/cpp/bindings",
+    "//third_party/blink/public/mojom:displayxr_service_mojo_bindings",
+    "//ui/gfx",
+    "//ui/gfx/geometry",
+  ]
+}
