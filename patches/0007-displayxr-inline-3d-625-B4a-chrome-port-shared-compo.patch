+    "//mojo/public/cpp/bindings",
+    "//ui/gfx",
+    "//ui/gfx/geometry",
+  ]
+  if (is_win) {
+    libs = [
+      "d3d11.lib",
+      "dxgi.lib",
+    ]
+  }
+}
