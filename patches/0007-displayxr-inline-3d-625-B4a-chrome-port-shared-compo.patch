+# Copyright 2026 The Chromium Authors / DisplayXR
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+import("//mojo/public/tools/bindings/mojom.gni")
+
+# DisplayXR inline-3D weave bridge (#625, Step B): GPU/Viz -> browser per-frame
+# weave RPC, consumed by the browser (weaver impl) + GPU (weave provider) sides
+# of this shared component. Plain mojom() with NO export attributes — the regular
+# variant has a single consumer path, so the bindings compile straight into it; a
+# component export macro would be LNK4217. See docs/roadmap/webxr-step-b-design.md.
+mojom("displayxr_weave_mojom") {
+  sources = [ "displayxr_weave.mojom" ]
+  public_deps = [
+    "//ui/gfx/geometry/mojom",
+    "//ui/gfx/mojom",
+  ]
+}
