From 25149007505f78ebb7b6d0a9bff6e8dd7c7e5082 Mon Sep 17 00:00:00 2001
From: David <dfattal@gmail.com>
Date: Sat, 18 Jul 2026 05:51:23 +0000
Subject: [PATCH] =?UTF-8?q?inline-3d(625):=20macOS=20weave=20client=20PR1?=
 =?UTF-8?q?=20=E2=80=94=20MoltenVK=20IPC=20session=20bring-up?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Ports the browser-process weave client (DisplayXRWeaveClient statics) to
macOS. dlopen the OpenXR loader + MoltenVK (dormant when the DisplayXR runtime
is absent — the delay-load analogue), create a forced-IPC instance, a MoltenVK
device (XR_KHR_vulkan_enable), the present-owner weave session
(XrGraphicsBindingVulkanKHR — the only binding the mac IPC weave path accepts;
metal/vk native compositors are disabled in service mode and headless cant
weave), xrWeaveBindWindowDXR(0), and resolve the weave PFNs. Wires the IS_MAC
dispatcher branches (MaybeInitializeFromCommandLine/IsSupported/WeaveSpecVersion).
Mirrors test_apps/probes/weave_probe_vk_macos. Compiles + links on arm64.

PR2 adds LocateViewsForRect (eyes); PR3 the GPU-process IOSurface weave.
---
 components/displayxr/browser/BUILD.gn         |  21 +
 .../browser/displayxr_weave_client.cc         |  15 +-
 .../browser/displayxr_weave_client_mac.h      |  29 ++
 .../browser/displayxr_weave_client_mac.mm     | 443 ++++++++++++++++++
 4 files changed, 507 insertions(+), 1 deletion(-)
 create mode 100644 components/displayxr/browser/displayxr_weave_client_mac.h
 create mode 100644 components/displayxr/browser/displayxr_weave_client_mac.mm

diff --git a/components/displayxr/browser/BUILD.gn b/components/displayxr/browser/BUILD.gn
index 6e3f4079fadbe..091edc2fb2a67 100644
--- a/components/displayxr/browser/BUILD.gn
+++ b/components/displayxr/browser/BUILD.gn
@@ -26,6 +26,27 @@ component("weave_client") {
       "d3d11.lib",
       "dxgi.lib",
     ]
+  } else if (is_mac) {
+    # macOS PR1: the OpenXR loader + MoltenVK are dlopen'd at runtime (dormant
+    # when the DisplayXR runtime is absent — the delay-load analogue), so we
+    # need the HEADERS only, not the link. The weave session binds MoltenVK
+    # (XrGraphicsBindingVulkanKHR) — the only binding the mac IPC weave path
+    # accepts (see displayxr_weave_client_mac.mm).
+    sources += [
+      "displayxr_weave_client_mac.h",
+      "displayxr_weave_client_mac.mm",
+    ]
+    # Reference the vendored OpenXR headers' include dir DIRECTLY rather than the
+    # //third_party/displayxr:openxr_headers config — that BUILD.gn imports
+    # visual_studio_version.gni at file scope and only loads on Windows.
+    include_dirs = [ "//third_party/displayxr/include" ]
+    deps += [ "//third_party/vulkan-headers/src:vulkan_headers" ]
+    frameworks = [
+      "Foundation.framework",
+      "IOSurface.framework",
+      "Metal.framework",
+      "QuartzCore.framework",
+    ]
   }
 }
 
diff --git a/components/displayxr/browser/displayxr_weave_client.cc b/components/displayxr/browser/displayxr_weave_client.cc
index 5dcb2f7aff9b5..f74b4c5f71a86 100644
--- a/components/displayxr/browser/displayxr_weave_client.cc
+++ b/components/displayxr/browser/displayxr_weave_client.cc
@@ -43,6 +43,10 @@
 #include <openxr/XR_DXR_win32_window_binding.h>
 #endif  // BUILDFLAG(IS_WIN)
 
+#if BUILDFLAG(IS_MAC)
+#include "components/displayxr/browser/displayxr_weave_client_mac.h"
+#endif
+
 namespace displayxr {
 
 namespace {
@@ -1065,6 +1069,8 @@ DisplayXRWeaveClient::WeaveSubmitResult DisplayXRWeaveClient::SubmitBatch(
 uint32_t DisplayXRWeaveClient::WeaveSpecVersion() {
 #if BUILDFLAG(IS_WIN)
   return State().weave_spec_version;
+#elif BUILDFLAG(IS_MAC)
+  return WeaveSpecVersionMac();
 #else
   return 0;
 #endif
@@ -1074,6 +1080,8 @@ uint32_t DisplayXRWeaveClient::WeaveSpecVersion() {
 bool DisplayXRWeaveClient::IsSupported() {
 #if BUILDFLAG(IS_WIN)
   return IsSupportedWin();
+#elif BUILDFLAG(IS_MAC)
+  return IsSupportedMac();
 #else
   return false;
 #endif
@@ -1122,8 +1130,13 @@ void DisplayXRWeaveClient::MaybeInitializeFromCommandLine() {
   // 120 × 500ms = 60s: a dcheck_always_on build on a cold profile can take
   // well over 10s to show its first window; the retry is a no-op once bound.
   InitializeWin(/*attempts_left=*/120);
+#elif BUILDFLAG(IS_MAC)
+  // macOS PR1: bring up the MoltenVK-bound IPC weave session directly (no HWND
+  // retry — the runtime stores window id 0 and the snap is identity). Dormant
+  // when the runtime/loader is absent.
+  InitializeCoreMac();
 #else
-  LOG(ERROR) << "[DisplayXR] inline-3D is Windows-only in Step B";
+  LOG(ERROR) << "[DisplayXR] inline-3D is not supported on this platform yet";
 #endif
 }
 
diff --git a/components/displayxr/browser/displayxr_weave_client_mac.h b/components/displayxr/browser/displayxr_weave_client_mac.h
new file mode 100644
