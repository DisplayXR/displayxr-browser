+                  "mailbox.";
+    return nullptr;
+  }
+
+  // No SCANOUT enforcement here (see header): the canvas SI is DISPLAY_READ-only
+  // but the D3D overlay representation still exposes its ID3D11Texture2D, which
+  // is all the weave copy needs.
+  auto representation = backing->ProduceOverlay(this, tracker);
+  if (!representation) {
+    LOG(ERROR) << "SharedImageManager::ProduceOverlayForWeave: incompatible "
+                  "backing: "
+               << backing->GetName();
+    return nullptr;
+  }
+
+  return representation;
+}
