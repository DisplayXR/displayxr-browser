+  // sub-rects (Seam D) come in B3.
+  const DisplayXRWeaveProvider::Result r = provider->WeaveCanvas(
+      device_x.Get(), overlay_image->d3d11_video_texture(),
+      static_cast<UINT>(overlay_image->texture_array_slice()), gfx::Rect(size_),
+      gfx::Rect(size_));
   if (!r.ok) {
     return;
   }
