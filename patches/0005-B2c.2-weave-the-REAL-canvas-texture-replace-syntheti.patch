+  auto overlay = shared_image_representation_factory_->ProduceOverlayForWeave(
+      target->mailbox());
+  if (!overlay) {
+    return;
+  }
+  auto access = overlay->BeginScopedReadAccess();
+  if (!access) {
+    return;
+  }
+  std::optional<gl::DCLayerOverlayImage> overlay_image =
+      access->GetDCLayerOverlayImage();
+  if (!overlay_image ||
+      overlay_image->type() != gl::DCLayerOverlayType::kD3D11Texture ||
+      !overlay_image->d3d11_video_texture()) {
+    return;
+  }
