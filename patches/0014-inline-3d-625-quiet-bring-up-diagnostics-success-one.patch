-                     ? "  — B2a PASSED (window-bound weave session live)"
-                     : "  — bindWindow FAILED");
+  if (XR_SUCCEEDED(br)) {
+    VLOG(1) << "[DisplayXR] present-owner session bound; xrWeaveBindWindowEXT(hwnd="
+            << reinterpret_cast<void*>(s.hwnd) << ") -> " << br;
+  } else {
+    LOG(ERROR) << "[DisplayXR] xrWeaveBindWindowEXT(hwnd="
+               << reinterpret_cast<void*>(s.hwnd) << ") failed -> " << br;
+  }
 }
 
 // Drive one weave on the live present-owner session. Returns ok=false unless the
