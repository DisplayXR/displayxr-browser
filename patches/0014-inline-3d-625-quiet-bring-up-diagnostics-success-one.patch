   if (!has_d3d11 || !has_window || !s.has_weave) {
     LOG(ERROR) << "[DisplayXR] required extensions missing — weave unavailable "
@@ -241,9 +240,9 @@ void InitializeWin() {
       s.display_h_m = di.displaySizeMeters.height;
       s.display_px_w = di.displayPixelWidth;
       s.display_px_h = di.displayPixelHeight;
-      LOG(ERROR) << "[DisplayXR] display info: " << s.display_w_m << "x"
-                 << s.display_h_m << " m, " << s.display_px_w << "x"
-                 << s.display_px_h << " px";
+      VLOG(1) << "[DisplayXR] display info: " << s.display_w_m << "x"
+              << s.display_h_m << " m, " << s.display_px_w << "x"
+              << s.display_px_h << " px";
     }
   }
 
@@ -254,10 +253,10 @@ void InitializeWin() {
   xrGetInstanceProcAddr(s.instance, "xrWeaveSnapWindowRectEXT",
                         reinterpret_cast<PFN_xrVoidFunction*>(&s.snap));
 
-  LOG(ERROR) << "[DisplayXR] instance + system OK; weave PFNs: bindWindow="
-             << (s.bind_window ? "ok" : "NULL")
-             << " submit=" << (s.submit ? "ok" : "NULL")
-             << " snap=" << (s.snap ? "ok" : "NULL");
+  VLOG(1) << "[DisplayXR] instance + system OK; weave PFNs: bindWindow="
+          << (s.bind_window ? "ok" : "NULL")
+          << " submit=" << (s.submit ? "ok" : "NULL")
+          << " snap=" << (s.snap ? "ok" : "NULL");
   if (!s.bind_window || !s.submit) {
     LOG(ERROR) << "[DisplayXR] failed to resolve weave entry points";
     return;
@@ -312,11 +311,13 @@ void InitializeWin() {
   }
 
   XrResult br = s.bind_window(s.session, reinterpret_cast<void*>(s.hwnd));
-  LOG(ERROR) << "[DisplayXR] present-owner session + xrWeaveBindWindowEXT(hwnd="
-             << reinterpret_cast<void*>(s.hwnd) << ") -> " << br
