+import "ui/gfx/geometry/mojom/geometry.mojom";
+
+// DisplayXR inline-3D (#625, Step B): the glasses-free-3D display + runtime
+// geometry the WebXR "inline-3d" session needs, delivered renderer<-browser.
+struct DisplayXRDisplayInfo {
+  // Physical display dimensions.
+  float display_width_m;
+  float display_height_m;
+  uint32 display_width_px;
+  uint32 display_height_px;
+
+  // The woven canvas element's rect in physical-display device pixels
+  // (bound-window client origin + the GPU's latest committed weave rect). Only
+  // meaningful when |rect_valid| is true.
+  gfx.mojom.Rect element_display_rect;
+  bool rect_valid;
+};
+
+// Renderer -> browser, frame-scoped (bound via BrowserInterfaceBroker). The
+// browser process hosts the OpenXR weave client — the GPU sandbox forbids the
+// per-frame weave RPC to displayxr-service — so the inline-3d session pulls the
+// tracked eyes + committed element rect from here to build its off-axis
+// (Kooima) projections. Windows-only in practice; on other platforms the
+// interface is simply never bound and IsInline3DSupported() resolves false.
+interface DisplayXRService {
+  // True iff a glasses-free-3D display + runtime is present and a weave session
+  // is live. WebXR navigator.xr.isSessionSupported('inline-3d') resolves to it.
+  IsInline3DSupported() => (bool supported);
+
+  // Latest tracked eye positions in display-space metres, flattened xyz
+  // triples (empty and |valid| == false until tracking is available). |info|
+  // carries the display + element geometry for the per-eye off-axis projection.
+  GetLatestEyes() => (array<float> eyes, bool valid, DisplayXRDisplayInfo info);
+};
