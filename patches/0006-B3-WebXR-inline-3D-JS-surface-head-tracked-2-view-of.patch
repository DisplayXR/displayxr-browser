+        /*index=*/1, device::mojom::blink::XREye::kRight,
+        gfx::Rect(half_w, 0, w - half_w, h), graphics_api_));
+  }
+
+  const mojom::blink::DisplayXRDisplayInfo& di = *inline_3d_info_;
+  const float near_depth = static_cast<float>(render_state_->depthNear());
+  const float far_depth = static_cast<float>(render_state_->depthFar());
+
+  // Metres per device pixel (square pixels; derive from height).
+  const float pixel_m = di.display_height_px > 0
+                            ? di.display_height_m / di.display_height_px
+                            : 0.f;
+
+  // Element rect centre offset from the display centre + half-size, in
+  // display-space metres (+x right, +y up; screen y is top-down).
+  const gfx::Rect& er = di.element_display_rect;
+  const float disp_cx = di.display_width_px * 0.5f;
+  const float disp_cy = di.display_height_px * 0.5f;
+  const float elem_cx_m = (er.x() + er.width() * 0.5f - disp_cx) * pixel_m;
+  const float elem_cy_m = (disp_cy - (er.y() + er.height() * 0.5f)) * pixel_m;
+  const float half_w_m = er.width() * pixel_m * 0.5f;
+  const float half_h_m = er.height() * pixel_m * 0.5f;
+
+  const wtf_size_t eye_count =
+      static_cast<wtf_size_t>(inline_3d_eyes_.size() / 3u);
+  for (wtf_size_t i = 0; i < 2u; ++i) {
+    // eyes are ordered [left, right]; reuse eye 0 for both if only one tracked.
+    const wtf_size_t e = (eye_count >= 2u) ? i : 0u;
+    float ex = 0.f, ey = 0.f, ez = 0.5f;  // nominal 0.5 m if untracked
+    if (e < eye_count) {
+      ex = inline_3d_eyes_[e * 3u + 0u];
+      ey = inline_3d_eyes_[e * 3u + 1u];
+      ez = inline_3d_eyes_[e * 3u + 2u];
+    }
+    // Eye relative to the element centre; element plane at z = 0.
+    const float rx = ex - elem_cx_m;
+    const float ry = ey - elem_cy_m;
+    float rz = ez;
+    if (rz < 0.001f) {
+      rz = 0.65f;  // arm's-length fallback (avoid divide-by-zero, doc §7)
+    }
+    // Asymmetric half-angles: each element edge projected through the eye.
+    const float left_rad = std::atan2(half_w_m + rx, rz);
+    const float right_rad = std::atan2(half_w_m - rx, rz);
+    const float up_rad = std::atan2(half_h_m - ry, rz);
+    const float down_rad = std::atan2(half_h_m + ry, rz);
+
+    XRViewData* view = views_[i];
+    view->UpdateProjectionMatrixFromFoV(up_rad, down_rad, left_rad, right_rad,
+                                        near_depth, far_depth);
+    // Per-eye pose: place the eye at its display-space position (world origin =
+    // element centre), identity orientation. View faces -z toward the element.
+    gfx::Transform mojo_from_view;
+    mojo_from_view.Translate3d(rx, ry, rz);
+    view->SetMojoFromView(mojo_from_view);
+  }
+}
