+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// DisplayXR inline-3D (#625, Step B). Binds a WebXR 'inline-3d' session to a DOM
+// element (a canvas), opting it into glasses-free 3D via the OS weave RPC. See
+// docs/roadmap/webxr-displayxr-explainer.md. Deliberately NOT a subclass of
+// XRCompositionLayer for this reference implementation (the weave is compositor-
+// tag-driven; the Layers backend is not involved).
+[
+  SecureContext,
+  Exposed=Window,
+  RuntimeEnabled=DisplayXRInline3D
+] interface XRDisplayLayer {
+  [RaisesException]
+  constructor(XRSession session, Element target,
+              optional XRDisplayLayerInit init = {});
+
+  // The DOM element shown in 3D.
+  readonly attribute Element target;
+
+  // Per-eye viewport into the target (side-by-side halves).
+  XRViewport? getViewport(XRView view);
+
+  // Stop weaving the target.
+  undefined close();
+};
