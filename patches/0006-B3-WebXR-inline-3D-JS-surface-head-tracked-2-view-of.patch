+mojom::blink::DisplayXRService* XRSystem::EnsureDisplayXRService() {
+  if (displayxr_service_.is_bound()) {
+    return displayxr_service_.get();
+  }
+  if (displayxr_service_disconnected_ || is_context_destroyed_ ||
+      !DomWindow()) {
+    return nullptr;
+  }
+  DomWindow()->GetBrowserInterfaceBroker().GetInterface(
+      displayxr_service_.BindNewPipeAndPassReceiver(
+          DomWindow()->GetTaskRunner(TaskType::kMiscPlatformAPI)));
+  displayxr_service_.set_disconnect_handler(BindOnce(
+      &XRSystem::OnDisplayXRServiceDisconnected, WrapWeakPersistent(this)));
+  return displayxr_service_.get();
+}
+
+void XRSystem::OnInline3DSupportedResult(PendingSupportsSessionQuery* query,
+                                         bool supported) {
+  DCHECK(outstanding_inline3d_queries_.Contains(query));
+  outstanding_inline3d_queries_.erase(query);
+  query->Resolve(supported);
+}
+
+void XRSystem::OnDisplayXRServiceDisconnected() {
+  // The browser declined to bind the service (e.g. --enable-inline-3d off) or
+  // the pipe dropped. Latch it, reset, and fail every pending inline-3d support
+  // query as unsupported — the mojo replies will never arrive.
+  displayxr_service_disconnected_ = true;
+  displayxr_service_.reset();
+  HeapHashSet<Member<PendingSupportsSessionQuery>> queries;
+  queries.swap(outstanding_inline3d_queries_);
+  for (const auto& query : queries) {
+    query->Resolve(false);
+  }
+}
