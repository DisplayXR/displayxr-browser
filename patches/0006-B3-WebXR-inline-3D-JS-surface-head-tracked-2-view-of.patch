+namespace content {
+
+DisplayXRServiceImpl::DisplayXRServiceImpl() = default;
+DisplayXRServiceImpl::~DisplayXRServiceImpl() = default;
+
+// static
+void DisplayXRServiceImpl::Create(
+    mojo::PendingReceiver<blink::mojom::DisplayXRService> receiver) {
+  mojo::MakeSelfOwnedReceiver(std::make_unique<DisplayXRServiceImpl>(),
+                              std::move(receiver));
+}
+
+void DisplayXRServiceImpl::IsInline3DSupported(
+    IsInline3DSupportedCallback callback) {
+  std::move(callback).Run(DisplayXRWeaveClient::IsSupported());
+}
+
+void DisplayXRServiceImpl::GetLatestEyes(GetLatestEyesCallback callback) {
+  std::vector<float> eyes;
+  bool valid = false;
+  DisplayXRWeaveClient::DisplayInfo di;
+  DisplayXRWeaveClient::GetLatest(&eyes, &valid, &di);
+
+  auto info = blink::mojom::DisplayXRDisplayInfo::New();
+  info->display_width_m = di.display_width_m;
+  info->display_height_m = di.display_height_m;
+  info->display_width_px = di.display_width_px;
+  info->display_height_px = di.display_height_px;
+  info->element_display_rect =
+      gfx::Rect(di.element_x, di.element_y, static_cast<int>(di.element_w),
+                static_cast<int>(di.element_h));
+  info->rect_valid = di.element_rect_valid;
+
+  std::move(callback).Run(std::move(eyes), valid, std::move(info));
+}
+
+}  // namespace content
