+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_MODULES_XR_XR_DISPLAY_LAYER_H_
+#define THIRD_PARTY_BLINK_RENDERER_MODULES_XR_XR_DISPLAY_LAYER_H_
+
+#include "third_party/blink/renderer/platform/bindings/script_wrappable.h"
+#include "third_party/blink/renderer/platform/heap/garbage_collected.h"
+#include "third_party/blink/renderer/platform/heap/member.h"
+#include "third_party/blink/renderer/platform/heap/visitor.h"
+
+namespace blink {
+
+class Element;
+class ExceptionState;
+class XRDisplayLayerInit;
+class XRSession;
+class XRView;
+class XRViewport;
+
+// DisplayXR inline-3D (#625, Step B / B3). Binds a WebXR 'inline-3d' session to a
+// DOM element (a canvas), opting that element into glasses-free 3D: the browser
+// weaves the element's rendered stereo pair through the OS weave RPC and
+// composites the woven result at the element's on-screen rect.
+//
+// This is intentionally a LIGHTWEIGHT binding, not a subclass of the WebXR
+// Layers XRCompositionLayer: the actual weave is driven Viz-side off a per-layer
+// compositor tag (cc::TextureLayer::SetWeaveTarget), so wiring the heavyweight XR
+// Layers compositor backend would be pure overhead and the browser contains no
+// weave/vendor code (ADR-007/019). Constructing the layer tags the target
+// canvas; close() (or session end) untags it. Multiple layers -> multiple 3D
+// elements. The whole path is dormant unless content_shell was launched with
+// --enable-inline-3d; the JS surface is gated by the DisplayXRInline3D
+// RuntimeEnabledFeature.
+class XRDisplayLayer final : public ScriptWrappable {
+  DEFINE_WRAPPERTYPEINFO();
+
+ public:
+  static XRDisplayLayer* Create(XRSession* session,
+                                Element* target,
+                                const XRDisplayLayerInit* init,
+                                ExceptionState& exception_state);
+
+  XRDisplayLayer(XRSession* session, Element* target);
+  ~XRDisplayLayer() override;
+
+  // The DOM element shown in 3D.
+  Element* target() const { return target_.Get(); }
+
+  // Per-eye viewport into the target: left eye = left half, right eye = right
+  // half (side-by-side). Null if |view| is not from this layer's session.
+  XRViewport* getViewport(XRView* view);
+
+  // Stop weaving the target (untag its compositor layer). Idempotent.
+  void close();
+
+  void Trace(Visitor*) const override;
+
+ private:
+  Member<XRSession> session_;
+  Member<Element> target_;
+  // True while the target is tagged as a weave target.
+  bool active_ = false;
+};
+
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_MODULES_XR_XR_DISPLAY_LAYER_H_
