--- a/components/displayxr/common/displayxr_weave.mojom
+++ b/components/displayxr/common/displayxr_weave.mojom
@@ -54,4 +54,20 @@ interface DisplayXRWeaver {
   [EnableIf=is_win]
   WeaveSubmit(gfx.mojom.DXGIHandle texture, gfx.mojom.Rect rect)
       => (DisplayXRWeaveResult? result);
+
+  // #625 sync weave: report the tracked eyes to the browser process.
+  //
+  // In sync mode the GPU process owns the weave session and performs the
+  // submits, so the eyes come back THERE — while the browser process's
+  // weave-client cache (which DisplayXRService serves to the renderer, and
+  // which the renderer needs to build its off-axis views) is only ever written
+  // by a submit and so stays empty forever. That silently drops the inline-3d
+  // session to its mono fallback: one view at the origin, no look-around. Push
+  // the eyes over after each sync submit to keep the renderer fed.
+  //
+  // Fire-and-forget (no reply): a stale-by-a-frame eye set is harmless — the
+  // renderer already treats these as "latest known" — and a reply would put a
+  // round-trip on the zero-lag present thread.
+  [EnableIf=is_win]
+  ReportInline3DEyes(array<float> eyes, bool eyes_valid);
 };
