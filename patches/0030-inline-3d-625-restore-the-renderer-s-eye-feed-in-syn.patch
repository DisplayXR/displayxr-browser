+void DisplayXRWeaveGpu::ReportEyesToBrowser(const std::vector<float>& eyes,
+                                            bool eyes_valid) {
+  // Sync mode owns the weave session HERE, so the eyes land in this process —
+  // but the renderer reads them from the BROWSER process's weave-client cache
+  // (via DisplayXRService), which only a local submit would fill. Push them
+  // over so the renderer's off-axis views actually activate; without it the
+  // inline-3d session silently serves a single mono view at the origin (no
+  // cube, no look-around). Fire-and-forget: one frame of staleness is fine and
+  // a reply would cost a round-trip on the present thread.
+  if (!weaver_.is_bound()) {
+    return;
+  }
+  weaver_->ReportInline3DEyes(eyes, eyes_valid);
+}
