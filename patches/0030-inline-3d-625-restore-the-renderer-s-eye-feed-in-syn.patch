 void XRSession::RequestInline3DState() {
   mojom::blink::DisplayXRService* svc = xr_->EnsureDisplayXRService();
   if (!svc) {
     return;
   }
+  // Ask for views scoped to the SCENE layer's canvas. The browser only knows
+  // the last submitted weave rect, which on a page with several 3D windows is
+  // an arbitrary one — building the scene's off-axis frustum from a different
+  // element's rect would place the scene wrongly and at the wrong scale. An
+  // empty rect means "no scene layer": the browser falls back to the submitted
+  // rect (single-window pages).
+  gfx::Rect scene_rect = Inline3DSceneWindowRect();
   svc->GetLatestEyes(
-      BindOnce(&XRSession::OnInline3DState, WrapWeakPersistent(this)));
+      scene_rect, BindOnce(&XRSession::OnInline3DState, WrapWeakPersistent(this)));
+}
+
+// The scene layer's canvas rect in window-relative device px — the same basis
+// ReportInline3DRects uses for the weave rects, so the views and the woven
+// output describe the same element.
+gfx::Rect XRSession::Inline3DSceneWindowRect() const {
+  if (!inline_3d_scene_layer_) {
+    return gfx::Rect();
+  }
+  Element* target = inline_3d_scene_layer_->target();
+  if (!target) {
+    return gfx::Rect();
+  }
+  LocalDOMWindow* window = DynamicTo<LocalDOMWindow>(GetExecutionContext());
+  if (!window || !window->GetFrame()) {
+    return gfx::Rect();
+  }
+  DOMRect* r = target->GetBoundingClientRect();
+  if (!r) {
+    return gfx::Rect();
+  }
+  const double dsf = window->GetFrame()->DevicePixelRatio();
+  gfx::RectF css_rect(static_cast<float>(r->x()), static_cast<float>(r->y()),
+                      static_cast<float>(r->width()),
+                      static_cast<float>(r->height()));
+  css_rect.Scale(static_cast<float>(dsf));
+  return gfx::ToRoundedRect(css_rect);
 }
 
 void XRSession::OnInline3DState(const Vector<float>& eyes,
@@ -2557,6 +2596,12 @@ void XRSession::RegisterDisplayLayer(XRDisplayLayer* layer) {
 
 void XRSession::UnregisterDisplayLayer(XRDisplayLayer* layer) {
   display_layers_.erase(layer);
+  // A closed scene layer must stop scoping the views (its canvas is gone), or
+  // we'd keep building frusta for a stale rect.
+  if (inline_3d_scene_layer_ == layer) {
+    inline_3d_scene_layer_ = nullptr;
+    inline_3d_virtual_display_height_ = 0.f;
+  }
 }
 
