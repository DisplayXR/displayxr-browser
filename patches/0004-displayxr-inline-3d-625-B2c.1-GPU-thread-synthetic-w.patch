+// Static SBS test pattern (B2c.1): left half red, right half blue, in BGRA8 to
+// match the runtime's pre-weave input format. Distinct halves give the woven
+// interlace real left/right parallax, so a successful weave is visible as 3D.
+constexpr uint32_t kLeft = 0xFFFF0000u;   // BGRA bytes 00,00,FF,FF = red
+constexpr uint32_t kRight = 0xFF0000FFu;  // BGRA bytes FF,00,00,FF = blue
+}  // namespace
+
+DisplayXRWeaveGpu::DisplayXRWeaveGpu() = default;
+
+DisplayXRWeaveGpu::~DisplayXRWeaveGpu() {
+  if (input_handle_) {
+    ::CloseHandle(input_handle_);
+    input_handle_ = nullptr;
+  }
+}
+
+void DisplayXRWeaveGpu::Bind() {
+  ChildThread::Get()->BindHostReceiver(weaver_.BindNewPipeAndPassReceiver());
+}
+
+bool DisplayXRWeaveGpu::EnsureSyntheticInput(uint32_t w, uint32_t h) {
+  if (input_tex_ && input_w_ == w && input_h_ == h) {
+    return true;  // already sized + filled
+  }
+  input_tex_.Reset();
+  input_mutex_.Reset();
+  if (input_handle_) {
+    ::CloseHandle(input_handle_);
+    input_handle_ = nullptr;
+  }
+
+  if (!device_) {
+    const D3D_FEATURE_LEVEL levels[] = {D3D_FEATURE_LEVEL_11_1,
+                                        D3D_FEATURE_LEVEL_11_0};
+    D3D_FEATURE_LEVEL got = {};
+    const HRESULT hr = ::D3D11CreateDevice(
+        nullptr, D3D_DRIVER_TYPE_HARDWARE, nullptr, 0, levels, 2u,
+        D3D11_SDK_VERSION, &device_, &got, &context_);
+    if (FAILED(hr) || !device_) {
+      LOG(ERROR) << "[DisplayXR] B2c.1 synthetic input: D3D11CreateDevice "
+                    "failed: 0x"
+                 << std::hex << hr;
+      return false;
+    }
+  }
+
+  D3D11_TEXTURE2D_DESC td = {};
+  td.Width = w;
+  td.Height = h;
+  td.MipLevels = 1;
+  td.ArraySize = 1;
+  td.Format = DXGI_FORMAT_B8G8R8A8_UNORM;
+  td.SampleDesc.Count = 1;
+  td.Usage = D3D11_USAGE_DEFAULT;
+  td.BindFlags = D3D11_BIND_SHADER_RESOURCE;
+  td.MiscFlags =
+      D3D11_RESOURCE_MISC_SHARED_KEYEDMUTEX | D3D11_RESOURCE_MISC_SHARED_NTHANDLE;
+  HRESULT hr = device_->CreateTexture2D(&td, nullptr, &input_tex_);
+  if (FAILED(hr) || !input_tex_) {
+    LOG(ERROR) << "[DisplayXR] B2c.1 synthetic input: CreateTexture2D failed: 0x"
+               << std::hex << hr;
+    return false;
+  }
+  if (FAILED(input_tex_.As(&input_mutex_))) {
+    LOG(ERROR) << "[DisplayXR] B2c.1 synthetic input: no keyed mutex";
+    return false;
+  }
+  // The shared handle is opened by the EXTERNAL displayxr-service (not a Chromium
+  // process), and this texture is created in the sandboxed GPU process — its
+  // restricted token would otherwise give the object a DACL the service can't
+  // open. Grant an explicit null DACL (any process may open) so the service can
+  // OpenSharedResource1 it. (Same need will apply to the real canvas export in
+  // B2c.2.)
+  SECURITY_DESCRIPTOR sd = {};
+  ::InitializeSecurityDescriptor(&sd, SECURITY_DESCRIPTOR_REVISION);
+  ::SetSecurityDescriptorDacl(&sd, TRUE, /*pDacl=*/nullptr,
+                              /*bDaclDefaulted=*/FALSE);
