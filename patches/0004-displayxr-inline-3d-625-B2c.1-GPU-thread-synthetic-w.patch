+#include "mojo/public/cpp/bindings/remote.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace content {
+
+// GPU-process implementation of viz::DisplayXRWeaveProvider (#625 Step B, B2c.1).
+//
+// Owns: (a) the Mojo remote to the browser-process weave bridge (DisplayXRWeaver,
+// which drives the real xrWeaveSubmitEXT), and (b) a synthetic, GPU-owned
+// keyed-mutex side-by-side (SBS) input texture (a static test pattern) standing
+// in for the real canvas texture until B2c.2. Per weave it hands the synthetic
+// input + rect to the browser and returns the woven texture/fence handles to Viz
+// (SkiaOutputSurfaceImplOnGpu), which imports + composites them.
+//
+// Created, bound, and called on the GPU main thread.
+class DisplayXRWeaveGpu : public viz::DisplayXRWeaveProvider {
+ public:
+  DisplayXRWeaveGpu();
+  DisplayXRWeaveGpu(const DisplayXRWeaveGpu&) = delete;
+  DisplayXRWeaveGpu& operator=(const DisplayXRWeaveGpu&) = delete;
+  ~DisplayXRWeaveGpu() override;
+
+  // Bind the Mojo remote to the browser weave bridge. Call once on the GPU main
+  // thread (ChildThread must exist).
+  void Bind();
+
+  // viz::DisplayXRWeaveProvider:
+  Result WeaveSynthetic(const gfx::Rect& window_rect) override;
+
+ private:
+  // Lazily (re)create the synthetic SBS input + its shared NT handle at |w|x|h|
+  // and fill the static test pattern. Returns false on failure.
+  bool EnsureSyntheticInput(uint32_t w, uint32_t h);
+
+  mojo::Remote<shell::mojom::DisplayXRWeaver> weaver_;
+
+  // Own D3D11 device (runtime adapter) for the synthetic input, so we never poke
+  // Viz's DirectComposition device/context. The shared NT handle crosses devices
+  // to the service, which opens it on its own device.
+  Microsoft::WRL::ComPtr<ID3D11Device> device_;
+  Microsoft::WRL::ComPtr<ID3D11DeviceContext> context_;
+  Microsoft::WRL::ComPtr<ID3D11Texture2D> input_tex_;
+  Microsoft::WRL::ComPtr<IDXGIKeyedMutex> input_mutex_;
+  HANDLE input_handle_ = nullptr;  // NT shared handle (owned)
+  uint32_t input_w_ = 0;
+  uint32_t input_h_ = 0;
+};
+
+}  // namespace content
+
+#endif  // BUILDFLAG(IS_WIN)
+
+#endif  // CONTENT_SHELL_GPU_DISPLAYXR_WEAVE_GPU_H_
