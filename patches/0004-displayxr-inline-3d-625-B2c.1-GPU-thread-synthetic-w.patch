@@ -0,0 +1,60 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef COMPONENTS_VIZ_SERVICE_DISPLAY_EMBEDDER_DISPLAYXR_WEAVE_PROVIDER_H_
+#define COMPONENTS_VIZ_SERVICE_DISPLAY_EMBEDDER_DISPLAYXR_WEAVE_PROVIDER_H_
+
+#include "build/build_config.h"
+
+#if BUILDFLAG(IS_WIN)
+
+#include <cstdint>
+
+#include "components/viz/service/viz_service_export.h"
+#include "ui/gfx/geometry/rect.h"
+
+namespace viz {
+
+// DisplayXR inline-3D (#625, Step B) GPU-side weave hook.
+//
+// The per-frame weave RPC client lives in the BROWSER process (the GPU sandbox
+// blocks it; see docs/roadmap/webxr-step-b-design.md), but the woven texture
+// import + composite must run in the GPU process where the SharedImage factory
+// and the present live (SkiaOutputSurfaceImplOnGpu). Viz can't reach up to the
+// content/shell Mojo remote, so the embedder (ShellContentGpuClient) implements
+// this interface and registers it process-globally; Viz calls it on the GPU
+// main thread when a canvas quad is tagged as a weave target.
+class VIZ_SERVICE_EXPORT DisplayXRWeaveProvider {
+ public:
+  // Outcome of one weave (mirrors XrWeaveOutputEXT). All handles are Win32
+  // HANDLEs carried as uintptr_t; ownership transfers to the Viz caller, which
+  // is responsible for closing them. |woven_handle| / |fence_handle| are 0 on
+  // steady-state frames (reuse the previously imported texture / opened fence).
+  struct Result {
+    bool ok = false;
+    uintptr_t woven_handle = 0;
+    uintptr_t fence_handle = 0;
+    uint64_t fence_value = 0;
+    uint32_t width = 0;
+    uint32_t height = 0;
+  };
+
+  virtual ~DisplayXRWeaveProvider() = default;
+
+  // B2c.1: drive a weave from a synthetic (test-pattern) pre-weave SBS input the
+  // provider owns. |window_rect| is the element's window-relative device-pixel
+  // placement. Runs on the GPU main thread (blocks on the synchronous RPC).
+  virtual Result WeaveSynthetic(const gfx::Rect& window_rect) = 0;
+};
+
+// Register / fetch the process-global provider (GPU process, GPU main thread).
+// Passing nullptr clears it. Not owned.
+VIZ_SERVICE_EXPORT void SetDisplayXRWeaveProvider(DisplayXRWeaveProvider* p);
+VIZ_SERVICE_EXPORT DisplayXRWeaveProvider* GetDisplayXRWeaveProvider();
+
+}  // namespace viz
+
+#endif  // BUILDFLAG(IS_WIN)
+
+#endif  // COMPONENTS_VIZ_SERVICE_DISPLAY_EMBEDDER_DISPLAYXR_WEAVE_PROVIDER_H_
