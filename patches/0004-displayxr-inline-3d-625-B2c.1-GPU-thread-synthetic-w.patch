+  sa.nLength = sizeof(sa);
+  sa.lpSecurityDescriptor = &sd;
+  sa.bInheritHandle = FALSE;
+  ComPtr<IDXGIResource1> res1;
+  if (FAILED(input_tex_.As(&res1)) ||
+      FAILED(res1->CreateSharedHandle(
+          &sa, DXGI_SHARED_RESOURCE_READ | DXGI_SHARED_RESOURCE_WRITE, nullptr,
+          &input_handle_))) {
+    LOG(ERROR) << "[DisplayXR] B2c.1 synthetic input: CreateSharedHandle failed";
+    return false;
+  }
+
+  // Build the SBS test pattern on the CPU and upload it once. Acquire/release
+  // key 0 so the texture is handed off in the "caller done writing" state the
+  // runtime acquires (key 0 = runtime may read).
+  std::vector<uint32_t> pixels(static_cast<size_t>(w) * h);
+  const uint32_t mid = w / 2u;
+  for (uint32_t y = 0; y < h; ++y) {
+    const size_t row = static_cast<size_t>(y) * w;
+    for (uint32_t x = 0; x < w; ++x) {
+      pixels[row + x] = (x < mid) ? kLeft : kRight;
+    }
+  }
+  if (input_mutex_->AcquireSync(0, 1000) != S_OK) {
+    LOG(ERROR) << "[DisplayXR] B2c.1 synthetic input: AcquireSync(0) failed";
+    return false;
+  }
+  context_->UpdateSubresource(input_tex_.Get(), 0, nullptr, pixels.data(),
+                              w * 4u, 0);
+  context_->Flush();
+  input_mutex_->ReleaseSync(0);
+
+  input_w_ = w;
+  input_h_ = h;
+  LOG(ERROR) << "[DisplayXR] B2c.1 synthetic SBS input ready " << w << "x" << h
+             << " (NT handle=" << input_handle_ << ")";
+  return true;
+}
+
+viz::DisplayXRWeaveProvider::Result DisplayXRWeaveGpu::WeaveSynthetic(
+    const gfx::Rect& window_rect) {
+  Result out;
+  if (!weaver_.is_bound() || window_rect.IsEmpty()) {
+    return out;
+  }
+  if (!EnsureSyntheticInput(static_cast<uint32_t>(window_rect.width()),
+                            static_cast<uint32_t>(window_rect.height()))) {
+    return out;
+  }
+
+  // Duplicate the input handle for the Mojo message (it consumes/duplicates the
+  // handle into the browser process); keep our own for reuse.
+  HANDLE dup = nullptr;
+  if (!::DuplicateHandle(::GetCurrentProcess(), input_handle_,
+                         ::GetCurrentProcess(), &dup, 0, FALSE,
+                         DUPLICATE_SAME_ACCESS) ||
+      !dup) {
+    LOG(ERROR) << "[DisplayXR] B2c.1 weave: DuplicateHandle(input) failed";
+    return out;
+  }
+  gfx::DXGIHandle input{base::win::ScopedHandle(dup)};
+
+  shell::mojom::DisplayXRWeaveResultPtr result;
+  if (!weaver_->WeaveSubmit(std::move(input), window_rect, &result)) {
+    LOG(ERROR) << "[DisplayXR] B2c.1 weave: Sync WeaveSubmit call failed";
+    return out;
+  }
+  if (!result) {
+    return out;  // browser-side weave failed / session not live
+  }
+
+  out.ok = true;
+  out.fence_value = result->fence_value;
+  out.width = result->width;
+  out.height = result->height;
+  if (result->woven) {
+    out.woven_handle = reinterpret_cast<uintptr_t>(
+        result->woven->TakeBufferHandle().release());
+  }
+  if (result->fence) {
+    out.fence_handle = reinterpret_cast<uintptr_t>(
+        result->fence->TakeBufferHandle().release());
+  }
+  return out;
+}
+
+}  // namespace content
