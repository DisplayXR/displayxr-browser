+#if BUILDFLAG(IS_WIN)
+void SkiaOutputSurfaceImplOnGpu::MaybeWeaveSubstitute(
+    const std::vector<raw_ptr<ImageContextImpl, VectorExperimental>>&
+        image_contexts) {
+  DCHECK_CALLED_ON_VALID_THREAD(thread_checker_);
+  auto* provider = GetDisplayXRWeaveProvider();
+  if (!provider) {
+    return;
+  }
+  // Find the first canvas quad SkiaRenderer tagged as a weave target.
+  ImageContextImpl* target = nullptr;
+  for (ImageContextImpl* ctx : image_contexts) {
+    if (ctx && ctx->is_weave_target()) {
+      target = ctx;
+      break;
+    }
+  }
+  if (!target) {
+    return;
+  }
+  static bool s_logged_target = false;
+  if (!s_logged_target) {
+    s_logged_target = true;
+    LOG(ERROR) << "[DisplayXR] B2c.1 weave target found; driving synthetic weave";
+  }
+
+  // B2c.1: weave the full window from a synthetic SBS input. (B2c.2 will pass
+  // the real canvas texture + the element's sub-rect.)
+  const DisplayXRWeaveProvider::Result r =
+      provider->WeaveSynthetic(gfx::Rect(size_));
+  if (!r.ok) {
+    return;
+  }
+
+  // (Re)import the woven texture whenever a fresh handle arrives — that is the
+  // first weave and again on re-allocation (window resize). Steady-state frames
+  // return handle 0 and we reuse the imported SharedImage (the runtime re-weaves
+  // into the same texture in place).
+  if (r.woven_handle) {
+    if (!displayxr_woven_mailbox_.IsZero()) {
+      shared_image_factory_->DestroySharedImage(displayxr_woven_mailbox_);
+      displayxr_woven_mailbox_ = gpu::Mailbox();
+    }
+    gfx::DXGIHandle dxgi(
+        base::win::ScopedHandle(reinterpret_cast<HANDLE>(r.woven_handle)));
+    gpu::Mailbox mailbox = gpu::Mailbox::Generate();
+    gpu::SharedImageInfo si_info(
+        SinglePlaneFormat::kRGBA_8888,
+        gfx::Size(static_cast<int>(r.width), static_cast<int>(r.height)),
+        gfx::ColorSpace::CreateSRGB(), kTopLeft_GrSurfaceOrigin,
+        kPremul_SkAlphaType, gpu::SHARED_IMAGE_USAGE_DISPLAY_READ,
+        "DisplayXRWoven");
+    if (shared_image_factory_->CreateSharedImage(
+            mailbox, si_info, gfx::GpuMemoryBufferHandle(std::move(dxgi)))) {
+      displayxr_woven_mailbox_ = mailbox;
+    } else {
+      LOG(ERROR) << "[DisplayXR] B2c.1 failed to import woven SharedImage "
+                 << r.width << "x" << r.height;
+      return;
+    }
+  }
+  if (displayxr_woven_mailbox_.IsZero()) {
+    return;
+  }
+
+  // (Re)open + GPU-wait the service->caller fence so the woven content is ready
+  // before the canvas quad samples it. The woven texture has no keyed mutex
+  // (fence-synced), so this wait is the sole synchronization.
+  if (r.fence_handle) {
+    displayxr_weave_fence_ = gfx::D3DSharedFence::CreateFromUnownedHandle(
+        reinterpret_cast<HANDLE>(r.fence_handle));
