+// ---------------------------------------------------------------------------
+// GPU-process synchronous weave (#625, zero-lag spike).
+// ---------------------------------------------------------------------------
+
+// The service duplicates the woven output + fence handles INTO this GPU process
+// on the first weave submit (service->GPU DuplicateHandle). Its Medium-integrity
+// OpenProcess(PROCESS_DUP_HANDLE, gpu_pid) must pass this process object's DACL,
+// which the sandbox's lockdown default can strip the interactive user from.
+// Grant the current user PROCESS_DUP_HANDLE explicitly — pre-sandbox, while the
+// thread's impersonation token still holds WRITE_DAC. Other SANDBOXED processes
+// still fail their restricted-SID access check, so this does not reopen the
+// sandbox-to-sandbox handle-steal hole.
+void WidenProcessDaclForServiceDup() {
+  HANDLE token = nullptr;
+  if (!::OpenProcessToken(::GetCurrentProcess(), TOKEN_QUERY, &token)) {
+    LOG(ERROR) << "[DisplayXR] OpenProcessToken failed: " << ::GetLastError();
+    return;
+  }
+  BYTE user_buf[256] = {};
+  DWORD len = 0;
+  const BOOL got_user = ::GetTokenInformation(token, TokenUser, user_buf,
+                                              sizeof(user_buf), &len);
+  ::CloseHandle(token);
+  if (!got_user) {
+    LOG(ERROR) << "[DisplayXR] GetTokenInformation(TokenUser) failed: "
+               << ::GetLastError();
+    return;
+  }
+  PSID user_sid = reinterpret_cast<TOKEN_USER*>(user_buf)->User.Sid;
+
+  PACL old_dacl = nullptr;
+  PSECURITY_DESCRIPTOR sd = nullptr;
+  DWORD rc = ::GetSecurityInfo(::GetCurrentProcess(), SE_KERNEL_OBJECT,
+                               DACL_SECURITY_INFORMATION, nullptr, nullptr,
+                               &old_dacl, nullptr, &sd);
+  if (rc != ERROR_SUCCESS) {
+    LOG(ERROR) << "[DisplayXR] GetSecurityInfo(process) failed: " << rc;
+    return;
+  }
+
+  EXPLICIT_ACCESSW ea = {};
+  ea.grfAccessPermissions = PROCESS_DUP_HANDLE;
+  ea.grfAccessMode = GRANT_ACCESS;
+  ea.grfInheritance = NO_INHERITANCE;
+  ea.Trustee.TrusteeForm = TRUSTEE_IS_SID;
+  ea.Trustee.TrusteeType = TRUSTEE_IS_USER;
+  ea.Trustee.ptstrName = reinterpret_cast<LPWSTR>(user_sid);
+
+  PACL new_dacl = nullptr;
+  rc = ::SetEntriesInAclW(1, &ea, old_dacl, &new_dacl);
+  if (rc == ERROR_SUCCESS) {
+    rc = ::SetSecurityInfo(::GetCurrentProcess(), SE_KERNEL_OBJECT,
+                           DACL_SECURITY_INFORMATION, nullptr, nullptr,
+                           new_dacl, nullptr);
+    VLOG(1) << "[DisplayXR] process DACL widened for service woven-handle dup "
+               "(user PROCESS_DUP_HANDLE) -> rc="
+            << rc;
+  } else {
+    LOG(ERROR) << "[DisplayXR] SetEntriesInAcl failed: " << rc;
+  }
+  if (new_dacl) {
+    ::LocalFree(new_dacl);
+  }
+  if (sd) {
+    ::LocalFree(sd);
+  }
+}
+
+void PreSandboxInitializeForGpuProcessWin() {
+  WeaveClientState& s = State();
+  if (s.initialized) {
+    return;
+  }
+  const base::TimeTicks t0 = base::TimeTicks::Now();
+
+  WidenProcessDaclForServiceDup();
+
+  // Bounded wait for the BROWSER's main frame window — the GPU process
+  // launches before the browser shows it. 32 x 250ms = 8s cap (the GPU
+  // watchdog's init budget is finite); typical appearance is 1-3s.
+  const DWORD browser_pid =
+      static_cast<DWORD>(base::GetParentProcessId(::GetCurrentProcess()));
+  HWND hwnd = nullptr;
+  for (int i = 0; i < 32 && !hwnd; ++i) {
+    hwnd = FindMainWindowForProcess(browser_pid);
+    if (!hwnd) {
+      ::Sleep(250);
+    }
+  }
+  VLOG(1) << "[DisplayXR] pre-sandbox browser-window wait: hwnd=" << hwnd
+          << " (browser pid " << browser_pid << ") after "
+          << (base::TimeTicks::Now() - t0).InMilliseconds() << " ms";
+  if (!hwnd) {
+    return;  // weave stays dormant this GPU-process lifetime
+  }
+
+  InitializeCore(hwnd);
+  if (s.session == XR_NULL_HANDLE) {
+    LOG(ERROR) << "[DisplayXR] pre-sandbox weave session create FAILED "
+                  "(see messages above / runtime client log)";
+    return;
+  }
+  // Session is live and window-bound. Do NOT submit here: the FIRST
+  // xrWeaveSubmitDXR must be the real per-frame submit on Viz's present thread,
+  // so it (a) does the one-time woven-output export on that thread and (b) leaves
+  // the IPC connection untouched by any other thread. A pre-sandbox test submit
+  // pre-sets the runtime's per-session `exported` flag, which would suppress the
+  // export on the first real submit (Viz would never receive the woven handle).
+  VLOG(1) << "[DisplayXR] GPU-process weave session ready pre-sandbox (hwnd="
+          << hwnd << ")";
+}
