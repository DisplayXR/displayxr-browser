+bool DisplayXRWeaveGpu::SubmitSync(WeaveInput& in,
+                                   const gfx::Rect& window_rect,
+                                   uint32_t target_id) {
+  // #625 zero-lag: xrWeaveSubmitDXR directly on the GPU-process session — no
+  // mojo, no browser hop, no deadlock. The woven output comes back in this call,
+  // stored into results_ immediately so Viz's same-frame TryTakeWovenResult
+  // draws it at the current rect (zero lag). The input rides tagged as a legacy
+  // DXGI handle (see EnsureInput), so the runtime IPC needs no OpenProcess.
+  DisplayXRWeaveClient::WeaveSubmitResult sr = DisplayXRWeaveClient::Submit(
+      reinterpret_cast<uintptr_t>(in.input_handle), window_rect.x(),
+      window_rect.y(), window_rect.width(), window_rect.height(),
+      /*input_is_dxgi=*/true);
+  if (!sr.ok) {
+    return false;
+  }
+  static bool logged_sync = false;
+  if (!logged_sync) {
+    logged_sync = true;
+    VLOG(1) << "[DisplayXR] GPU-process SYNC weave live: target=" << target_id
+            << " woven=0x" << std::hex << sr.woven_handle << std::dec << " "
+            << sr.width << "x" << sr.height << " eyes_valid=" << sr.eyes_valid;
+  }
+
+  // Store the synchronous result exactly as OnWeaveReply would, so the existing
+  // Viz Phase-B import/draw path is unchanged. Fresh woven/fence handles arrive
+  // only on the first submit / a window-size change (steady frames carry 0);
+  // carry a still-pending fresh handle forward so Viz never misses the import.
+  PendingResult& pending = results_[target_id];
+  Result r;
+  r.ok = true;
+  r.fence_value = sr.fence_value;
+  r.width = sr.width;
+  r.height = sr.height;
+  if (sr.woven_handle) {
+    r.woven_handle = sr.woven_handle;
+  } else if (pending.have) {
+    r.woven_handle = pending.result.woven_handle;
+    pending.result.woven_handle = 0;
+  }
+  if (sr.fence_handle) {
+    r.fence_handle = sr.fence_handle;
+  } else if (pending.have) {
+    r.fence_handle = pending.result.fence_handle;
+    pending.result.fence_handle = 0;
+  }
+  if (pending.have) {
+    CloseResultHandles(pending.result);
+  }
+  pending.result = r;
+  pending.have = true;
+  return true;
+}
