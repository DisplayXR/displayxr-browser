diff --git a/components/viz/service/display_embedder/displayxr_weave_provider.h b/components/viz/service/display_embedder/displayxr_weave_provider.h
index ab0f0b6f224bf..8e5e7bc8d6cef 100644
--- a/components/viz/service/display_embedder/displayxr_weave_provider.h
+++ b/components/viz/service/display_embedder/displayxr_weave_provider.h
@@ -114,6 +114,21 @@ class VIZ_SERVICE_EXPORT DisplayXRWeaveProvider {
   virtual bool BatchMode() const;
   virtual void BeginBatchSync(const gfx::Size& window_size);
   virtual bool SubmitBatchSync();
+
+  // DP-composited 2D overlays (XR_DXR_weave spec v4, browser#18/#22). Set ONCE
+  // per batch frame, between BeginBatchSync and SubmitBatchSync, with a
+  // window-sized PREMULTIPLIED-alpha RGBA atlas the caller assembled (all 2D
+  // overlays flattened in z-order onto transparency). The atlas rides the batch
+  // submit as a second shared texture the runtime DP composites OVER the woven
+  // output (final = woven·(1 − a) + overlay), so the browser no longer composites
+  // overlays itself. |atlas_tex| / |array_slice| are the assembled atlas resolved
+  // on the GPU thread (its dims define the window size); copied into an owned
+  // keyed-mutex overlay input on |device|. Returns true if the atlas was staged.
+  // A frame that never calls this weaves with no overlay (unchanged). Default:
+  // no-op (non-batch providers don't carry overlays).
+  virtual bool SetBatchOverlay(ID3D11Device* device,
+                               ID3D11Texture2D* atlas_tex,
+                               UINT array_slice);
 };
 
 // Register / fetch the process-global provider (GPU process, GPU main thread).
diff --git a/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.cc b/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.cc
index 3c7c8eda92acc..5edc4da1aa2e6 100644
--- a/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.cc
+++ b/components/viz/service/display_embedder/skia_output_surface_impl_on_gpu.cc
@@ -3174,18 +3174,167 @@ void SkiaOutputSurfaceImplOnGpu::WeaveCompositedSurface(SkSurface* output,
       displayxr_drawn_rect_[t] = gfx::Rect();
     }
   }
+
+  // v4 (browser#18/#22): assemble this frame's isolated 2D overlays into ONE
+  // window-sized premultiplied-alpha atlas and stage it as the runtime DP's
+  // overlay input, so the DP composites 2D OVER the woven output
+  // (final = woven·(1 − a) + overlay). This REPLACES the browser-side kSrcOver
+  // draw-back that used to run in Phase B — the overlays now travel through the
+  // weave submit and land glued to their tiles (no main-thread-rect scroll lag).
+  // Runs before SubmitBatchSync (the overlay rides that submit). Any failure just
+  // skips the overlay this frame; the weave itself is unaffected.
+  if (batch && !inline_3d_overlays_.empty()) {
+    auto stage_overlay_atlas = [&]() -> bool {
+      DisplayXRScratchState& atlas = displayxr_overlay_atlas_state_;
+      // (1) Ensure a window-sized RGBA8 premul atlas (same overlay-exposable
+      // D3DImageBacking recipe as the weave scratch: DISPLAY_READ/WRITE keeps a
+      // sampleable ID3D11Texture2D, CPU_READ forces D3DImageBackingFactory and
+      // avoids the DComp-visual path). Recreated only on a window-size change.
+      if (atlas.mailbox.IsZero() || atlas.size != window_bounds.size()) {
+        if (!atlas.mailbox.IsZero()) {
+          shared_image_factory_->DestroySharedImage(atlas.mailbox);
+          skia_representations_.erase(atlas.mailbox);
+          atlas.mailbox = gpu::Mailbox();
+        }
+        gpu::Mailbox mailbox = gpu::Mailbox::Generate();
+        gpu::SharedImageInfo si_info(
+            SinglePlaneFormat::kRGBA_8888, window_bounds.size(),
+            gfx::ColorSpace::CreateSRGB(), kTopLeft_GrSurfaceOrigin,
+            kPremul_SkAlphaType,
+            gpu::SHARED_IMAGE_USAGE_DISPLAY_READ |
+                gpu::SHARED_IMAGE_USAGE_DISPLAY_WRITE |
+                gpu::SHARED_IMAGE_USAGE_CPU_READ,
+            "DisplayXROverlayAtlas");
+        if (!shared_image_factory_->CreateSharedImage(
+                mailbox, si_info, gpu::kNullSurfaceHandle)) {
+          return false;
+        }
+        atlas.mailbox = mailbox;
+        atlas.size = window_bounds.size();
+      }
+
+      // (2) Composite every isolated overlay kSrcOver into the (cleared) atlas at
+      // its compositor-exact window rect — the same per-overlay resolve/draw the
+      // old Phase-B block did, but into the atlas surface (z-order + overlap +
+      // translucency resolved here) instead of |out_canvas|.
+      int composited = 0;
+      {
+        auto atlas_rep = shared_image_representation_factory_->ProduceSkia(
+            atlas.mailbox, context_state_.get());
+        if (!atlas_rep) {
+          return false;
+        }
+        std::vector<GrBackendSemaphore> abegin, aend;
+        SkSurfaceProps props;
+        auto atlas_write = atlas_rep->BeginScopedWriteAccess(
+            /*final_msaa_count=*/0, props, &abegin, &aend,
+            gpu::SharedImageRepresentation::AllowUnclearedAccess::kYes);
+        if (!atlas_write || !atlas_write->surface()) {
+          return false;
+        }
+        SkSurface* atlas_surface = atlas_write->surface();
+        if (!abegin.empty()) {
+          atlas_surface->wait(abegin.size(), abegin.data(),
+                              /*deleteSemaphoresAfterWait=*/false);
+        }
+        // Reused across frames: clear last frame's overlays first (transparent =
+        // show the weave through; the premultiplied alpha is the 2D-vs-3D mask).
+        atlas_surface->getCanvas()->clear(SK_ColorTRANSPARENT);
+        SkPaint over_paint;
+        over_paint.setBlendMode(SkBlendMode::kSrcOver);
+        for (const SkiaOutputSurface::Inline3dLayerMailbox& overlay :
+             inline_3d_overlays_) {
+          gfx::Rect r = overlay.rect;
+          r.Intersect(window_bounds);
+          if (r.IsEmpty() || overlay.mailbox.IsZero()) {
+            continue;
+          }
+          auto overlay_rep = shared_image_representation_factory_->ProduceSkia(
+              overlay.mailbox, context_state_.get());
+          if (!overlay_rep) {
+            continue;
+          }
+          std::vector<GrBackendSemaphore> obegin, oend;
+          auto overlay_access =
+              overlay_rep->BeginScopedReadAccess(&obegin, &oend);
+          if (!overlay_access) {
+            continue;
+          }
+          sk_sp<SkImage> overlay_img =
+              overlay_access->CreateSkImage(context_state_.get());
+          if (!overlay_img) {
+            continue;
+          }
+          if (!obegin.empty()) {
+            atlas_surface->wait(obegin.size(), obegin.data(),
+                                /*deleteSemaphoresAfterWait=*/false);
+          }
+          const SkRect src =
+              SkRect::MakeWH(overlay_img->width(), overlay_img->height());
+          const SkRect dst =
+              SkRect::MakeXYWH(r.x(), r.y(), r.width(), r.height());
+          atlas_surface->getCanvas()->drawImageRect(
+              overlay_img.get(), src, dst,
+              SkSamplingOptions(SkFilterMode::kLinear), &over_paint,
+              SkCanvas::kStrict_SrcRectConstraint);
+          ++composited;
+        }
+        FlushSurface(atlas_surface, aend, atlas_write.get());
+        if (gr_context()) {
+          gr_context()->submit();
