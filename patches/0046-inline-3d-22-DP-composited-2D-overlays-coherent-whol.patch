+    ResetInput(overlay_input_);
     batch_mutex_held_ = false;
     device_ = device;
     context_.Reset();
@@ -434,6 +436,45 @@ void DisplayXRWeaveGpu::BeginBatchSync(const gfx::Size& window_size) {
   batch_open_ = true;
   batch_size_ = window_size;
   batch_entries_.clear();
+  // v4: the overlay atlas is opt-in per frame. Cleared here so a frame with no
+  // overlays does not re-submit the previous frame's (stale) atlas.
+  overlay_set_this_batch_ = false;
+}
+
+// v4 DP-composited 2D overlays (browser#18/#22): stage the caller's window-sized
+// premultiplied-alpha RGBA atlas into a keyed-mutex overlay input whose legacy
+// DXGI handle rides the batch submit's XrWeaveSubmitOverlaysDXR chain. The whole
+// atlas is composited by the runtime DP (premul alpha authoritative), so there is
+// one full-resource copy, no per-overlay rects. Call once per batch frame between
+// BeginBatchSync and SubmitBatchSync.
+bool DisplayXRWeaveGpu::SetBatchOverlay(ID3D11Device* device,
+                                        ID3D11Texture2D* atlas_tex,
+                                        UINT array_slice) {
+  if (!batch_open_ || !device || !atlas_tex) {
+    return false;
+  }
+  D3D11_TEXTURE2D_DESC ad = {};
+  atlas_tex->GetDesc(&ad);
+  // EnsureInput allocates the overlay input on |device| with the atlas's own
+  // format/size and exports the legacy-DXGI keyed-mutex handle (same branch as the
+  // SBS input; sync mode → GetSharedHandle). Recreated only on size/format change.
+  if (!EnsureInput(overlay_input_, device, ad.Format, ad.Width, ad.Height)) {
+    return false;
+  }
+  if (overlay_input_.input_mutex->AcquireSync(0, 1000) != S_OK) {
+    LOG(ERROR) << "[DisplayXR] batch weave overlay: AcquireSync(0) failed";
+    return false;
+  }
+  // One whole-resource copy of the assembled premul atlas into the shared input
+  // (dims match by construction), respecting the source array slice.
+  context_->CopySubresourceRegion(overlay_input_.input_tex.Get(),
+                                  /*DstSubresource=*/0, /*DstX=*/0, /*DstY=*/0,
+                                  /*DstZ=*/0, atlas_tex, array_slice,
+                                  /*pSrcBox=*/nullptr);
+  context_->Flush();
+  overlay_input_.input_mutex->ReleaseSync(0);
+  overlay_set_this_batch_ = true;
+  return true;
 }
 
 bool DisplayXRWeaveGpu::EnsureBatchInputAndAcquire(ID3D11Device* device,
@@ -611,10 +652,17 @@ bool DisplayXRWeaveGpu::SubmitBatchSync() {
     rects.push_back({e.rect.x(), e.rect.y(), e.rect.width(), e.rect.height()});
   }
 
+  // v4: hand the overlay atlas alongside the content input when one was staged
+  // this frame; 0 otherwise (runtime omits the overlay chain). Legacy DXGI like
+  // the content input (sync mode, Low-integrity GPU process).
+  const uintptr_t overlay_handle =
+      overlay_set_this_batch_
+          ? reinterpret_cast<uintptr_t>(overlay_input_.input_handle)
+          : 0;
   const base::TimeTicks t0 = base::TimeTicks::Now();
   DisplayXRWeaveClient::WeaveSubmitResult sr = DisplayXRWeaveClient::SubmitBatch(
       reinterpret_cast<uintptr_t>(shared_input_.input_handle), rects,
-      /*input_is_dxgi=*/true);
+      /*input_is_dxgi=*/true, overlay_handle, /*overlay_is_dxgi=*/true);
   const base::TimeDelta dt = base::TimeTicks::Now() - t0;
   if (!sr.ok) {
     static int s_fail = 0;
