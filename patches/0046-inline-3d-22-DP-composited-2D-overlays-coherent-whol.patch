 #if BUILDFLAG(IS_WIN)
-  return SubmitWin(input_handle, x, y, w, h, input_is_dxgi);
+  return SubmitWin(input_handle, x, y, w, h, input_is_dxgi, overlay_handle,
+                   overlay_is_dxgi);
 #else
   return {};
 #endif
@@ -1053,9 +1092,12 @@ DisplayXRWeaveClient::WeaveSubmitResult DisplayXRWeaveClient::Submit(
 DisplayXRWeaveClient::WeaveSubmitResult DisplayXRWeaveClient::SubmitBatch(
     uintptr_t input_handle,
     const std::vector<WeaveRect>& rects,
-    bool input_is_dxgi) {
