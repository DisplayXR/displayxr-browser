+    bool overlay_is_dxgi = false) {
   const size_t rect_count = rects.size();
   DisplayXRWeaveClient::WeaveSubmitResult result;
   WeaveClientState& s = State();
@@ -719,6 +735,26 @@ DisplayXRWeaveClient::WeaveSubmitResult SubmitBatchWin(
     in.inputTexture = reinterpret_cast<void*>(input_handle);
     in.inputIsDxgi = input_is_dxgi ? XR_TRUE : XR_FALSE;
     // Base rect is ignored under the batch chain; keep it zero.
+    // v5 (browser#22): mark the FIRST chunk of the frame so the runtime clears
+    // its window-sized woven output to transparent before weaving — gaps between
+    // tiles come out transparent (not stale), letting Viz present the woven
+    // output WHOLE-WINDOW. Later chunks (done > 0) accumulate into the same
+    // output. No-op on a spec<5 runtime (the field is past its struct; ignored).
+    in.firstChunk = (done == 0) ? XR_TRUE : XR_FALSE;
+
+    // v4 (browser#18/#22): the DP-composited 2D overlay atlas composites OVER the
+    // whole woven output, so chain it on the LAST chunk only — it must land once,
+    // on top, after every rect has woven. Splice ahead of the rects struct
+    // (OpenXR next-chains are unordered) so the batch layout is preserved.
+    XrWeaveSubmitOverlaysDXR overlays = {XR_TYPE_WEAVE_SUBMIT_OVERLAYS_DXR};
+    const bool last_chunk = (done + n) >= rect_count;
+    if (overlay_handle != 0 && last_chunk && s.weave_spec_version >= 4) {
+      overlays.overlayTexture = reinterpret_cast<void*>(overlay_handle);
+      overlays.overlayIsDxgi = overlay_is_dxgi ? XR_TRUE : XR_FALSE;
+      overlays.rectCount = 0;  // whole-atlas composite (premul alpha authoritative)
+      overlays.next = &batch;
+      in.next = &overlays;
+    }
 
     XrWeaveOutputDXR out = {XR_TYPE_WEAVE_OUTPUT_DXR};
     const XrResult sr = s.submit(s.session, &in, &out);
@@ -1041,9 +1077,12 @@ DisplayXRWeaveClient::WeaveSubmitResult DisplayXRWeaveClient::Submit(
     int32_t y,
     int32_t w,
     int32_t h,
-    bool input_is_dxgi) {
