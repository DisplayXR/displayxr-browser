diff --git a/third_party/blink/renderer/modules/xr/xr_display_layer_exclusion_init.idl b/third_party/blink/renderer/modules/xr/xr_display_layer_exclusion_init.idl
new file mode 100644
index 0000000000000..7c65ddd6ac915
--- /dev/null
+++ b/third_party/blink/renderer/modules/xr/xr_display_layer_exclusion_init.idl
@@ -0,0 +1,21 @@
+// Copyright 2026 The Chromium Authors / DisplayXR
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+// DisplayXR inline-3D overlay exclusion (browser#18). How an excluded 2D
+// element composites against the woven 3D output, per the zone formalism
+//   final = M*weave + (1-M)*2D          (per-pixel scalar mask M)
+// "over"  — the 2D overlay wins the pixel (M=0 inside the exclusion rect);
+//           the only mode implemented in v1.
+// "under" — reserved: 2D composited beneath the weave. Named now so adding it
+//           later is not a breaking change; requesting it throws
+//           NotSupportedError.
+enum XRDisplayLayerExclusionComposite {
+  "over",
+  "under"
+};
+
+// Options for XRDisplayLayer.excludeElement().
+dictionary XRDisplayLayerExclusionInit {
+  XRDisplayLayerExclusionComposite composite = "over";
+};
diff --git a/third_party/blink/renderer/modules/xr/xr_session.cc b/third_party/blink/renderer/modules/xr/xr_session.cc
index 35c0b29efce4c..8c1a788af22c2 100644
--- a/third_party/blink/renderer/modules/xr/xr_session.cc
+++ b/third_party/blink/renderer/modules/xr/xr_session.cc
@@ -2664,31 +2664,52 @@ void XRSession::ReportInline3DRects() {
     return;
   }
   const double dsf = frame->DevicePixelRatio();
+  // getBoundingClientRect() is viewport-relative CSS px; the composited output
+  // is window-relative device px. For the main frame the visual-viewport origin
+  // maps to the widget origin, so device px = CSS px x DSF (pinch-zoom /
+  // multi-monitor origin refinements are deferred).
+  auto device_rect_of = [dsf](Element* el) {
+    DOMRect* r = el->GetBoundingClientRect();
+    if (!r) {
+      return gfx::Rect();
+    }
+    gfx::RectF css_rect(static_cast<float>(r->x()), static_cast<float>(r->y()),
+                        static_cast<float>(r->width()),
+                        static_cast<float>(r->height()));
+    css_rect.Scale(static_cast<float>(dsf));
+    return gfx::ToRoundedRect(css_rect);
+  };
   std::vector<gfx::Rect> rects;
   rects.reserve(display_layers_.size());
+  // Overlay-exclusion rects (browser#18): 2D UI the page declared as painted
+  // over a woven element (XRDisplayLayer.excludeElement). They ride the same
+  // metadata push so holes arrive atomically with the frame's pixels; Viz
+  // associates them to weave targets geometrically (exclusion ∩ target rect),
+  // so a single flat list serves every layer. Disconnected / display:none
+  // overlays yield an empty rect and drop out here. Not clipped to the layer
+  // rect on purpose — the GPU stage clips against the (scroll-exact,
+  // possibly tracked-channel) target rect, not this main-thread one.
+  std::vector<gfx::Rect> exclusion_rects;
   for (const auto& layer : display_layers_) {
     Element* target = layer->target();
     if (!target) {
       continue;
     }
-    // getBoundingClientRect() is viewport-relative CSS px; the composited output
-    // is window-relative device px. For the main frame the visual-viewport origin
-    // maps to the widget origin, so device px = CSS px x DSF (pinch-zoom /
-    // multi-monitor origin refinements are deferred).
-    DOMRect* r = target->GetBoundingClientRect();
-    if (!r) {
-      continue;
-    }
-    gfx::RectF css_rect(static_cast<float>(r->x()), static_cast<float>(r->y()),
-                        static_cast<float>(r->width()),
-                        static_cast<float>(r->height()));
-    css_rect.Scale(static_cast<float>(dsf));
-    gfx::Rect device_rect = gfx::ToRoundedRect(css_rect);
+    gfx::Rect device_rect = device_rect_of(target);
     if (!device_rect.IsEmpty()) {
       rects.push_back(device_rect);
     }
+    for (const auto& excluded : layer->excluded_elements()) {
+      if (!excluded->isConnected()) {
+        continue;
+      }
+      gfx::Rect hole = device_rect_of(excluded);
+      if (!hole.IsEmpty()) {
+        exclusion_rects.push_back(hole);
+      }
+    }
   }
-  widget->SetInline3DRects(rects);
+  widget->SetInline3DRects(rects, exclusion_rects);
 }
 
