+void XRDisplayLayer::excludeElement(Element* element,
+                                    const XRDisplayLayerExclusionInit* init,
+                                    ExceptionState& exception_state) {
+  if (!active_) {
+    exception_state.ThrowDOMException(DOMExceptionCode::kInvalidStateError,
+                                      "The layer is closed.");
+    return;
+  }
+  if (!element) {
+    exception_state.ThrowTypeError("element must not be null.");
+    return;
+  }
+  // v1 implements 2D-over only (the overlay wins the pixel, M=0 in the
+  // exclusion rect — the runtime auto-wish default). 2D-under is reserved in
+  // the enum so adding it later is additive, not breaking.
+  if (init && init->composite().AsEnum() ==
+                  V8XRDisplayLayerExclusionComposite::Enum::kUnder) {
+    exception_state.ThrowDOMException(
+        DOMExceptionCode::kNotSupportedError,
+        "composite:\"under\" is reserved for a future release; only "
+        "\"over\" is supported.");
+    return;
+  }
+  excluded_elements_.insert(element);
+}
+
+void XRDisplayLayer::unexcludeElement(Element* element) {
+  if (element) {
+    excluded_elements_.erase(element);
+  }
+}
+
 void XRDisplayLayer::close() {
   if (!active_) {
     return;
   }
   active_ = false;
+  excluded_elements_.clear();
   if (session_) {
     session_->UnregisterDisplayLayer(this);
   }
@@ -106,6 +140,7 @@ void XRDisplayLayer::close() {
 void XRDisplayLayer::Trace(Visitor* visitor) const {
   visitor->Trace(session_);
   visitor->Trace(target_);
+  visitor->Trace(excluded_elements_);
   ScriptWrappable::Trace(visitor);
 }
 
